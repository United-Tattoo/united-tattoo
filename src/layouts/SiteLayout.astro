---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import Announcement from '../components/Announcement.astro';
import HeaderNav from '../components/HeaderNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Schema from '../components/Schema.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article' | 'profile';
  frontmatter?: {
    title?: string;
    description?: string;
    image?: string;
  };
	  announcement?: string;
	  hideAnnouncement?: boolean;
	  removeMainPadding?: boolean;
	  disableSmoothScroll?: boolean;
	  hideFooter?: boolean;
  artistSchema?: {
    name: string;
    description: string;
    image: string;
    sameAs?: string[];
  };
  articleSchema?: {
    headline: string;
    datePublished: Date | string;
    dateModified?: Date | string;
    author: string;
    keywords?: string[];
  };
  breadcrumbs?: {
    name: string;
    url: string;
  }[];
}

const {
  frontmatter,
  hideAnnouncement = false,
  removeMainPadding = false,
  disableSmoothScroll = false,
  hideFooter = false,
  announcement,
  image = '/images/united-studio-main.avif',
  type = 'website',
  artistSchema,
  articleSchema,
  breadcrumbs,
  ...props 
} = Astro.props;

const title = props.title || frontmatter?.title || '';
const description = props.description || frontmatter?.description || 'Tattoo studio in Fountain, CO';
const currentPath = Astro.url.pathname;
const siteUrl = Astro.site ? Astro.site.toString() : 'https://unitedtattoo.com';
const canonicalUrl = new URL(currentPath, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();
---

<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
    <ClientRouter />
		
    <!-- SEO -->
    <title>{title ? `${title} | ${SITE_TITLE}` : SITE_TITLE}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title ? `${title} | ${SITE_TITLE}` : SITE_TITLE} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title ? `${title} | ${SITE_TITLE}` : SITE_TITLE} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    {type === 'article' && articleSchema && (
      <>
        <meta property="article:published_time" content={new Date(articleSchema.datePublished).toISOString()} />
        <meta property="article:modified_time" content={new Date(articleSchema.dateModified || articleSchema.datePublished).toISOString()} />
        <meta property="article:author" content={articleSchema.author} />
        {articleSchema.keywords?.map((tag) => (
          <meta property="article:tag" content={tag} />
        ))}
      </>
    )}

    <!-- Schema.org JSON-LD -->
    <Schema 
      type={type} 
      title={title} 
      description={description} 
      image={image} 
      canonicalUrl={canonicalUrl}
      artistData={artistSchema}
      articleData={articleSchema}
      breadcrumbs={breadcrumbs}
    />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100;200;300;400;500;600;700&family=Geist+Mono:wght@300;400;500;600&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap" rel="stylesheet">
		<!-- Icons -->
		<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
	</head>
		<body class="bg-background text-foreground selection:bg-primary/20 selection:text-foreground" data-smooth-scroll={disableSmoothScroll ? 'disabled' : 'enabled'}>
		<!-- Lenis + GSAP ScrollTrigger Setup -->
		<script>
			import Lenis from 'lenis';
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			// Register GSAP plugins
			gsap.registerPlugin(ScrollTrigger);

			const smoothScrollEnabled = document.body.dataset.smoothScroll !== 'disabled';

			if (smoothScrollEnabled) {
				// Initialize Lenis for smooth scrolling on editorial pages.
				const lenis = new Lenis({
					duration: 1.2,
					easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
					orientation: 'vertical',
					smoothWheel: true,
				});

				// Sync Lenis with GSAP ScrollTrigger
				lenis.on('scroll', ScrollTrigger.update);

				gsap.ticker.add((time) => {
					lenis.raf(time * 1000);
				});

				// Make lenis globally available for other scripts
				window.lenis = lenis;
			} else {
				window.lenis = null;
			}

			gsap.ticker.lagSmoothing(0);

			// Make animation libraries globally available for page scripts
			window.gsap = gsap;
			window.ScrollTrigger = ScrollTrigger;

      // Handle View Transitions
      document.addEventListener('astro:page-load', () => {
        // Refresh ScrollTrigger on page load to ensure positions are correct
        ScrollTrigger.refresh();
      });
		</script>
		<HeaderNav currentPath={currentPath} hasAnnouncement={false} />

		<main class:list={[{ "pt-32 pb-24": !removeMainPadding }]}>
			<slot />
		</main>

		{!hideFooter && <SiteFooter />}
	</body>
</html>
