---
import '../styles/global.css';
import { SITE_TITLE } from '../consts';
import Announcement from '../components/Announcement.astro';
import HeaderNav from '../components/HeaderNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title?: string;
  description?: string;
  frontmatter?: {
    title?: string;
    description?: string;
  };
  announcement?: string;
  hideAnnouncement?: boolean;
}

const { frontmatter, hideAnnouncement = false, announcement, ...props } = Astro.props;
const title = props.title || frontmatter?.title || '';
const description = props.description || frontmatter?.description || 'Professional tattoo studio in Fountain, CO';
const currentPath = Astro.url.pathname;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title ? `${title} | ${SITE_TITLE}` : SITE_TITLE}</title>
		<meta name="description" content={description} />
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<!-- Icons -->
		<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
	</head>
	<body class="bg-bg-deep text-text-main selection:bg-white/20 selection:text-white">
		<!-- Subtle background texture -->
		<div class="fixed inset-0 noise pointer-events-none z-50"></div>

		{!hideAnnouncement && <Announcement message={announcement} />}
		<HeaderNav currentPath={currentPath} />

		<main class="pt-32 pb-24">
			<slot />
		</main>

		<SiteFooter />
	</body>
</html>
