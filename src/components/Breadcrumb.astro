---
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: BreadcrumbItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
---

<nav class:list={[
  "flex items-center gap-2 font-mono text-[10px] uppercase tracking-widest text-neutral-500",
  className
]}>
  {items.map((item, index) => (
    <>
      {item.href ? (
        <a href={item.href} class="hover:text-white transition-colors">
          {item.label}
        </a>
      ) : (
        <span class="text-neutral-400">{item.label}</span>
      )}
      {index < items.length - 1 && (
        <span class="text-neutral-700">·</span>
      )}
    </>
  ))}
</nav>

