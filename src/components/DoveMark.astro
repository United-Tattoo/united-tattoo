  viewBox="0 0 64 64"
  fill="none"
  aria-hidden="true"
>
  <!-- Minimal dove mark (abstract line art) -->
  <path
    d="M48.5 23.5c-4.2 2.6-8.9 5-14.2 7.2-2.4 1-5 2.2-7.7 3.6-2 1-3.8 2.3-5.5 3.8"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    opacity="0.9"
  />
  <path
    d="M48.5 23.5c-2.6 3.9-6.2 7.5-10.8 10.8-4.6 3.3-9.6 5.6-15.1 6.9"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    stroke-linejoin="round"
    opacity="0.55"
  />
  <path
    d="M33 26.3c1.1-3.8 3.3-6.7 6.6-8.8 2.3-1.5 4.8-2.3 7.4-2.5-1.2 2.7-2.1 5.4-2.6 8.1"
