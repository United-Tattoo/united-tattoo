---
import {
  ADDRESS_LINE_1,
  ADDRESS_LOCALITY,
  ADDRESS_REGION,
  COUNTRY_CODE,
  EMAIL,
  GEO_LATITUDE,
  GEO_LONGITUDE,
  GOOGLE_MAPS_URL,
  INKROSTER,
  INSTAGRAM,
  LOGO_IMAGE,
  PHONE_NUMBER,
  POSTAL_CODE,
  SITE_DESCRIPTION,
  SITE_TITLE,
  URL as SITE_URL,
  YELP,
  YOUTUBE,
} from '../consts';

interface Props {
  type?: 'website' | 'article' | 'profile';
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
  breadcrumbs?: {
    name: string;
    url: string;
  }[];
  articleData?: {
    headline: string;
    datePublished: Date | string;
    dateModified?: Date | string;
    author: string;
    keywords?: string[];
  };
  artistData?: {
    name: string;
    description: string;
    image: string;
    sameAs?: string[];
  };
}

const {
  type = 'website',
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image = '/images/united-studio-main.avif',
  canonicalUrl = Astro.url.href,
  breadcrumbs,
  articleData,
  artistData
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, '') : SITE_URL;
const absoluteImage = new URL(image, siteUrl).toString();

const toIsoDate = (value: Date | string) => {
  const date = value instanceof Date ? value : new Date(value);
  return date.toISOString();
};

// Base LocalBusiness Schema (United Tattoo)
const localBusinessSchema = {
  "@id": `${siteUrl}/#localbusiness`,
  "@type": "TattooShop",
  "name": SITE_TITLE,
  "description": SITE_DESCRIPTION,
  "image": new URL('/images/united-studio-main.avif', siteUrl).toString(),
  "url": siteUrl,
  "telephone": PHONE_NUMBER,
  "email": EMAIL,
  "sameAs": [INSTAGRAM, YOUTUBE, YELP, INKROSTER],
  "hasMap": GOOGLE_MAPS_URL,
  "priceRange": "$$",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": ADDRESS_LINE_1,
    "addressLocality": ADDRESS_LOCALITY,
    "addressRegion": ADDRESS_REGION,
    "postalCode": POSTAL_CODE,
    "addressCountry": COUNTRY_CODE
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": GEO_LATITUDE,
    "longitude": GEO_LONGITUDE
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Thursday", "Friday", "Saturday"],
      "opens": "10:00",
      "closes": "20:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Sunday", "Monday", "Tuesday", "Wednesday"],
      "opens": "10:00",
      "closes": "18:00"
    }
  ]
};

const schemaGraph: Record<string, unknown>[] = [localBusinessSchema];

if (type === 'profile' && artistData) {
  schemaGraph.push({
    "@id": `${canonicalUrl}#person`,
    "@type": "Person",
    "name": artistData.name,
    "description": artistData.description,
    "image": new URL(artistData.image, siteUrl).toString(),
    "url": canonicalUrl,
    "jobTitle": "Tattoo Artist",
    "worksFor": {
      "@type": "TattooShop",
      "@id": `${siteUrl}/#localbusiness`
    },
    "sameAs": artistData.sameAs || []
  });
}

if (type === 'article' && articleData) {
  schemaGraph.push({
    "@id": `${canonicalUrl}#article`,
    "@type": "BlogPosting",
    "headline": articleData.headline,
    "description": description,
    "image": absoluteImage,
    "url": canonicalUrl,
    "mainEntityOfPage": canonicalUrl,
    "datePublished": toIsoDate(articleData.datePublished),
    "dateModified": toIsoDate(articleData.dateModified || articleData.datePublished),
    "keywords": articleData.keywords || [],
    "author": {
      "@type": "Organization",
      "name": articleData.author,
      "@id": `${siteUrl}/#localbusiness`
    },
    "publisher": {
      "@type": "Organization",
      "name": SITE_TITLE,
      "@id": `${siteUrl}/#localbusiness`,
      "logo": {
        "@type": "ImageObject",
        "url": new URL(LOGO_IMAGE, siteUrl).toString()
      }
    }
  });
}

if (breadcrumbs && breadcrumbs.length > 0) {
  schemaGraph.push({
    "@id": `${canonicalUrl}#breadcrumb`,
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((item, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "name": item.name,
      "item": new URL(item.url, siteUrl).toString()
    }))
  });
}

const schemaData = {
  "@context": "https://schema.org",
  "@graph": schemaGraph
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
