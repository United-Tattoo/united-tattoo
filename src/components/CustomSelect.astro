---
interface Option {
  value: string;
  label: string;
  selected?: boolean;
}

interface Props {
  id: string;
  name: string;
  label: string;
  options: Option[];
  required?: boolean;
  placeholder?: string;
  hint?: string;
}

const { id, name, label, options, required = false, placeholder = 'Select an option...', hint } = Astro.props;

const selectedOption = options.find(opt => opt.selected);
const displayValue = selectedOption?.label || placeholder;
const selectedValue = selectedOption?.value || '';
---

<div class="custom-select-wrapper" data-select-id={id}>
  <label for={id} class="block font-mono text-[10px] uppercase tracking-widest text-muted-foreground mb-2">
    {label}
  </label>

  <div class="custom-select relative">
    <!-- Hidden input for form submission -->
    <input
      type="hidden"
      id={id}
      name={name}
      value={selectedValue}
      data-required={required ? 'true' : 'false'}
    />

    <!-- Trigger Button -->
    <button
      type="button"
      class="custom-select-trigger w-full bg-transparent border-b border-input py-4 text-left font-mono text-sm transition-all duration-300 hover:border-ring focus:outline-none flex items-center justify-between gap-4 group"
      aria-haspopup="listbox"
      aria-expanded="false"
      data-value={selectedValue}
      data-lenis-prevent
    >
      <span class="custom-select-value truncate text-secondary-foreground group-hover:text-foreground transition-colors" data-placeholder={!selectedValue}>
        {displayValue}
      </span>
      <span class="custom-select-arrow transition-transform duration-300">
        <iconify-icon icon="solar:alt-arrow-down-linear" class="text-muted-foreground group-hover:text-secondary-foreground"></iconify-icon>
      </span>
    </button>

    <!-- Dropdown Menu -->
    <div
      class="custom-select-dropdown absolute top-full left-0 right-0 mt-2 bg-card border border-border opacity-0 invisible translate-y-2 transition-all duration-300 z-[70] max-h-[300px] overflow-y-auto overscroll-contain shadow-2xl shadow-black/50"
      data-lenis-prevent
    >
      <ul role="listbox" class="py-2">
        {placeholder && (
          <li
            role="option"
            data-value=""
            class="custom-select-option px-4 py-4 font-mono text-sm text-muted-foreground cursor-pointer hover:bg-secondary transition-colors"
            aria-selected={!selectedValue}
          >
            {placeholder}
          </li>
        )}
        {options.map((option) => (
          <li
            role="option"
            data-value={option.value}
            class={`custom-select-option px-4 py-4 font-mono text-sm cursor-pointer hover:bg-secondary transition-colors flex items-center justify-between ${option.value === selectedValue ? 'text-foreground bg-secondary' : 'text-secondary-foreground'}`}
            aria-selected={option.value === selectedValue}
          >
            <span>{option.label}</span>
            {option.value === selectedValue && (
              <iconify-icon icon="solar:check-bold" class="text-foreground text-xs"></iconify-icon>
            )}
          </li>
        ))}
      </ul>
    </div>
  </div>

  {hint && (
    <p class="font-mono text-[10px] text-muted-foreground/60 mt-2">{hint}</p>
  )}
</div>

<style>
  .custom-select-trigger[data-placeholder="true"] .custom-select-value,
  .custom-select-value[data-placeholder="true"] {
    color: var(--muted-foreground);
  }

  .custom-select.open .custom-select-trigger {
    border-color: var(--ring);
  }

  .custom-select.open .custom-select-arrow {
    transform: rotate(180deg);
  }

  .custom-select.open .custom-select-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .custom-select-dropdown::-webkit-scrollbar {
    width: 4px;
  }

  .custom-select-dropdown::-webkit-scrollbar-track {
    background: transparent;
  }

  .custom-select-dropdown::-webkit-scrollbar-thumb {
    background: oklch(from var(--foreground) l c h / 0.1);
    border-radius: 2px;
  }

  .custom-select-dropdown::-webkit-scrollbar-thumb:hover {
    background: oklch(from var(--foreground) l c h / 0.2);
  }

  .custom-select-trigger,
  .custom-select-option {
    touch-action: manipulation;
  }

  @media (max-width: 767px) {
    .custom-select-trigger {
      min-height: 3.5rem;
      border: 1px solid var(--input);
      background: color-mix(in srgb, var(--brand-paper) 3.5%, transparent);
      padding: 0.95rem 1rem;
    }

    .custom-select-dropdown {
      z-index: 220;
      max-height: min(52svh, 24rem);
      margin-top: 0.5rem;
      border-color: color-mix(in srgb, var(--brand-paper) 16%, var(--border));
      background: color-mix(in srgb, var(--background) 94%, var(--brand-paper));
      transform: translateY(0.35rem);
    }

    .custom-select.open .custom-select-dropdown {
      transform: translateY(0);
    }

    .custom-select-option {
      min-height: 3.25rem;
      padding: 1rem;
    }
  }
</style>

<script>
  function initCustomSelects() {
    const selects = document.querySelectorAll('.custom-select');

    selects.forEach((select) => {
      // Guard against duplicate init (Astro view transitions re-run scripts)
      if ((select as HTMLElement).dataset.initialized) return;
      (select as HTMLElement).dataset.initialized = 'true';

      const trigger = select.querySelector('.custom-select-trigger') as HTMLButtonElement;
      const dropdown = select.querySelector('.custom-select-dropdown') as HTMLDivElement;
      const options = select.querySelectorAll('.custom-select-option');
      const hiddenInput = select.querySelector('input[type="hidden"]') as HTMLInputElement;
      const valueDisplay = select.querySelector('.custom-select-value') as HTMLSpanElement;

      if (!trigger || !dropdown || !hiddenInput || !valueDisplay) return;

      // Toggle dropdown
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();

        // Close other open selects
        document.querySelectorAll('.custom-select.open').forEach((s) => {
          if (s !== select) {
            s.classList.remove('open');
            s.querySelector('.custom-select-trigger')?.setAttribute('aria-expanded', 'false');
          }
        });

        const isOpen = select.classList.toggle('open');
        trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });

      // Shared option selection logic
      function selectOption(option: Element) {
        const value = (option as HTMLElement).dataset.value || '';
        const label = option.textContent?.trim() || '';

        hiddenInput.value = value;
        valueDisplay.textContent = label;
        valueDisplay.dataset.placeholder = value ? 'false' : 'true';
        trigger.dataset.value = value;

        options.forEach((opt) => {
          const isSelected = (opt as HTMLElement).dataset.value === value;
          opt.setAttribute('aria-selected', isSelected ? 'true' : 'false');
          opt.classList.toggle('text-foreground', isSelected);
          opt.classList.toggle('bg-secondary', isSelected);
          opt.classList.toggle('text-secondary-foreground', !isSelected);

          const checkIcon = opt.querySelector('iconify-icon[icon="solar:check-bold"]');
          if (isSelected && !checkIcon) {
            const icon = document.createElement('iconify-icon');
            icon.setAttribute('icon', 'solar:check-bold');
            icon.className = 'text-foreground text-xs';
            opt.appendChild(icon);
          } else if (!isSelected && checkIcon) {
            checkIcon.remove();
          }
        });

        select.classList.remove('open');
        trigger.setAttribute('aria-expanded', 'false');
        hiddenInput.dispatchEvent(new Event('change', { bubbles: true }));
      }

      // Handle option selection — click for desktop, touchend for mobile
      options.forEach((option) => {
        option.addEventListener('click', () => selectOption(option));

        // touchend fires reliably on iOS where <li> click can be swallowed
        option.addEventListener('touchend', (e) => {
          e.preventDefault(); // blocks ghost click so selectOption runs once
          selectOption(option);
        });
      });

      // Keyboard navigation
      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          trigger.click();
        } else if (e.key === 'Escape') {
          select.classList.remove('open');
          trigger.setAttribute('aria-expanded', 'false');
        } else if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
          e.preventDefault();
          if (!select.classList.contains('open')) {
            trigger.click();
          }
        }
      });
    });

    // Close on outside tap — pointerdown is reliable across mouse + touch
    // Guard so view transitions don't stack duplicate document listeners
    if (!(window as any).__csOutsideInit) {
      (window as any).__csOutsideInit = true;
      document.addEventListener('pointerdown', (e) => {
        const target = e.target as HTMLElement;
        if (!target.closest('.custom-select')) {
          document.querySelectorAll('.custom-select.open').forEach((s) => {
            s.classList.remove('open');
            s.querySelector('.custom-select-trigger')?.setAttribute('aria-expanded', 'false');
          });
        }
      });
    }
  }

  // Run on initial load and after view transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCustomSelects);
  } else {
    initCustomSelects();
  }
  document.addEventListener('astro:page-load', initCustomSelects);
</script>
