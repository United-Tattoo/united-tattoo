---
// Clean editorial footer - no "system verified" or underscore language
import {
  ADDRESS_LINE_1,
  ADDRESS_LINE_2,
  EMAIL,
  INKROSTER,
  INSTAGRAM,
  PHONE_NUMBER,
  YELP,
  YOUTUBE,
} from '../consts';
---

<footer class="py-16 px-6 md:px-20 border-t border-border">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <!-- Brand -->
      <div class="md:col-span-2 space-y-4">
        <a href="/" class="font-display text-3xl italic tracking-tight">United Tattoo</a>
        <p class="text-sm text-muted-foreground max-w-sm leading-relaxed">
          Tattoo collective in Fountain, Colorado. Custom artwork, experienced artists, exceptional results.
        </p>
      </div>

      <!-- Location -->
      <div class="space-y-4">
        <h4 class="text-xs uppercase tracking-widest text-muted-foreground">Visit</h4>
        <address class="text-sm text-muted-foreground not-italic leading-relaxed">
          {ADDRESS_LINE_1} <br/>
          {ADDRESS_LINE_2}
        </address>
        <div class="space-y-1">
          <a href={`tel:${PHONE_NUMBER.replace(/\s+/g, '')}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            {PHONE_NUMBER}
          </a>
          <br />
          <a href={`mailto:${EMAIL}`} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            {EMAIL}
          </a>
        </div>
        <p class="text-sm text-muted-foreground">
          Thursday-Saturday: 10am–8pm <br/>
          Sunday-Wednesday: 10am-6pm
        </p>
      </div>

      <!-- Links -->
      <div class="space-y-4">
        <h4 class="text-xs uppercase tracking-widest text-muted-foreground">Explore</h4>
        <div class="flex flex-col gap-2">
          <a href="/artists" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Artists</a>
          <a href="/blog" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Journal</a>
          <a href="/booking" class="text-sm text-muted-foreground hover:text-foreground transition-colors" data-analytics-event="booking_cta_click" data-analytics-location="site_footer" data-analytics-label="Booking" data-analytics-href="/booking">Booking</a>
          <a href="/aftercare" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Aftercare</a>
          <a href={INSTAGRAM} target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Instagram</a>
          <a href={YOUTUBE} target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-foreground transition-colors">YouTube</a>
          <a href={YELP} target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-foreground transition-colors">Yelp</a>
          <a href={INKROSTER} target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-foreground transition-colors">InkRoster</a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6 pt-8 border-t border-border">
      <p class="text-xs text-muted-foreground/60">
        © {new Date().getFullYear()} United Tattoo. All rights reserved.
      </p>
      <div class="flex items-center gap-8">
        <a href="/privacy" class="text-xs text-muted-foreground/60 hover:text-muted-foreground transition-colors">Privacy</a>
        <a href="/terms" class="text-xs text-muted-foreground/60 hover:text-muted-foreground transition-colors">Terms</a>
        <a href="/blog" class="text-xs text-muted-foreground/60 hover:text-muted-foreground transition-colors">Journal</a>
        <a href="/aftercare" class="text-xs text-muted-foreground/60 hover:text-muted-foreground transition-colors">Aftercare</a>
      </div>
    </div>
  </div>
</footer>
