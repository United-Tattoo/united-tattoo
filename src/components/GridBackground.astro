---
interface Props {
  opacity?: number;
  columns?: number;
  class?: string;
}

const {
  opacity = 40,
  columns = 12,
  class: className = ''
} = Astro.props;

const opacityClass = `opacity-${opacity}`;
---

<div class:list={[
  "absolute inset-0 grid pointer-events-none select-none z-0",
  columns === 12 ? "grid-cols-6 md:grid-cols-12" : `grid-cols-${columns}`,
  className
]} style={`opacity: ${opacity / 100}`}>
  {Array.from({ length: columns }).map((_, i) => (
    <div class:list={[
      "h-full border-r border-white/5",
      i === 0 && "border-l",
      columns === 12 && i >= 6 && "hidden md:block"
    ]}></div>
  ))}
</div>

