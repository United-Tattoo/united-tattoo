---
interface Props {
  title: string;
  meta?: string;
  titleClass?: string;
  class?: string;
  variant?: 'uppercase' | 'italic';
}

const {
  title,
  meta,
  titleClass = '',
  class: className = '',
  variant = 'uppercase'
} = Astro.props;

const titleVariantClass = variant === 'uppercase'
  ? 'uppercase tracking-tight'
  : 'italic tracking-tighter';
---

<div class:list={[
  "px-6 md:px-8 py-10 md:py-14 border-b border-border",
  className
]}>
  <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4">
    <h2 class:list={[
      "text-4xl md:text-5xl lg:text-6xl text-foreground font-extralight",
      titleVariantClass,
      titleClass
    ]}>
      {title}
    </h2>
    {meta && (
      <span class="font-mono text-[10px] text-primary/60 uppercase tracking-[0.2em]">
        {meta}
      </span>
    )}
  </div>
</div>

