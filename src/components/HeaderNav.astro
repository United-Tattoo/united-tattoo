---
import { ADDRESS_LINE_1, ADDRESS_LINE_2, PHONE_NUMBER } from '../consts';
import DoveMark from './DoveMark.astro';

interface Props {
  currentPath?: string;
  hasAnnouncement?: boolean;
}

const { currentPath = "", hasAnnouncement = false } = Astro.props;
const isHomePage = currentPath === "/";
const isArtistsPage = currentPath.startsWith("/artists");
const isBookingPage = currentPath.startsWith("/booking");

const desktopNavItems = [
  { href: '/', label: 'Home', num: '01', active: isHomePage },
  { href: '/artists', label: 'Artists', num: '02', active: isArtistsPage },
  { href: '/#process', label: 'Process', num: '03', active: false },
];

const mobileNavItems = [
  { href: '/', label: 'Home', num: '01' },
  { href: '/artists', label: 'Artists', num: '02' },
  { href: '/#process', label: 'Process', num: '03' },
  { href: '/booking', label: 'Book a Session', num: '04' },
];
---

<nav id="main-nav" class:list={[
  "fixed left-0 right-0 z-[60]",
  hasAnnouncement ? "top-8" : "top-0"
]}>
  <div class="nav-shell max-w-[1800px] mx-auto px-4 md:px-8 lg:px-12">
    <div class="nav-row flex justify-between items-center gap-4 py-4 md:py-5">
      <!-- Logo / Wordmark -->
      <a href="/" class="nav-logo group relative z-[110]" aria-label="United Tattoo home">
        <span class="nav-mark">
          <DoveMark class="nav-dove w-5 h-5 transition-all duration-300 group-hover:rotate-[-8deg]" />
        </span>
        <span class="nav-brand-text">
          <span class="nav-wordmark">United</span>
          <span class="nav-submark">Tattoo</span>
        </span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-4">
        <div class="nav-links flex items-center">
          {desktopNavItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                'nav-link font-mono text-[11px] uppercase tracking-[0.18em] transition-all duration-300',
                { 'is-active': item.active }
              ]}
            >
              <span class="nav-link-num">{item.num}</span>
              <span>{item.label}</span>
            </a>
          ))}
        </div>

        <a
          href="/booking"
          class:list={[
            'nav-book-btn font-mono text-[11px] uppercase tracking-[0.18em] px-5 py-3 border transition-all duration-300',
            { 'is-active': isBookingPage }
          ]}
        >
          <span>Book</span>
          <span class="hidden lg:inline">a Session</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="mobile-menu-btn md:hidden relative z-[110] w-11 h-11 flex flex-col items-center justify-center gap-[5px]" aria-label="Toggle Menu">
        <span class="hamburger-line w-5 h-px bg-foreground transition-all duration-300 origin-center"></span>
        <span class="hamburger-line w-5 h-px bg-foreground transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-[100] bg-background/96 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-400">
  <div class="relative max-w-[1800px] mx-auto w-full h-full border-l border-r border-border/70 flex flex-col">
    <!-- Menu content -->
    <div class="flex-1 flex flex-col justify-center px-8 pt-20">
      <nav class="flex flex-col gap-1">
        {mobileNavItems.map((item, i) => (
          <a
            href={item.href}
            class="mobile-link group flex items-baseline gap-4 py-4 border-b border-border/40 transform translate-y-6 opacity-0 transition-all duration-500"
            style={`transition-delay: ${100 + i * 80}ms`}
          >
            <span class="font-mono text-[10px] text-muted-foreground/50 tracking-wider">{item.num}</span>
            <span class="text-3xl font-sans font-light text-foreground/85 group-hover:text-primary group-hover:translate-x-1 transition-all uppercase tracking-tight">{item.label}</span>
          </a>
        ))}
      </nav>
    </div>

    <!-- Mobile menu footer -->
    <div class="px-8 pb-10 transform translate-y-4 opacity-0 transition-all duration-500 delay-500 mobile-footer">
      <div class="border-t border-border/50 pt-6 flex justify-between items-end">
        <div>
          <p class="font-mono text-[9px] uppercase tracking-[0.25em] text-muted-foreground/50 mb-2">Visit Us</p>
          <p class="text-muted-foreground/70 text-sm font-light leading-relaxed">
            {ADDRESS_LINE_1}<br/>
            {ADDRESS_LINE_2}
          </p>
        </div>
        <a href={`tel:${PHONE_NUMBER}`} class="font-mono text-[10px] text-primary tracking-wider">{PHONE_NUMBER}</a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--foreground);
    min-width: 9rem;
  }

  .nav-mark {
    width: 2.25rem;
    height: 2.25rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid color-mix(in srgb, var(--foreground) 18%, transparent);
    background: color-mix(in srgb, var(--background) 56%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    transition: border-color 0.3s ease, background 0.3s ease;
  }

  .nav-logo:hover .nav-mark {
    border-color: color-mix(in srgb, var(--foreground) 45%, transparent);
    background: color-mix(in srgb, var(--foreground) 8%, transparent);
  }

  .nav-brand-text {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
  }

  .nav-wordmark {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    line-height: 1;
  }

  .nav-submark {
    font-family: var(--font-mono);
    font-size: 8px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--foreground) 48%, transparent);
  }

  /* Nav never has its own background — pointer-events only on interactive elements */
  .nav-shell {
    transition: background 0.3s ease, border-color 0.3s ease, padding 0.3s ease;
  }

  #main-nav {
    pointer-events: none;
    transition: transform 0.3s ease;
  }

  #main-nav a,
  #main-nav button {
    pointer-events: auto;
  }

  #main-nav.nav-scrolled .nav-shell {
    background: color-mix(in srgb, var(--background) 88%, transparent);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid color-mix(in srgb, var(--foreground) 12%, transparent);
  }

  #main-nav.nav-scrolled {
    pointer-events: auto;
  }

  .nav-links {
    border: 1px solid color-mix(in srgb, var(--foreground) 16%, transparent);
    background: color-mix(in srgb, var(--background) 42%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  /* Links */
  .nav-link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.45rem;
    color: color-mix(in srgb, var(--foreground) 66%, transparent);
    padding: 0.75rem 1rem;
    border-right: 1px solid color-mix(in srgb, var(--foreground) 12%, transparent);
  }

  .nav-link:last-child {
    border-right: 0;
  }

  .nav-link-num {
    color: color-mix(in srgb, var(--foreground) 34%, transparent);
    font-size: 9px;
  }

  .nav-link.is-active {
    color: var(--foreground);
    background: color-mix(in srgb, var(--foreground) 7%, transparent);
  }

  .nav-link:hover {
    color: var(--foreground);
    background: color-mix(in srgb, var(--foreground) 9%, transparent);
  }

  /* Book button */
  .nav-book-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border-color: color-mix(in srgb, var(--foreground) 32%, transparent);
    color: color-mix(in srgb, var(--foreground) 82%, transparent);
    background: color-mix(in srgb, var(--background) 42%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .nav-scrolled .nav-book-btn {
    border-color: color-mix(in srgb, var(--foreground) 28%, transparent);
    color: color-mix(in srgb, var(--foreground) 84%, transparent);
  }

  .nav-book-btn.is-active {
    background: var(--foreground);
    border-color: var(--foreground);
    color: var(--background);
  }

  .nav-book-btn:hover {
    background: var(--foreground);
    border-color: var(--foreground);
    color: var(--background);
  }

  .mobile-menu-btn {
    border: 1px solid color-mix(in srgb, var(--foreground) 16%, transparent);
    background: color-mix(in srgb, var(--background) 44%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  /* Hamburger animation */
  .menu-open .hamburger-line:first-child {
    transform: rotate(45deg) translateY(3px);
  }

  .menu-open .hamburger-line:last-child {
    transform: rotate(-45deg) translateY(-3px);
  }

  @media (max-width: 767px) {
    .nav-shell {
      padding-inline: 1rem;
    }

    .nav-logo {
      min-width: 0;
    }
  }
</style>

<script>
  function initHeader() {
    const nav = document.getElementById('main-nav');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const mobileFooter = document.querySelector('.mobile-footer');
    let isMenuOpen = false;

    if (!nav) return;

    // Scroll-based nav background
    let lastScroll = 0;
    const handleScroll = () => {
      const scrollY = window.scrollY;

      if (scrollY > 80) {
        nav.classList.remove('nav-transparent');
        nav.classList.add('nav-scrolled');
      } else if (!isMenuOpen) {
        nav.classList.add('nav-transparent');
        nav.classList.remove('nav-scrolled');
      }

      lastScroll = scrollY;
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Check initial state

    // Mobile menu
    if (!menuBtn || !mobileMenu) return;

    function toggleMenu() {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'pointer-events-auto');

        // Animate links in
        mobileLinks.forEach(link => {
          link.classList.remove('translate-y-6', 'opacity-0');
        });
        mobileFooter?.classList.remove('translate-y-4', 'opacity-0');

        // Hamburger → X
        menuBtn.classList.add('menu-open');

        // Nav stays on top, transparent over menu
        nav.classList.remove('nav-transparent', 'nav-scrolled');
        nav.classList.add('z-[110]');

        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');

        // Reset link animations
        mobileLinks.forEach(link => {
          link.classList.add('translate-y-6', 'opacity-0');
        });
        mobileFooter?.classList.add('translate-y-4', 'opacity-0');

        // X → Hamburger
        menuBtn.classList.remove('menu-open');

        // Restore nav
        setTimeout(() => {
          nav.classList.remove('z-[110]');
          handleScroll();
        }, 300);

        document.body.style.overflow = '';
      }
    }

    menuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initHeader);
  document.addEventListener('astro:page-load', initHeader);
</script>
