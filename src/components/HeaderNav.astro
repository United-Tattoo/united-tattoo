---
// Minimal navigation - clean and refined
interface Props {
  currentPath?: string;
  hasAnnouncement?: boolean;
}

const { currentPath = "", hasAnnouncement = false } = Astro.props;
const isArtistsPage = currentPath.startsWith("/artists");
const isBookingPage = currentPath.startsWith("/booking");
const isProcessPage = currentPath.includes("#process") || currentPath === "/#process";
const isHomePage = currentPath === "/" || currentPath === "";
---

<nav id="main-nav" class:list={[
  "fixed left-0 w-full px-5 md:px-8 py-4 flex justify-between items-center transition-all duration-300",
  "bg-neutral-950/80 backdrop-blur-sm border-b border-white/[0.04] z-[60]",
  hasAnnouncement ? "top-8" : "top-0"
]}>
  <!-- Logo -->
  <a href="/" class="nav-logo relative z-[110] font-display text-xl md:text-2xl tracking-tight text-white hover:text-sage transition-colors duration-300">
    United Tattoo
  </a>

  <!-- Desktop Links -->
  <div class="hidden md:flex items-center gap-8">
    <a
      href="/artists"
      class:list={[
        "nav-link text-[13px] tracking-wide transition-colors duration-300",
        isArtistsPage ? "text-white" : "text-neutral-400 hover:text-white"
      ]}
    >
      Artists
    </a>
    <a
      href="/#process"
      class:list={[
        "nav-link text-[13px] tracking-wide transition-colors duration-300",
        isProcessPage ? "text-white" : "text-neutral-400 hover:text-white"
      ]}
    >
      Process
    </a>
    <a
      href="/booking"
      class:list={[
        "nav-link text-[13px] tracking-wide transition-colors duration-300",
        isBookingPage ? "text-white" : "text-neutral-400 hover:text-white"
      ]}
    >
      Book
    </a>
  </div>

  <!-- Mobile Menu Button (Hamburger) -->
  <button
    id="mobile-menu-btn"
    class="md:hidden relative z-[110] w-8 h-8 flex items-center justify-center group"
    aria-label="Toggle Menu"
    aria-expanded="false"
  >
    <div class="hamburger-icon">
      <span class="hamburger-line hamburger-line-1"></span>
      <span class="hamburger-line hamburger-line-2"></span>
    </div>
  </button>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-[100] bg-neutral-950/95 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-300">
  <nav class="h-full flex flex-col justify-center items-center gap-8">
    <a
      href="/"
      class:list={[
        "mobile-link text-2xl font-display tracking-tight transition-all duration-300 translate-y-3 opacity-0",
        isHomePage ? "text-white" : "text-neutral-400 hover:text-white"
      ]}
      style="transition-delay: 50ms;"
    >
      Home
    </a>
    <a
      href="/artists"
      class:list={[
        "mobile-link text-2xl font-display tracking-tight transition-all duration-300 translate-y-3 opacity-0",
        isArtistsPage ? "text-white" : "text-neutral-400 hover:text-white"
      ]}
      style="transition-delay: 100ms;"
    >
      Artists
    </a>
    <a
      href="/#process"
      class:list={[
        "mobile-link text-2xl font-display tracking-tight transition-all duration-300 translate-y-3 opacity-0",
        isProcessPage ? "text-white" : "text-neutral-400 hover:text-white"
      ]}
      style="transition-delay: 150ms;"
    >
      Process
    </a>
    <a
      href="/booking"
      class:list={[
        "mobile-link text-2xl font-display tracking-tight transition-all duration-300 translate-y-3 opacity-0",
        isBookingPage ? "text-white" : "text-neutral-400 hover:text-white"
      ]}
      style="transition-delay: 200ms;"
    >
      Book
    </a>
  </nav>
</div>

<style>
  /* Hamburger Icon */
  .hamburger-icon {
    position: relative;
    width: 20px;
    height: 12px;
  }

  .hamburger-line {
    position: absolute;
    left: 0;
    width: 100%;
    height: 1.5px;
    background-color: currentColor;
    color: #a3a3a3;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform-origin: center;
  }

  .hamburger-line-1 {
    top: 0;
  }

  .hamburger-line-2 {
    bottom: 0;
  }

  /* Hover state */
  .group:hover .hamburger-line {
    color: #fff;
  }

  /* Open state - X shape */
  .menu-open .hamburger-line-1 {
    top: 50%;
    transform: translateY(-50%) rotate(45deg);
    color: #fff;
  }

  .menu-open .hamburger-line-2 {
    bottom: 50%;
    transform: translateY(50%) rotate(-45deg);
    color: #fff;
  }

  /* Nav link underline effect */
  .nav-link {
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 0;
    height: 1px;
    background-color: currentColor;
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .nav-link:hover::after {
    width: 100%;
  }
</style>

<script>
  function initMobileMenu() {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const nav = document.getElementById('main-nav');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    let isMenuOpen = false;

    if (!menuBtn || !mobileMenu || !nav) return;

    function openMenu() {
      isMenuOpen = true;

      // Update button state
      menuBtn.classList.add('menu-open');
      menuBtn.setAttribute('aria-expanded', 'true');

      // Show overlay
      mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('opacity-100', 'pointer-events-auto');

      // Animate links in
      mobileLinks.forEach(link => {
        link.classList.remove('translate-y-3', 'opacity-0');
        link.classList.add('translate-y-0', 'opacity-100');
      });

      // Update nav - raise z-index and make transparent
      nav.classList.remove('bg-neutral-950/80', 'border-white/[0.04]', 'z-[60]');
      nav.classList.add('bg-transparent', 'border-transparent', 'z-[110]');

      // Lock scroll
      document.body.style.overflow = 'hidden';
    }

    function closeMenu() {
      isMenuOpen = false;

      // Update button state
      menuBtn.classList.remove('menu-open');
      menuBtn.setAttribute('aria-expanded', 'false');

      // Hide overlay
      mobileMenu.classList.add('opacity-0', 'pointer-events-none');
      mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');

      // Reset link positions
      mobileLinks.forEach(link => {
        link.classList.add('translate-y-3', 'opacity-0');
        link.classList.remove('translate-y-0', 'opacity-100');
      });

      // Restore nav background and z-index (delayed)
      setTimeout(() => {
        if (!isMenuOpen) {
          nav.classList.add('bg-neutral-950/80', 'border-white/[0.04]', 'z-[60]');
          nav.classList.remove('bg-transparent', 'border-transparent', 'z-[110]');
        }
      }, 150);

      // Unlock scroll
      document.body.style.overflow = '';
    }

    function toggleMenu() {
      if (isMenuOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    }

    // Button click
    menuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    // Close on link click
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) closeMenu();
      });
    });

    // Close on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isMenuOpen) {
        closeMenu();
      }
    });

    // Close on click outside (on overlay background)
    mobileMenu.addEventListener('click', (e) => {
      if (e.target === mobileMenu) {
        closeMenu();
      }
    });
  }

  // Initialize on page load and Astro page transitions
  document.addEventListener('DOMContentLoaded', initMobileMenu);
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
