---
// Editorial-style navigation with clean typography
import { ADDRESS_LINE_1, ADDRESS_LINE_2 } from '../consts';
import DoveMark from './DoveMark.astro';

interface Props {
  currentPath?: string;
  hasAnnouncement?: boolean;
}

const { currentPath = "", hasAnnouncement = false } = Astro.props;
const isArtistsPage = currentPath.startsWith("/artists");
const isBookingPage = currentPath.startsWith("/booking");
---

<nav id="main-nav" class:list={[
  "fixed left-0 w-full px-6 py-4 flex justify-between items-center z-[60] bg-background/60 backdrop-blur-md border-b border-border transition-all duration-300",
  hasAnnouncement ? "top-8" : "top-0"
]}>
  <div class="flex items-center gap-4 relative z-[110]">
    <a href="/" class="font-sans text-2xl md:text-3xl font-semibold tracking-tighter leading-none hover:opacity-70 transition-opacity">
      United Tattoo
    </a>
    <span class="hidden lg:inline-flex items-center text-muted-foreground/70">
      <DoveMark class="w-6 h-6" />
    </span>
    <span class="hidden lg:block text-muted-foreground/60 mx-2">·</span>
    <span class="hidden lg:block text-xs text-muted-foreground tracking-wide">
      Fountain, Colorado
    </span>
  </div>

  <div class="hidden md:flex gap-8 items-center text-sm text-muted-foreground">
    <a
      href="/artists"
      class:list={[
        "hover:text-foreground transition-colors",
        { "text-foreground": isArtistsPage }
      ]}
    >
      Artists
    </a>
    <a
      href="/#process"
      class="hover:text-foreground transition-colors"
    >
      Process
    </a>
    <a
      href="/booking"
      class:list={[
        "px-5 py-2 bg-foreground text-background text-xs font-medium tracking-wide hover:bg-foreground/80 transition-all",
        { "bg-foreground/80": isBookingPage }
      ]}
    >
      Book a Session
    </a>
  </div>

  <button id="mobile-menu-btn" class="md:hidden text-sm text-muted-foreground hover:text-foreground transition-colors uppercase tracking-widest relative z-[110]" aria-label="Toggle Menu">
    Menu
  </button>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-[100] bg-background/98 backdrop-blur-xl opacity-0 pointer-events-none transition-all duration-500 flex flex-col justify-center items-center">

  <nav class="relative z-10 flex flex-col items-center gap-10 text-center">
    <a href="/" class="mobile-link text-4xl font-sans font-semibold text-foreground/80 hover:text-foreground transition-colors transform translate-y-4 opacity-0 transition-all duration-500 delay-100">Home</a>
    <a href="/artists" class="mobile-link text-4xl font-sans font-semibold text-foreground/80 hover:text-foreground transition-colors transform translate-y-4 opacity-0 transition-all duration-500 delay-200">Artists</a>
    <a href="/#process" class="mobile-link text-4xl font-sans font-semibold text-foreground/80 hover:text-foreground transition-colors transform translate-y-4 opacity-0 transition-all duration-500 delay-300">Process</a>
    <a href="/booking" class="mobile-link text-4xl font-sans font-semibold text-foreground/80 hover:text-foreground transition-colors transform translate-y-4 opacity-0 transition-all duration-500 delay-400">Book a Session</a>
  </nav>

  <div class="absolute bottom-12 text-center transform translate-y-4 opacity-0 transition-all duration-500 delay-500 mobile-footer">
    <p class="text-muted-foreground text-xs uppercase tracking-widest mb-4">Visit Us</p>
    <p class="text-muted-foreground text-sm font-light">
      {ADDRESS_LINE_1}<br/>
      {ADDRESS_LINE_2}
    </p>
  </div>
</div>

<script>
  function initMobileMenu() {
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const nav = document.getElementById('main-nav');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const mobileFooter = document.querySelector('.mobile-footer');
    let isMenuOpen = false;

    if (!menuBtn || !mobileMenu) return;

    function toggleMenu() {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        // Open menu
        mobileMenu?.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu?.classList.add('opacity-100', 'pointer-events-auto');

        // Animate links
        mobileLinks.forEach(link => {
          link.classList.remove('translate-y-4', 'opacity-0');
        });
        mobileFooter?.classList.remove('translate-y-4', 'opacity-0');

        if (menuBtn) {
          menuBtn.textContent = 'Close';
          menuBtn.classList.add('text-foreground');
        }

        // Ensure nav stays on top and blends
        nav?.classList.remove('bg-background/60', 'backdrop-blur-md', 'border-border', 'z-[60]');
        nav?.classList.add('border-transparent', 'z-[110]');

        document.body.style.overflow = 'hidden';
      } else {
        // Close menu
        mobileMenu?.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu?.classList.remove('opacity-100', 'pointer-events-auto');

        // Reset animations
        mobileLinks.forEach(link => {
          link.classList.add('translate-y-4', 'opacity-0');
        });
        mobileFooter?.classList.add('translate-y-4', 'opacity-0');

        if (menuBtn) {
          menuBtn.textContent = 'Menu';
          menuBtn.classList.remove('text-foreground');
        }

        // Restore nav styles
        setTimeout(() => {
          nav?.classList.add('bg-background/60', 'backdrop-blur-md', 'border-border', 'z-[60]');
          nav?.classList.remove('border-transparent', 'z-[110]');
        }, 200);

        document.body.style.overflow = '';
      }
    }

    menuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    // Close menu when clicking a link
    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });
  }

  // Run on load and on Astro page swaps (if View Transitions used later)
  document.addEventListener('DOMContentLoaded', initMobileMenu);
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
