---
import { ADDRESS_LINE_1, ADDRESS_LINE_2, PHONE_NUMBER } from '../consts';
import DoveMark from './DoveMark.astro';

interface Props {
  currentPath?: string;
  hasAnnouncement?: boolean;
}

const { currentPath = "", hasAnnouncement = false } = Astro.props;
const isArtistsPage = currentPath.startsWith("/artists");
const isBookingPage = currentPath.startsWith("/booking");

const desktopNavItems = [
  { href: '/artists', label: 'Artists', num: '01', active: isArtistsPage },
  { href: '/#process', label: 'Process', num: '02', active: false },
];

const mobileNavItems = [
  { href: '/', label: 'Home', num: '01' },
  { href: '/artists', label: 'Artists', num: '02' },
  { href: '/#process', label: 'Process', num: '03' },
  { href: '/booking', label: 'Book a Session', num: '04' },
];
---

<nav id="main-nav" class:list={[
  "fixed left-0 right-0 z-[60]",
  hasAnnouncement ? "top-8" : "top-0"
]}>
  <div class="max-w-[1800px] mx-auto border-l border-r border-border px-6 md:px-10 lg:px-14">
    <div class="nav-row flex justify-between items-center py-5 md:py-6">
      <!-- Logo / Wordmark -->
      <a href="/" class="nav-logo group relative z-[110]">
        <DoveMark class="nav-dove w-6 h-6 text-primary transition-all duration-300 group-hover:rotate-[-8deg]" />
        <span class="nav-wordmark">United</span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-10">
        {desktopNavItems.map((item) => (
          <a
            href={item.href}
            class:list={[
              'nav-link font-mono text-[13px] uppercase tracking-[0.15em] text-foreground/70 transition-all duration-300',
              { '!text-foreground': item.active }
            ]}
          >
            {item.label}
          </a>
        ))}

        <a
          href="/booking"
          class:list={[
            'nav-book-btn font-mono text-[13px] uppercase tracking-[0.15em] px-5 py-2.5 border transition-all duration-300',
            { '!bg-foreground !text-background !border-foreground': isBookingPage }
          ]}
        >
          Book a Session
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden relative z-[110] w-9 h-9 flex flex-col items-center justify-center gap-[5px]" aria-label="Toggle Menu">
        <span class="hamburger-line w-5 h-px bg-foreground transition-all duration-300 origin-center"></span>
        <span class="hamburger-line w-5 h-px bg-foreground transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 z-[100] bg-background/95 backdrop-blur-md opacity-0 pointer-events-none transition-opacity duration-400">
  <div class="absolute inset-0 pointer-events-none mobile-grid-lines"></div>

  <div class="relative max-w-[1800px] mx-auto w-full h-full border-l border-r border-border/70 flex flex-col">
    <!-- Menu content -->
    <div class="flex-1 flex flex-col justify-center px-8 pt-20">
      <nav class="flex flex-col gap-1">
        {mobileNavItems.map((item, i) => (
          <a
            href={item.href}
            class="mobile-link group flex items-baseline gap-4 py-4 border-b border-border/40 transform translate-y-6 opacity-0 transition-all duration-500"
            style={`transition-delay: ${100 + i * 80}ms`}
          >
            <span class="font-mono text-[10px] text-muted-foreground/50 tracking-wider">{item.num}</span>
            <span class="text-3xl font-sans font-light text-foreground/85 group-hover:text-foreground group-hover:translate-x-1 transition-all uppercase tracking-tight">{item.label}</span>
          </a>
        ))}
      </nav>
    </div>

    <!-- Mobile menu footer -->
    <div class="px-8 pb-10 transform translate-y-4 opacity-0 transition-all duration-500 delay-500 mobile-footer">
      <div class="border-t border-border/50 pt-6 flex justify-between items-end">
        <div>
          <p class="font-mono text-[9px] uppercase tracking-[0.25em] text-muted-foreground/50 mb-2">Visit Us</p>
          <p class="text-muted-foreground/70 text-sm font-light leading-relaxed">
            {ADDRESS_LINE_1}<br/>
            {ADDRESS_LINE_2}
          </p>
        </div>
        <a href={`tel:${PHONE_NUMBER}`} class="font-mono text-[10px] text-primary tracking-wider">{PHONE_NUMBER}</a>
      </div>
    </div>
  </div>
</div>

<style>
  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .nav-wordmark {
    font-family: var(--font-sans);
    font-size: 17px;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--foreground);
  }

  /* Nav never has its own background — pointer-events only on interactive elements */
  #main-nav {
    background: none;
    pointer-events: none;
    transition: background 0.3s ease;
  }

  #main-nav a,
  #main-nav button {
    pointer-events: auto;
  }

  #main-nav.nav-scrolled {
    background: oklch(from var(--background) l c h / 0.94);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    pointer-events: auto;
  }

  /* Links */
  .nav-link:hover {
    color: var(--foreground);
  }

  /* Book button */
  .nav-book-btn {
    border-color: rgba(255, 255, 255, 0.4);
    color: rgba(255, 255, 255, 0.9);
  }

  .nav-scrolled .nav-book-btn {
    border-color: oklch(from var(--foreground) l c h / 0.4);
    color: oklch(from var(--foreground) l c h / 0.85);
  }

  .nav-book-btn:hover {
    background: var(--foreground) !important;
    border-color: var(--foreground) !important;
    color: var(--background) !important;
  }

  /* Hamburger animation */
  .menu-open .hamburger-line:first-child {
    transform: rotate(45deg) translateY(3px);
  }

  .menu-open .hamburger-line:last-child {
    transform: rotate(-45deg) translateY(-3px);
  }

  .mobile-grid-lines {
    background-image:
      linear-gradient(to right, transparent 24.9%, oklch(from var(--border) l c h / 0.35) 25%, transparent 25.1%),
      linear-gradient(to right, transparent 49.9%, oklch(from var(--border) l c h / 0.22) 50%, transparent 50.1%),
      linear-gradient(to right, transparent 74.9%, oklch(from var(--border) l c h / 0.35) 75%, transparent 75.1%);
  }
</style>

<script>
  function initHeader() {
    const nav = document.getElementById('main-nav');
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const mobileLinks = document.querySelectorAll('.mobile-link');
    const mobileFooter = document.querySelector('.mobile-footer');
    let isMenuOpen = false;

    if (!nav) return;

    // Scroll-based nav background
    let lastScroll = 0;
    const handleScroll = () => {
      const scrollY = window.scrollY;

      if (scrollY > 80) {
        nav.classList.remove('nav-transparent');
        nav.classList.add('nav-scrolled');
      } else if (!isMenuOpen) {
        nav.classList.add('nav-transparent');
        nav.classList.remove('nav-scrolled');
      }

      lastScroll = scrollY;
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll(); // Check initial state

    // Mobile menu
    if (!menuBtn || !mobileMenu) return;

    function toggleMenu() {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        mobileMenu.classList.remove('opacity-0', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'pointer-events-auto');

        // Animate links in
        mobileLinks.forEach(link => {
          link.classList.remove('translate-y-6', 'opacity-0');
        });
        mobileFooter?.classList.remove('translate-y-4', 'opacity-0');

        // Hamburger → X
        menuBtn.classList.add('menu-open');

        // Nav stays on top, transparent over menu
        nav.classList.remove('nav-transparent', 'nav-scrolled');
        nav.classList.add('z-[110]');

        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.classList.add('opacity-0', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'pointer-events-auto');

        // Reset link animations
        mobileLinks.forEach(link => {
          link.classList.add('translate-y-6', 'opacity-0');
        });
        mobileFooter?.classList.add('translate-y-4', 'opacity-0');

        // X → Hamburger
        menuBtn.classList.remove('menu-open');

        // Restore nav
        setTimeout(() => {
          nav.classList.remove('z-[110]');
          handleScroll();
        }, 300);

        document.body.style.overflow = '';
      }
    }

    menuBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      toggleMenu();
    });

    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initHeader);
  document.addEventListener('astro:page-load', initHeader);
</script>
