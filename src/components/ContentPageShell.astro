---
interface Props {
  title: string;
  eyebrow?: string;
  heading: string;
  intro?: string;
  lastUpdated?: string;
  ctaEyebrow?: string;
  ctaText?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  eyebrow,
  heading,
  intro,
  lastUpdated,
  ctaEyebrow,
  ctaText,
  ctaLabel,
  ctaHref,
} = Astro.props;
---

<section class="px-6 md:px-20 max-w-4xl">
  <div class="mb-12">
    {eyebrow && <span class="section-label block mb-4">{eyebrow}</span>}
    <h1 class="text-5xl md:text-6xl font-semibold tracking-tighter text-foreground italic mb-6">{heading}</h1>
    {intro && (
      <p class="text-muted-foreground text-base max-w-lg leading-relaxed">
        {intro}
      </p>
    )}
    {lastUpdated && <p class="text-sm text-muted-foreground">Last Updated: {lastUpdated}</p>}
  </div>

  <div class="prose-editorial max-w-none">
    <slot />
  </div>
</section>

{ctaEyebrow && ctaText && ctaLabel && ctaHref && (
  <section class="px-6 md:px-20 mt-16 max-w-4xl">
    <div class="glass-card p-8 text-center">
      <span class="section-label block mb-4">{ctaEyebrow}</span>
      <p class="text-muted-foreground text-base mb-6">
        {ctaText}
      </p>
      <a href={ctaHref} class="inline-block px-8 py-4 bg-foreground text-background text-sm font-medium tracking-wide hover:bg-foreground/90 transition-all">
        {ctaLabel}
      </a>
    </div>
  </section>
)}
