---
interface Props {
  href: string;
  label: string;
}

const { href, label } = Astro.props;
---

<div id="floating-cta" class="hidden lg:block fixed bottom-8 right-8 z-50 transition-all duration-300">
  <a href={href} class="hero-cta group flex items-center gap-3 px-6 py-4 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-[0.15em] transition-all shadow-2xl shadow-primary/30">
    <span class="group-hover:translate-x-1 transition-transform">{label}</span>
    <span class="w-6 h-6 rounded-full flex items-center justify-center bg-primary-foreground text-primary transition-all">→</span>
  </a>
</div>

<style>
  #floating-cta a:hover {
    filter: brightness(1.1);
    transform: translateY(-2px);
    box-shadow: 0 25px 60px oklch(from var(--primary) l c h / 0.4);
  }
</style>
