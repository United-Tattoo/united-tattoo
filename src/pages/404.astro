---
import SiteLayout from '../layouts/SiteLayout.astro';

export const prerender = true;
---

<SiteLayout title="Page Not Found" hideAnnouncement={true}>
  <section class="min-h-[70vh] flex items-center justify-center px-6 md:px-20">
    <div class="text-center max-w-lg">
      <span class="text-8xl md:text-9xl font-normal tracking-tighter text-foreground/10 italic block mb-4">
        404
      </span>

      <h1 class="text-3xl md:text-4xl font-semibold tracking-tighter text-foreground italic mb-4">
        Page Not Found
      </h1>

      <p class="text-muted-foreground text-base mb-8">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="px-8 py-4 bg-foreground text-background text-sm font-medium tracking-wide hover:bg-foreground/90 transition-all">
          Return Home
        </a>
        <a href="/artists" class="px-8 py-4 border border-border text-foreground text-sm hover:bg-secondary transition-all">
          View Artists
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
