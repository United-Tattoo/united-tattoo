---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import EditorialFooter from '../../components/EditorialFooter.astro';
import PageHero from '../../components/PageHero.astro';

export const prerender = true;

const artists = await getCollection('artists');

// Sort artists alphabetically or by some other criteria if needed
const sortedArtists = artists.sort((a, b) => a.data.name.localeCompare(b.data.name));
const specialtyNames = Array.from(
  new Set(sortedArtists.flatMap((artist) => artist.data.specialties || []))
).slice(0, 8);
const heroImage = '/artists/Christy-Lumberg/Portfolio/26-01-02%2019-25-03%2048.jpg';
---

<SiteLayout
  title="The Collective"
  description="Meet the resident artists at United Tattoo. A collective of distinct styles and shared dedication to the craft."
  removeMainPadding={true}
  hideFooter={true}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Artists', url: '/artists' },
  ]}
>
  <div class="relative mx-auto max-w-[1800px] border-l border-r border-border">
  <PageHero
    eyebrow="Resident artists"
    title={['Artists', 'in ink']}
    description="A focused group of tattoo artists with distinct styles, shared standards, and portfolios built around custom work."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Artists' },
    ]}
    image={heroImage}
    imagePosition="76% 45%"
    stats={[
      { value: artists.length, label: 'Artists' },
      { value: specialtyNames.length, label: 'Styles' },
    ]}
  />

  <!-- Artist Gallery -->
  <section class="artist-list-section relative z-20 px-6 pb-28 pt-10 md:px-12 lg:px-20" data-scroll-section>
    <div class="mx-auto max-w-7xl">
    <div class="artist-grid">
      {sortedArtists.map((artist, index) => (
        <a href={`/artists/${artist.id}`} class="artist-card group" data-index={index}>
          <div class="artist-card-media">
            <img
              src={artist.data.portrait}
              alt={artist.data.name}
              class="artist-card-image"
            />
            <div class="artist-card-shade"></div>
          </div>

          <div class="artist-card-body">
            <div>
              <h2>{artist.data.name}</h2>
              <p>
                {artist.data.specialties && artist.data.specialties.length > 0 ? (
                  artist.data.specialties.slice(0, 2).join(' / ')
                ) : (
                  'Custom work'
                )}
              </p>
            </div>

            <span class="artist-card-link">View portfolio <span aria-hidden="true">→</span></span>
          </div>
        </a>
      ))}
    </div>
    </div>
  </section>

  <EditorialFooter />
  </div>

  <script>
    const initAnimations = () => {
      const gsap = (window as any).gsap;
      const ScrollTrigger = (window as any).ScrollTrigger;
      
      if (!gsap || !ScrollTrigger) {
        setTimeout(initAnimations, 100);
        return;
      }

      // Hero Animations
      gsap.set('.page-hero-title-line > span', { y: '100%' });
      gsap.set('.page-hero-reveal', { opacity: 0, y: 20 });
      
      const tl = gsap.timeline({ delay: 0.2 });
      
      tl.to('.page-hero-title-line > span', {
        y: '0%',
        duration: 1.2,
        stagger: 0.1,
        ease: 'power4.out'
      })
      .to('.page-hero-reveal', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: 'power2.out'
      }, '-=0.8');

      // List Animations
      const cards = document.querySelectorAll('.artist-card');
      
      cards.forEach((card, i) => {
        gsap.from(card, {
          y: 60,
          opacity: 0,
          duration: 1.2,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: card,
            start: 'top 90%'
          }
        });
      });
    };

    document.addEventListener('astro:page-load', initAnimations);
  </script>

  <style>
    .artist-list-section {
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--brand-paper) 1.5%, transparent), transparent 14rem),
        var(--background);
    }

    .artist-grid {
      display: grid;
      gap: 0;
      border-left: 1px solid var(--border);
      border-top: 1px solid var(--border);
    }

    @media (min-width: 768px) {
      .artist-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (min-width: 1180px) {
      .artist-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }

    .artist-card {
      position: relative;
      display: grid;
      grid-template-rows: auto 1fr;
      gap: 1rem;
      border-right: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: 1rem;
      color: inherit;
      transition: background 0.25s ease;
    }

    @media (min-width: 768px) {
      .artist-card {
        padding: 1.25rem;
      }
    }

    .artist-card:hover {
      background: color-mix(in srgb, var(--brand-paper) 2.5%, transparent);
    }

    .artist-card-media {
      position: relative;
      aspect-ratio: 4 / 5;
      overflow: hidden;
      background: var(--secondary);
    }

    .artist-card-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      filter: grayscale(0.28) contrast(1.04) brightness(0.88);
      transition: filter 0.55s ease, transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .artist-card:hover .artist-card-image {
      filter: grayscale(0) contrast(1.04) brightness(0.98);
      transform: scale(1.045);
    }

    .artist-card-shade {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgb(0 0 0 / 0.08), transparent 42%),
        linear-gradient(0deg, rgb(0 0 0 / 0.34), transparent 44%);
      opacity: 0.72;
      transition: opacity 0.35s ease;
    }

    .artist-card:hover .artist-card-shade {
      opacity: 0.5;
    }

    .artist-card-body {
      display: grid;
      gap: 1rem;
      min-height: 9rem;
      align-content: space-between;
    }

    .artist-card-body h2 {
      font-family: var(--font-display);
      font-size: clamp(2.35rem, 4vw, 4.8rem);
      font-weight: 400;
      line-height: 0.96;
      letter-spacing: 0;
      color: var(--foreground);
      transition: color 0.25s ease;
    }

    .artist-card-body p {
      margin-top: 0.7rem;
      color: var(--muted-foreground);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.18em;
      line-height: 1.7;
      text-transform: uppercase;
    }

    .artist-card-link {
      width: max-content;
      color: color-mix(in srgb, var(--brand-paper) 42%, transparent);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      transition: color 0.25s ease;
    }

    .artist-card:hover .artist-card-link {
      color: var(--foreground);
    }

    .artist-card-link span {
      display: inline-block;
      letter-spacing: 0;
      transition: transform 0.25s ease;
    }

    .artist-card:hover .artist-card-link span {
      transform: translateX(0.25rem);
    }
  </style>
</SiteLayout>
