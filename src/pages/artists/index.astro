---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import EditorialFooter from '../../components/EditorialFooter.astro';
import GridBackground from '../../components/GridBackground.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';

export const prerender = true;

const artists = await getCollection('artists');

// Sort artists alphabetically or by some other criteria if needed
const sortedArtists = artists.sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<SiteLayout
  title="The Collective"
  description="Meet the resident artists at United Tattoo. A collective of distinct styles and shared dedication to the craft."
  removeMainPadding={true}
  hideFooter={true}
>
  <!-- Hero Section -->
  <section class="artist-hero-section relative min-h-[50vh] lg:min-h-[60vh] flex flex-col justify-end px-6 md:px-12 lg:px-24 pb-24 pt-48" data-scroll-section>
    <GridBackground opacity={20} />
    
    <div class="relative z-10 w-full">
      <div class="artist-hero-reveal mb-8">
        <Breadcrumb
          items={[
            { label: 'Home', href: '/' },
            { label: 'Artists' }
          ]}
        />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
        <div class="lg:col-span-8">
          <h1 class="text-[15vw] lg:text-[12vw] leading-[0.8] font-display font-medium tracking-tighter text-white uppercase mix-blend-difference">
            <span class="artist-hero-title-line block overflow-hidden"><span class="inline-block">The</span></span>
            <span class="artist-hero-title-line block overflow-hidden"><span class="inline-block italic text-neutral-500">Artists</span></span>
          </h1>
        </div>
        
        <div class="lg:col-span-4 artist-hero-reveal mb-2">
          <p class="text-neutral-400 text-lg leading-relaxed font-light border-l border-terracotta/50 pl-6 max-w-sm">
            A collective of distinct styles and shared dedication to the craft. 
            <span class="block mt-4 font-mono text-xs uppercase tracking-widest text-terracotta">
              {artists.length} Resident Artists
            </span>
          </p>
        </div>
      </div>
    </div>
    
    <ScrollIndicator class="artist-hero-reveal absolute bottom-12 right-6 lg:right-12" />
  </section>

  <!-- Artist Gallery -->
  <section class="artist-list-section relative z-20 px-6 md:px-12 lg:px-24 pb-32" data-scroll-section>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-20 lg:gap-y-32">
      {sortedArtists.map((artist, index) => (
        <a href={`/artists/${artist.id}`} class="artist-card group block relative" data-index={index}>
          <!-- Image Container -->
          <div class="relative aspect-[3/4] overflow-hidden bg-white/5 mb-8">
            <!-- Frame/Border Effect -->
            <div class="absolute inset-0 border border-white/10 z-20 transition-colors duration-500 group-hover:border-white/30"></div>
            
            <!-- Image -->
            <img
              src={artist.data.portrait}
              alt={artist.data.name}
              class="absolute inset-0 w-full h-full object-cover grayscale-[20%] contrast-[1.1] transition-all duration-700 ease-[cubic-bezier(0.25,1,0.5,1)] group-hover:scale-105 group-hover:grayscale-0"
            />
            
            <!-- Hover Overlay (Warmth) -->
            <div class="absolute inset-0 bg-terracotta/0 mix-blend-overlay transition-colors duration-700 group-hover:bg-terracotta/20 z-10"></div>
            
            <!-- Corner Accents -->
            <div class="absolute top-0 left-0 w-3 h-3 border-l border-t border-white/0 transition-all duration-500 group-hover:border-terracotta/80 z-30"></div>
            <div class="absolute bottom-0 right-0 w-3 h-3 border-r border-b border-white/0 transition-all duration-500 group-hover:border-terracotta/80 z-30"></div>
          </div>

          <!-- Typography / Label -->
          <div class="flex flex-col items-start relative overflow-hidden">
            <h2 class="text-3xl lg:text-4xl font-display text-white group-hover:text-terracotta transition-colors duration-300">
              {artist.data.name}
            </h2>
            
            <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-neutral-500 group-hover:text-neutral-300 transition-colors duration-300">
              {artist.data.specialties && artist.data.specialties.slice(0, 2).map((specialty, i) => (
                <span class="font-mono text-[10px] uppercase tracking-widest flex items-center gap-4">
                  {specialty}
                  {i < (artist.data.specialties?.slice(0, 2).length || 0) - 1 && (
                    <span class="w-1 h-1 rounded-full bg-terracotta/50"></span>
                  )}
                </span>
              ))}
            </div>

            <!-- Hover "View" CTA -->
            <div class="absolute right-0 top-1/2 -translate-y-1/2 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-500 delay-100">
              <iconify-icon icon="solar:arrow-right-linear" class="text-2xl text-white"></iconify-icon>
            </div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <EditorialFooter />

  <script>
    const initAnimations = () => {
      const gsap = (window as any).gsap;
      const ScrollTrigger = (window as any).ScrollTrigger;
      
      if (!gsap || !ScrollTrigger) {
        setTimeout(initAnimations, 100);
        return;
      }

      // Hero Animations
      gsap.set('.artist-hero-title-line > span', { y: '100%' });
      gsap.set('.artist-hero-reveal', { opacity: 0, y: 20 });
      
      const tl = gsap.timeline({ delay: 0.2 });
      
      tl.to('.artist-hero-title-line > span', {
        y: '0%',
        duration: 1.2,
        stagger: 0.1,
        ease: 'power4.out'
      })
      .to('.artist-hero-reveal', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: 'power2.out'
      }, '-=0.8');

      // List Animations
      const cards = document.querySelectorAll('.artist-card');
      
      cards.forEach((card, i) => {
        gsap.from(card, {
          y: 60,
          opacity: 0,
          duration: 1.2,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: card,
            start: 'top 90%'
          }
        });
      });
    };

    document.addEventListener('astro:page-load', initAnimations);
  </script>
</SiteLayout>