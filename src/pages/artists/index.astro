---
import '../../styles/global.css';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../../consts';

export const prerender = true;

const artists = await getCollection('artists');
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Our Artists | {SITE_TITLE}</title>
		<meta name="description" content="Meet the talented artists at United Tattoo. Each brings unique skills and artistic vision to create exceptional custom tattoos." />
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<!-- Icons -->
		<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
	</head>
	<body class="bg-bg-deep text-text-main selection:bg-white/20 selection:text-white">
		<!-- Background Elements -->
		<div class="fixed inset-0 noise pointer-events-none z-50"></div>
		<div class="fixed inset-0 bg-grid pointer-events-none -z-10"></div>

		<!-- Technical Banner -->
		<div class="fixed top-0 left-0 w-full h-8 bg-[#0a0a0a] border-b border-white/5 z-[70] flex items-center justify-center overflow-hidden">
			<div class="flex items-center gap-4 animate-in fade-in slide-in-from-top-4 duration-700">
				<span class="relative flex h-1.5 w-1.5">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white/40 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span>
				</span>
				<p class="font-mono text-[9px] uppercase tracking-[0.2em] text-neutral-400">
					[System Status: <span class="text-white">Active</span>] &nbsp; | &nbsp; Now booking for <span class="text-white italic">February 2026</span>
				</p>
			</div>
		</div>

		<!-- Navigation -->
		<nav class="fixed top-8 left-0 w-full px-6 py-4 flex justify-between items-center z-[60] glass-card border-x-0 border-t-0 bg-black/40 backdrop-blur-md">
			<div class="flex items-center gap-4">
				<a href="/" class="font-display text-3xl font-normal tracking-tighter leading-none hover:opacity-70 transition-opacity italic">UNITED TATTOO</a>
				<div class="hidden lg:block w-[1px] h-4 bg-white/10 mx-2"></div>
				<span class="hidden lg:block font-mono text-[9px] text-neutral-500 tracking-[0.3em] uppercase">38.6942° N, 104.7008° W</span>
			</div>

			<div class="hidden md:flex gap-10 font-mono text-[10px] uppercase tracking-[0.25em] items-center text-neutral-400">
				<a href="/artists" class="text-white">[ Artists ]</a>
				<a href="/#process" class="hover:text-white transition-colors">[ Process ]</a>
				<a href="/booking" class="group relative px-6 py-2 bg-white text-black rounded-sm font-bold hover:bg-neutral-200 transition-all flex items-center gap-2">
					BOOK SESSION
					<iconify-icon icon="solar:arrow-right-up-linear" class="text-sm group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"></iconify-icon>
				</a>
			</div>

			<button class="md:hidden text-[10px] uppercase font-mono border border-white/20 px-4 py-1.5 rounded-sm bg-white/5">Menu</button>
		</nav>

		<main class="pt-32 pb-24">
			<!-- Page Header -->
			<section class="px-6 md:px-20 mb-20">
				<div class="flex flex-col md:flex-row justify-between items-end border-b border-white/5 pb-12">
					<div class="space-y-4">
						<div class="flex items-center gap-3">
							<span class="font-mono text-[10px] text-white bg-white/10 px-2 py-0.5 rounded-sm uppercase tracking-widest">[ ARCHIVE_ROSTER ]</span>
							<div class="w-12 h-[1px] bg-white/20"></div>
						</div>
						<h1 class="text-6xl md:text-8xl font-normal tracking-tighter text-white italic">The Collective</h1>
						<p class="font-mono text-[11px] text-neutral-400 uppercase tracking-wider max-w-md">
							Meet the resident artists of United Tattoo. Each brings unique expertise and artistic vision to create exceptional custom work.
						</p>
					</div>
					<div class="hidden md:block">
						<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-[0.3em]">{artists.length} ACTIVE_RESIDENTS</span>
					</div>
				</div>
			</section>

			<!-- Artists Grid -->
			<section class="px-6 md:px-20">
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
					{artists.map((artist, index) => (
						<a href={`/artists/${artist.id}`} class="group relative aspect-[3/4] overflow-hidden bg-neutral-950 border border-white/10 hover:border-white/30 transition-all duration-500">
							<img
								src={artist.data.portrait}
								alt={artist.data.name}
								class="absolute inset-0 w-full h-full object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 group-hover:scale-[1.02] transition-all duration-1000 ease-out"
							/>

							<!-- Glass Info Card -->
							<div class="absolute bottom-4 left-4 right-4 p-5 glass-card opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 z-30">
								<div class="flex justify-between items-start mb-4">
									<div>
										<span class="font-mono text-[8px] text-neutral-500 uppercase tracking-widest block mb-1">[ ID: 00{index + 1} ]</span>
										<h3 class="text-2xl font-normal text-white italic leading-none">{artist.data.name}</h3>
									</div>
									<div class="w-2 h-2 rounded-full bg-white/80 animate-pulse"></div>
								</div>

								{artist.data.specialties && (
									<div class="flex flex-wrap gap-1 mb-4">
										{artist.data.specialties.slice(0, 3).map((specialty: string) => (
											<span class="font-mono text-[7px] text-neutral-400 uppercase tracking-wider bg-white/5 px-2 py-0.5 rounded-sm">{specialty}</span>
										))}
									</div>
								)}

								<div class="flex items-center justify-between border-t border-white/10 pt-4">
									<span class="font-mono text-[8px] text-neutral-400 uppercase tracking-widest">Resident Artist</span>
									<div class="flex items-center gap-2">
										<span class="font-mono text-[8px] text-white uppercase tracking-widest">Portfolio</span>
										<iconify-icon icon="solar:arrow-right-up-linear" class="text-xs text-white"></iconify-icon>
									</div>
								</div>
							</div>

							<!-- Initial State Overlay -->
							<div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60 group-hover:opacity-0 transition-opacity duration-700"></div>
							<div class="absolute bottom-6 left-6 group-hover:opacity-0 transition-opacity">
								<h3 class="text-2xl font-normal text-white italic tracking-tight">{artist.data.name}</h3>
							</div>
						</a>
					))}
				</div>
			</section>

			<!-- CTA Section -->
			<section class="px-6 md:px-20 mt-32">
				<div class="glass-card p-12 md:p-16 text-center">
					<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-[0.4em] block mb-6">[ INITIATE_CONTACT ]</span>
					<h2 class="text-4xl md:text-5xl font-normal italic tracking-tighter text-white mb-6">Ready to Begin?</h2>
					<p class="font-mono text-[11px] text-neutral-400 uppercase tracking-wider max-w-md mx-auto mb-10">
						Submit a booking request and let's create something exceptional together.
					</p>
					<a href="/booking" class="inline-flex items-center gap-3 px-10 py-5 bg-white text-black font-mono font-bold uppercase text-[10px] tracking-[0.2em] hover:bg-neutral-200 transition-all">
						BOOK A SESSION
						<iconify-icon icon="solar:arrow-right-up-linear" class="text-base"></iconify-icon>
					</a>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="py-12 px-6 md:px-20 border-t border-white/5">
			<div class="flex flex-col md:flex-row justify-between items-center gap-8">
				<div class="flex items-center gap-4">
					<div class="w-2 h-2 rounded-full bg-white animate-pulse"></div>
					<span class="font-mono text-[9px] text-neutral-600 uppercase tracking-[0.3em]">System Verified © 2025 United Tattoo Collective.</span>
				</div>
				<div class="flex items-center gap-12">
					<a href="/privacy" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Privacy_Protocol</a>
					<a href="/terms" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Legal_Terms</a>
					<a href="/aftercare" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Aftercare</a>
				</div>
			</div>
		</footer>
	</body>
</html>

