---
import '../../styles/global.css';
import { getCollection, render } from 'astro:content';
import { SITE_TITLE } from '../../consts';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

export async function getStaticPaths() {
  const artists = await getCollection('artists');
  return artists.map((artist) => ({
    params: { slug: artist.id },
    props: { artist },
  }));
}

const { artist } = Astro.props;
const { Content } = await render(artist);

// Read portfolio images from the public directory at build time
const publicDir = path.join(process.cwd(), 'public');
const portfolioPath = path.join(publicDir, artist.data.galleryDir, 'Portfolio');

let portfolioImages: string[] = [];
try {
  if (fs.existsSync(portfolioPath)) {
    const files = fs.readdirSync(portfolioPath);
    portfolioImages = files
      .filter((file) => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(file))
      .map((file) => `/${artist.data.galleryDir}/Portfolio/${file}`);
  }
} catch (e) {
  // If the directory doesn't exist or can't be read, we'll just show no portfolio images
  console.warn(`Could not read portfolio directory for ${artist.data.name}:`, e);
}

// Also check for flash sheets
const flashPath = path.join(publicDir, artist.data.galleryDir, 'Flash');
let flashImages: string[] = [];
try {
  if (fs.existsSync(flashPath)) {
    const files = fs.readdirSync(flashPath);
    flashImages = files
      .filter((file) => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(file))
      .map((file) => `/${artist.data.galleryDir}/Flash/${file}`);
  }
} catch (e) {
  // No flash directory
}
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{artist.data.name} | {SITE_TITLE}</title>
		<meta name="description" content={`View the portfolio and learn more about ${artist.data.name}, a resident artist at United Tattoo in Fountain, CO.`} />
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<!-- Icons -->
		<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
	</head>
	<body class="bg-bg-deep text-text-main selection:bg-white/20 selection:text-white">
		<!-- Background Elements -->
		<div class="fixed inset-0 noise pointer-events-none z-50"></div>
		<div class="fixed inset-0 bg-grid pointer-events-none -z-10"></div>

		<!-- Technical Banner -->
		<div class="fixed top-0 left-0 w-full h-8 bg-[#0a0a0a] border-b border-white/5 z-[70] flex items-center justify-center overflow-hidden">
			<div class="flex items-center gap-4 animate-in fade-in slide-in-from-top-4 duration-700">
				<span class="relative flex h-1.5 w-1.5">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white/40 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span>
				</span>
				<p class="font-mono text-[9px] uppercase tracking-[0.2em] text-neutral-400">
					[System Status: <span class="text-white">Active</span>] &nbsp; | &nbsp; Now booking for <span class="text-white italic">February 2026</span>
				</p>
			</div>
		</div>

		<!-- Navigation -->
		<nav class="fixed top-8 left-0 w-full px-6 py-4 flex justify-between items-center z-[60] glass-card border-x-0 border-t-0 bg-black/40 backdrop-blur-md">
			<div class="flex items-center gap-4">
				<a href="/" class="font-display text-3xl font-normal tracking-tighter leading-none hover:opacity-70 transition-opacity italic">UNITED TATTOO</a>
				<div class="hidden lg:block w-[1px] h-4 bg-white/10 mx-2"></div>
				<span class="hidden lg:block font-mono text-[9px] text-neutral-500 tracking-[0.3em] uppercase">38.6942° N, 104.7008° W</span>
			</div>

			<div class="hidden md:flex gap-10 font-mono text-[10px] uppercase tracking-[0.25em] items-center text-neutral-400">
				<a href="/artists" class="text-white">[ Artists ]</a>
				<a href="/#process" class="hover:text-white transition-colors">[ Process ]</a>
				<a href="/booking" class="group relative px-6 py-2 bg-white text-black rounded-sm font-bold hover:bg-neutral-200 transition-all flex items-center gap-2">
					BOOK SESSION
					<iconify-icon icon="solar:arrow-right-up-linear" class="text-sm group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"></iconify-icon>
				</a>
			</div>

			<button class="md:hidden text-[10px] uppercase font-mono border border-white/20 px-4 py-1.5 rounded-sm bg-white/5">Menu</button>
		</nav>

		<main class="pt-32 pb-24">
			<!-- Breadcrumb -->
			<section class="px-6 md:px-20 mb-8">
				<nav class="flex items-center gap-2 font-mono text-[10px] text-neutral-500 uppercase tracking-widest">
					<a href="/" class="hover:text-white transition-colors">Home</a>
					<span>/</span>
					<a href="/artists" class="hover:text-white transition-colors">Artists</a>
					<span>/</span>
					<span class="text-white">{artist.data.name}</span>
				</nav>
			</section>

			<!-- Artist Header -->
			<section class="px-6 md:px-20 mb-16">
				<div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
					<!-- Portrait -->
					<div class="relative aspect-[3/4] overflow-hidden border border-white/10">
						<img
							src={artist.data.portrait}
							alt={artist.data.name}
							class="absolute inset-0 w-full h-full object-cover"
						/>
					</div>

					<!-- Info -->
					<div class="lg:col-span-2 flex flex-col justify-center">
						<div class="flex items-center gap-3 mb-4">
							<span class="font-mono text-[10px] text-white bg-white/10 px-2 py-0.5 rounded-sm uppercase tracking-widest">[ ARTIST_PROFILE ]</span>
							<div class="w-12 h-[1px] bg-white/20"></div>
						</div>

						<h1 class="text-5xl md:text-7xl font-normal tracking-tighter text-white italic mb-6">{artist.data.name}</h1>

						{artist.data.specialties && (
							<div class="flex flex-wrap gap-2 mb-8">
								{artist.data.specialties.map((specialty: string) => (
									<span class="font-mono text-[9px] text-neutral-300 uppercase tracking-wider bg-white/5 border border-white/10 px-3 py-1.5 rounded-sm">{specialty}</span>
								))}
							</div>
						)}

						<div class="prose prose-invert prose-sm max-w-none mb-10 [&>h2]:font-display [&>h2]:text-3xl [&>h2]:italic [&>h2]:tracking-tight [&>h2]:text-white [&>h2]:mb-4 [&>h2]:mt-8 [&>h3]:font-mono [&>h3]:text-xs [&>h3]:uppercase [&>h3]:tracking-widest [&>h3]:text-neutral-400 [&>h3]:mt-6 [&>h3]:mb-3 [&>p]:text-neutral-400 [&>p]:text-sm [&>p]:leading-relaxed">
							<Content />
						</div>

						<div class="flex flex-wrap gap-4">
							<a href={`/booking?artist=${artist.id}`} class="inline-flex items-center gap-3 px-8 py-4 bg-white text-black font-mono font-bold uppercase text-[10px] tracking-[0.2em] hover:bg-neutral-200 transition-all">
								BOOK WITH {artist.data.name.split(' ')[0].toUpperCase()}
								<iconify-icon icon="solar:calendar-bold" class="text-base"></iconify-icon>
							</a>

							{artist.data.instagram && (
								<a href={`https://instagram.com/${artist.data.instagram.replace('@', '')}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 px-8 py-4 border border-white/10 text-white font-mono uppercase text-[10px] tracking-[0.2em] hover:bg-white/5 transition-all">
									<iconify-icon icon="mdi:instagram" class="text-base"></iconify-icon>
									{artist.data.instagram}
								</a>
							)}
						</div>
					</div>
				</div>
			</section>

			<!-- Portfolio Gallery -->
			{portfolioImages.length > 0 && (
				<section class="px-6 md:px-20 mb-20">
					<div class="flex items-center gap-4 mb-10 border-b border-white/5 pb-6">
						<span class="font-mono text-[10px] text-white bg-white/10 px-2 py-0.5 rounded-sm uppercase tracking-widest">[ PORTFOLIO ]</span>
						<div class="w-12 h-[1px] bg-white/20"></div>
						<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-[0.3em]">{portfolioImages.length} WORKS</span>
					</div>

					<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
						{portfolioImages.map((image, index) => (
							<div class="group relative aspect-square overflow-hidden bg-neutral-950 border border-white/5 hover:border-white/20 transition-all cursor-pointer">
								<img
									src={image}
									alt={`${artist.data.name} portfolio work ${index + 1}`}
									class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
									loading="lazy"
								/>
								<div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors"></div>
							</div>
						))}
					</div>
				</section>
			)}

			<!-- Flash Gallery -->
			{flashImages.length > 0 && (
				<section class="px-6 md:px-20 mb-20">
					<div class="flex items-center gap-4 mb-10 border-b border-white/5 pb-6">
						<span class="font-mono text-[10px] text-white bg-white/10 px-2 py-0.5 rounded-sm uppercase tracking-widest">[ FLASH SHEETS ]</span>
						<div class="w-12 h-[1px] bg-white/20"></div>
						<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-[0.3em]">{flashImages.length} DESIGNS</span>
					</div>

					<div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-2">
						{flashImages.map((image, index) => (
							<div class="group relative aspect-square overflow-hidden bg-neutral-950 border border-white/5 hover:border-white/20 transition-all cursor-pointer">
								<img
									src={image}
									alt={`${artist.data.name} flash design ${index + 1}`}
									class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
									loading="lazy"
								/>
								<div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors"></div>
							</div>
						))}
					</div>
				</section>
			)}

			<!-- CTA Section -->
			<section class="px-6 md:px-20 mt-20">
				<div class="glass-card p-12 md:p-16 text-center">
					<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-[0.4em] block mb-6">[ INITIATE_PROJECT ]</span>
					<h2 class="text-4xl md:text-5xl font-normal italic tracking-tighter text-white mb-6">Work with {artist.data.name.split(' ')[0]}</h2>
					<p class="font-mono text-[11px] text-neutral-400 uppercase tracking-wider max-w-md mx-auto mb-10">
						Ready to start your project? Submit a booking request with your ideas and reference images.
					</p>
					<a href={`/booking?artist=${artist.id}`} class="inline-flex items-center gap-3 px-10 py-5 bg-white text-black font-mono font-bold uppercase text-[10px] tracking-[0.2em] hover:bg-neutral-200 transition-all">
						BOOK A SESSION
						<iconify-icon icon="solar:arrow-right-up-linear" class="text-base"></iconify-icon>
					</a>
				</div>
			</section>

			<!-- Back to Artists -->
			<section class="px-6 md:px-20 mt-16 text-center">
				<a href="/artists" class="inline-flex items-center gap-2 font-mono text-[10px] text-neutral-500 uppercase tracking-widest hover:text-white transition-colors">
					<iconify-icon icon="solar:arrow-left-linear" class="text-sm"></iconify-icon>
					Back to All Artists
				</a>
			</section>
		</main>

		<!-- Footer -->
		<footer class="py-12 px-6 md:px-20 border-t border-white/5">
			<div class="flex flex-col md:flex-row justify-between items-center gap-8">
				<div class="flex items-center gap-4">
					<div class="w-2 h-2 rounded-full bg-white animate-pulse"></div>
					<span class="font-mono text-[9px] text-neutral-600 uppercase tracking-[0.3em]">System Verified © 2025 United Tattoo Collective.</span>
				</div>
				<div class="flex items-center gap-12">
					<a href="/privacy" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Privacy_Protocol</a>
					<a href="/terms" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Legal_Terms</a>
					<a href="/aftercare" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Aftercare</a>
				</div>
			</div>
		</footer>
	</body>
</html>

