---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection, render } from 'astro:content';
import EditorialFooter from '../../components/EditorialFooter.astro';
import SectionSidebar from '../../components/SectionSidebar.astro';
import FloatingCTA from '../../components/FloatingCTA.astro';
import ScrollIndicator from '../../components/ScrollIndicator.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import GridBackground from '../../components/GridBackground.astro';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

export async function getStaticPaths() {
  const artists = await getCollection('artists');
  return artists.map((artist) => ({
    params: { slug: artist.id },
    props: { artist },
  }));
}

const { artist } = Astro.props;
const { Content } = await render(artist);

// Read portfolio images from the public directory at build time
const publicDir = path.join(process.cwd(), 'public');
const portfolioPath = path.join(publicDir, artist.data.galleryDir, 'Portfolio');

let portfolioImages: string[] = [];
try {
  if (fs.existsSync(portfolioPath)) {
    const files = fs.readdirSync(portfolioPath);
    portfolioImages = files
      .filter((file) => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(file))
      .map((file) => `/${artist.data.galleryDir}/Portfolio/${file}`);
  }
} catch (e) {
  console.warn(`Could not read portfolio directory for ${artist.data.name}:`, e);
}

// Also check for flash sheets
const flashPath = path.join(publicDir, artist.data.galleryDir, 'Flash');
let flashImages: string[] = [];
try {
  if (fs.existsSync(flashPath)) {
    const files = fs.readdirSync(flashPath);
    flashImages = files
      .filter((file) => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(file))
      .map((file) => `/${artist.data.galleryDir}/Flash/${file}`);
  }
} catch (e) {
  // No flash directory
}

const firstName = artist.data.name.split(' ')[0];
const lastName = artist.data.name.split(' ').slice(1).join(' ');

// Schema Data
const artistSchema = {
  name: artist.data.name,
  description: `Professional tattoo artist specializing in ${artist.data.specialties?.join(', ') || 'custom tattoos'}.`,
  image: artist.data.portrait,
  sameAs: [
    artist.data.instagram ? `https://instagram.com/${artist.data.instagram.replace('@', '')}` : '',
    artist.data.facebook ? `https://facebook.com/${artist.data.facebook}` : '',
    artist.data.tiktok ? `https://tiktok.com/@${artist.data.tiktok.replace('@', '')}` : '',
    artist.data.portfolioUrl || ''
  ].filter(Boolean)
};
---

<SiteLayout
  title={artist.data.name}
  description={`View the portfolio of ${artist.data.name} at United Tattoo.`}
  removeMainPadding={true}
  hideFooter={true}
  type="profile"
  artistSchema={artistSchema}
  image={artist.data.portrait}
>
  <FloatingCTA href={`/booking?artist=${artist.id}`} label={`Book with ${firstName}`} />

  <div class="main-content-wrapper relative">

  <!-- Hero Section -->
  <section class="artist-hero relative min-h-[90vh] flex flex-col justify-end overflow-hidden px-6 md:px-12 lg:px-24 pb-20 pt-48" data-scroll-section>
    <!-- Background Image with Editorial Mask -->
    <div class="absolute inset-0 z-0 select-none">
       <!-- Grid Overlay -->
       <GridBackground opacity={20} />
       
       <div class="absolute inset-0 z-0">
          <img
            src={artist.data.portrait}
            alt={artist.data.name}
            class="artist-hero-image w-full h-full object-cover object-[center_20%] opacity-40 grayscale-[20%] mix-blend-luminosity"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/80 to-background/10"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-background via-background/40 to-transparent"></div>
       </div>
    </div>

    <!-- Content -->
    <div class="relative z-10 w-full">
      <div class="artist-hero-reveal mb-12">
        <Breadcrumb items={[
          { label: 'Home', href: '/' },
          { label: 'Artists', href: '/artists' },
          { label: artist.data.name }
        ]} />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
        <div class="lg:col-span-9">
            <!-- Dramatic Typography -->
            <h1 class="artist-hero-title text-[15vw] md:text-[13vw] lg:text-[11vw] leading-[0.8] font-sans font-semibold tracking-tighter uppercase text-foreground mix-blend-difference mb-8">
              <span class="block overflow-hidden"><span class="artist-name-line inline-block">{firstName}</span></span>
              <span class="block overflow-hidden"><span class="artist-name-line inline-block text-foreground/50 italic">{lastName}</span></span>
            </h1>

            <!-- Specialties -->
            <div class="artist-hero-reveal flex flex-wrap gap-x-6 gap-y-3 items-center text-sm">
                {artist.data.specialties?.map((specialty, i) => (
                    <span class="font-mono text-xs uppercase tracking-[0.15em] text-muted-foreground flex items-center gap-6">
                        {specialty}
                        {i < (artist.data.specialties?.length || 0) - 1 && <span class="w-1 h-1 rounded-full bg-primary"></span>}
                    </span>
                ))}
            </div>
        </div>

        <!-- Social & Stats -->
        <div class="lg:col-span-3 artist-hero-reveal flex flex-col justify-end">
            <div class="space-y-6 border-l border-primary/30 pl-6">
                <div class="flex flex-col gap-1">
                    <span class="font-mono text-[9px] uppercase tracking-widest text-muted-foreground">Portfolio</span>
                    <span class="font-sans font-semibold text-2xl text-foreground">{portfolioImages.length} <span class="text-sm text-muted-foreground italic">Works</span></span>
                </div>

                {artist.data.instagram && (
                    <a href={`https://instagram.com/${artist.data.instagram.replace('@', '')}`} target="_blank" class="flex flex-col gap-1 group">
                        <span class="font-mono text-[9px] uppercase tracking-widest text-muted-foreground group-hover:text-primary transition-colors">Instagram</span>
                        <span class="font-mono text-sm text-foreground group-hover:translate-x-1 transition-transform">@{artist.data.instagram}</span>
                    </a>
                )}
            </div>
        </div>
      </div>
    </div>

    <ScrollIndicator class="artist-hero-scroll absolute bottom-12 right-6 lg:right-12" />
  </section>

  <!-- Bio Section -->
  <section class="about-section relative z-20 border-t border-border" data-scroll-section>
    <SectionSidebar
      sectionNum="01"
      label="About"
      description={`Meet ${firstName}`}
    >
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 px-6 md:px-12 py-20 lg:py-32">
        <div class="about-bio prose-editorial max-w-none">
            <h2 class="text-3xl lg:text-4xl font-sans font-semibold italic text-foreground mb-8">Artist Statement</h2>
            <Content />
        </div>
        
        <div class="relative">
            <div class="sticky top-32 p-10 border border-border bg-secondary backdrop-blur-sm">
                 <h3 class="font-sans font-semibold text-3xl text-foreground mb-6">Start a Project</h3>
                 <p class="font-mono text-xs text-muted-foreground leading-relaxed mb-8">
                    {firstName} specializes in {artist.data.specialties?.[0].toLowerCase()} and is currently accepting new clients.
                 </p>
                 <a href={`/booking?artist=${artist.id}`} class="w-full block text-center bg-foreground text-background font-mono text-xs uppercase tracking-[0.2em] py-4 hover:bg-primary hover:text-primary-foreground transition-colors duration-300">
                    Request Booking
                 </a>
            </div>
        </div>
      </div>
    </SectionSidebar>
  </section>

  <!-- Testimonials Section -->
  {artist.data.testimonials && artist.data.testimonials.length > 0 && (
    <section class="testimonials-section relative z-20 border-t border-border" data-scroll-section>
      <SectionSidebar
        sectionNum="02"
        label="Words"
        description="Client Experiences"
      >
        <div class="px-6 md:px-12 py-20 lg:py-32">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-24">
            {artist.data.testimonials.map((testimonial) => (
              <div class="testimonial-card">
                <blockquote class="font-sans font-semibold italic text-2xl md:text-3xl text-foreground leading-relaxed mb-6">
                  "{testimonial.quote}"
                </blockquote>
                <cite class="font-mono text-xs uppercase tracking-widest text-primary not-italic">
                  — {testimonial.client}
                </cite>
              </div>
            ))}
          </div>
        </div>
      </SectionSidebar>
    </section>
  )}

  <!-- Unified Works Section with Toggle -->
  {(portfolioImages.length > 0 || flashImages.length > 0) && (
    <section class="works-section relative z-20 border-t border-border" data-scroll-section>
      <SectionSidebar
        sectionNum={artist.data.testimonials && artist.data.testimonials.length > 0 ? "03" : "02"}
        label="Works"
        description="Selected Pieces"
      >
        <div class="px-6 md:px-12 py-20 lg:py-32">
           
           <!-- Toggle Controls -->
           <div class="flex items-center gap-8 mb-16 border-b border-border pb-6">
              <button id="show-portfolio" class="work-toggle active font-sans font-semibold text-3xl text-foreground transition-colors duration-300 hover:text-primary">
                Portfolio <span class="text-sm font-mono text-muted-foreground ml-2 align-middle">({portfolioImages.length})</span>
              </button>
              <button id="show-flash" class="work-toggle font-sans font-semibold text-3xl text-muted-foreground/40 transition-colors duration-300 hover:text-primary">
                Flash <span class="text-sm font-mono text-muted-foreground ml-2 align-middle">({flashImages.length})</span>
              </button>
           </div>

           <!-- Portfolio Grid -->
           <div id="portfolio-grid" class="work-grid transition-opacity duration-500">
             <div class="grid grid-cols-2 md:grid-cols-6 gap-1">
                {portfolioImages.map((image, index) => {
                    const pattern = index % 6;
                    let gridClass = ""; 
                    if (pattern === 0) gridClass = "col-span-2 md:col-span-4 aspect-[3/2] md:aspect-[4/3]";
                    else if (pattern === 1) gridClass = "col-span-1 md:col-span-2 aspect-square md:aspect-[2/3]";
                    else if (pattern === 2) gridClass = "col-span-1 md:col-span-2 aspect-square";
                    else if (pattern === 3) gridClass = "col-span-1 md:col-span-2 aspect-square";
                    else if (pattern === 4) gridClass = "col-span-1 md:col-span-2 aspect-square";
                    else if (pattern === 5) gridClass = "col-span-2 md:col-span-6 aspect-[2/1] md:aspect-[3/1]";

                    return (
                      <div 
                          class={`group relative overflow-hidden bg-secondary cursor-pointer ${gridClass}`}
                          data-lightbox-trigger
                          data-image-src={image}
                          data-image-alt={`${artist.data.name} portfolio ${index + 1}`}
                          role="button"
                          tabindex="0"
                      >
                          <img 
                          src={image} 
                          alt="" 
                          loading="lazy"
                          class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105 opacity-80 group-hover:opacity-100" 
                          />
                          <div class="absolute inset-0 border border-transparent group-hover:border-input transition-colors z-20"></div>
                          <div class="absolute bottom-4 left-4 font-mono text-[9px] text-white opacity-0 group-hover:opacity-100 transition-opacity z-20 tracking-widest uppercase bg-black/50 px-2 py-1 backdrop-blur-sm">
                              View Piece
                          </div>
                      </div>
                    );
                })}
             </div>
           </div>

           <!-- Flash Grid -->
           <div id="flash-grid" class="work-grid hidden opacity-0 transition-opacity duration-500">
             <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                {flashImages.map((image, index) => (
                    <div 
                      class="group relative aspect-[4/5] bg-popover p-3 shadow-lg rotate-1 hover:rotate-0 hover:scale-105 transition-all duration-300 cursor-pointer"
                      data-lightbox-trigger
                      data-image-src={image}
                      data-image-alt={`${artist.data.name} flash ${index + 1}`}
                      role="button"
                      tabindex="0"
                    >
                       <!-- Pin effect -->
                       <div class="absolute top-2 left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-black/20 shadow-inner z-20"></div>
                       
                       <div class="relative w-full h-full overflow-hidden border border-black/10 bg-white">
                          <img 
                          src={image} 
                          alt="" 
                          loading="lazy"
                          class="absolute inset-0 w-full h-full object-cover grayscale-[10%] group-hover:grayscale-0 transition-all duration-500" 
                          />
                       </div>
                       <div class="absolute bottom-4 right-4 z-20 opacity-0 group-hover:opacity-100 transition-opacity">
                          <iconify-icon icon="solar:magnifer-zoom-in-linear" class="text-black text-xl"></iconify-icon>
                       </div>
                    </div>
                ))}
             </div>
           </div>

        </div>
      </SectionSidebar>
    </section>
  )}

    <!-- Next Artist / Footer Nav -->
  <section class="relative z-20 border-t border-border bg-card py-24 lg:py-32" data-scroll-section>
    <div class="container mx-auto px-6 text-center">
        <span class="font-mono text-[10px] uppercase tracking-[0.3em] text-primary mb-6 block">Explore More</span>
        <h2 class="text-4xl md:text-5xl lg:text-7xl font-sans font-semibold italic text-foreground mb-12">
            Continue the Journey
        </h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
            <a href="/artists" class="px-8 py-4 border border-border text-foreground font-mono text-xs uppercase tracking-widest hover:bg-foreground hover:text-background transition-all">
                All Artists
            </a>
            <a href={`/booking?artist=${artist.id}`} class="px-8 py-4 bg-foreground text-background font-mono text-xs uppercase tracking-widest hover:bg-primary hover:text-primary-foreground transition-all">
                Book with {firstName}
            </a>
        </div>
    </div>
  </section>

  </div>

  <EditorialFooter />

  <!-- Lightbox (Reused Logic) -->
  <div id="lightbox" class="fixed inset-0 z-[100] bg-black/98 backdrop-blur-md hidden items-center justify-center p-4 lg:p-12 opacity-0 transition-opacity duration-300" role="dialog" aria-modal="true">
    <div class="absolute top-6 right-6 z-20">
        <button id="lightbox-close" class="group flex items-center gap-2 text-muted-foreground hover:text-foreground transition-colors">
            <span class="font-mono text-[10px] uppercase tracking-widest">Close</span>
            <iconify-icon icon="solar:close-circle-linear" class="text-2xl"></iconify-icon>
        </button>
    </div>
    
    <div class="relative w-full h-full flex items-center justify-center">
        <button id="lightbox-prev" class="absolute left-0 top-1/2 -translate-y-1/2 p-4 text-foreground/50 hover:text-foreground transition-colors">
            <iconify-icon icon="solar:arrow-left-linear" class="text-3xl"></iconify-icon>
        </button>
        
        <img id="lightbox-image" src="" alt="" class="max-h-full max-w-full object-contain shadow-2xl" />
        
        <button id="lightbox-next" class="absolute right-0 top-1/2 -translate-y-1/2 p-4 text-foreground/50 hover:text-foreground transition-colors">
            <iconify-icon icon="solar:arrow-right-linear" class="text-3xl"></iconify-icon>
        </button>
    </div>
  </div>

  <script>
    const initAnimations = () => {
      const gsap = (window as any).gsap;
      const ScrollTrigger = (window as any).ScrollTrigger;
      
      if (!gsap || !ScrollTrigger) { setTimeout(initAnimations, 100); return; }

      // Hero
      const heroTl = gsap.timeline({ delay: 0.2 });
      gsap.set('.artist-name-line', { y: '100%' });
      gsap.set('.artist-hero-reveal', { opacity: 0, y: 20 });
      gsap.set('.artist-hero-image', { scale: 1.1 });

      heroTl
        .to('.artist-hero-image', { scale: 1, duration: 2, ease: 'power2.out' })
        .to('.artist-name-line', { y: '0%', duration: 1.2, stagger: 0.1, ease: 'power4.out' }, '-=1.8')
        .to('.artist-hero-reveal', { opacity: 1, y: 0, duration: 0.8, stagger: 0.1, ease: 'power2.out' }, '-=1.0');

      // Scroll Triggers
      gsap.utils.toArray('section').forEach((section: any) => {
        gsap.from(section.querySelectorAll('.fade-up'), {
            opacity: 0, y: 30, duration: 0.8, stagger: 0.1, ease: 'power2.out',
            scrollTrigger: { trigger: section, start: 'top 85%' }
        });
      });
    };
    
    // Lightbox Logic
    const initLightbox = () => {
      const lightbox = document.getElementById('lightbox');
      const lbImage = document.getElementById('lightbox-image') as HTMLImageElement;
      const triggers = document.querySelectorAll('[data-lightbox-trigger]');
      const closeBtn = document.getElementById('lightbox-close');
      const prevBtn = document.getElementById('lightbox-prev');
      const nextBtn = document.getElementById('lightbox-next');

      if (!lightbox || !lbImage) return;

      let currentIndex = 0;
      const images: {src: string}[] = [];

      triggers.forEach((btn, idx) => {
          images.push({ src: btn.getAttribute('data-image-src') || '' });
          btn.addEventListener('click', () => {
              currentIndex = idx;
              openLightbox();
          });
      });

      function openLightbox() {
          if(!lightbox || !lbImage) return;
          updateImage();
          lightbox.classList.remove('hidden');
          // Force reflow
          void lightbox.offsetWidth; 
          lightbox.classList.remove('opacity-0');
          document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
          if(!lightbox) return;
          lightbox.classList.add('opacity-0');
          setTimeout(() => {
              lightbox.classList.add('hidden');
              document.body.style.overflow = '';
          }, 300);
      }

      function updateImage() {
          if(!lbImage) return;
          lbImage.src = images[currentIndex].src;
      }

      // Cleanup old listeners if needed (though DOM replacement handles most)
      const newCloseBtn = closeBtn?.cloneNode(true);
      if (closeBtn && newCloseBtn) {
         closeBtn.parentNode?.replaceChild(newCloseBtn, closeBtn);
         newCloseBtn.addEventListener('click', closeLightbox);
      }

      prevBtn?.addEventListener('click', () => {
          currentIndex = (currentIndex - 1 + images.length) % images.length;
          updateImage();
      });
      nextBtn?.addEventListener('click', () => {
          currentIndex = (currentIndex + 1) % images.length;
          updateImage();
      });
      
      // Close on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) {
          closeLightbox();
        }
      });
    };

    // Work Toggle Logic
    const initWorkToggle = () => {
      const portfolioBtn = document.getElementById('show-portfolio');
      const flashBtn = document.getElementById('show-flash');
      const portfolioGrid = document.getElementById('portfolio-grid');
      const flashGrid = document.getElementById('flash-grid');

      if (portfolioBtn && flashBtn && portfolioGrid && flashGrid) {
          portfolioBtn.addEventListener('click', () => {
              portfolioGrid.classList.remove('hidden');
              // Small delay to allow display:block to apply before opacity transition
              setTimeout(() => {
                  portfolioGrid.classList.remove('opacity-0');
              }, 10);
              
              flashGrid.classList.add('opacity-0');
              setTimeout(() => {
                  flashGrid.classList.add('hidden');
              }, 500);

              portfolioBtn.classList.add('text-foreground');
              portfolioBtn.classList.remove('text-muted-foreground/40');

              flashBtn.classList.add('text-muted-foreground/40');
              flashBtn.classList.remove('text-foreground');
          });

          flashBtn.addEventListener('click', () => {
              flashGrid.classList.remove('hidden');
              setTimeout(() => {
                  flashGrid.classList.remove('opacity-0');
              }, 10);

              portfolioGrid.classList.add('opacity-0');
              setTimeout(() => {
                  portfolioGrid.classList.add('hidden');
              }, 500);

              flashBtn.classList.add('text-foreground');
              flashBtn.classList.remove('text-muted-foreground/40');

              portfolioBtn.classList.add('text-muted-foreground/40');
              portfolioBtn.classList.remove('text-foreground');
          });
      }
    };

    document.addEventListener('astro:page-load', () => {
      initAnimations();
      initLightbox();
      initWorkToggle();
    });
  </script>
</SiteLayout>