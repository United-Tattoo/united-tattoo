---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

export async function getStaticPaths() {
  const artists = await getCollection('artists');
  return artists.map((artist) => ({
    params: { slug: artist.id },
    props: { artist },
  }));
}

const { artist } = Astro.props;
const { Content } = await render(artist);

// Read portfolio images from the public directory at build time
const publicDir = path.join(process.cwd(), 'public');
const portfolioPath = path.join(publicDir, artist.data.galleryDir, 'Portfolio');

let portfolioImages: string[] = [];
try {
  if (fs.existsSync(portfolioPath)) {
    const files = fs.readdirSync(portfolioPath);
    portfolioImages = files
      .filter((file) => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(file))
      .map((file) => `/${artist.data.galleryDir}/Portfolio/${file}`);
  }
} catch (e) {
  console.warn(`Could not read portfolio directory for ${artist.data.name}:`, e);
}

// Also check for flash sheets
const flashPath = path.join(publicDir, artist.data.galleryDir, 'Flash');
let flashImages: string[] = [];
try {
  if (fs.existsSync(flashPath)) {
    const files = fs.readdirSync(flashPath);
    flashImages = files
      .filter((file) => /\.(jpg|jpeg|png|webp|avif|gif)$/i.test(file))
      .map((file) => `/${artist.data.galleryDir}/Flash/${file}`);
  }
} catch (e) {
  // No flash directory
}
---

<SiteLayout
  title={artist.data.name}
  description={`View the portfolio and learn more about ${artist.data.name}, a resident artist at United Tattoo in Fountain, CO.`}
>
  <!-- Breadcrumb -->
  <section class="px-6 md:px-20 mb-8">
    <div class="max-w-7xl mx-auto">
      <nav class="flex items-center gap-2 text-sm text-neutral-500">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="text-neutral-700">/</span>
        <a href="/artists" class="hover:text-white transition-colors">Artists</a>
        <span class="text-neutral-700">/</span>
        <span class="text-neutral-300">{artist.data.name}</span>
      </nav>
    </div>
  </section>

  <!-- Artist Header -->
  <section class="px-6 md:px-20 mb-20">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Portrait -->
        <div class="relative aspect-[3/4] overflow-hidden">
          <img
            src={artist.data.portrait}
            alt={artist.data.name}
            class="absolute inset-0 w-full h-full object-cover"
          />
        </div>

        <!-- Info -->
        <div class="lg:col-span-2 flex flex-col justify-center">
          <span class="section-label block mb-4">Artist Profile</span>

          <h1 class="text-5xl md:text-7xl font-normal tracking-tighter text-white italic mb-6">
            {artist.data.name}
          </h1>

          {artist.data.specialties && (
            <div class="flex flex-wrap gap-2 mb-8">
              {artist.data.specialties.map((specialty: string) => (
                <span class="text-sm text-neutral-400 bg-white/5 border border-white/10 px-3 py-1.5">
                  {specialty}
                </span>
              ))}
            </div>
          )}

          <div class="prose-editorial max-w-none mb-10">
            <Content />
          </div>

          <div class="flex flex-wrap gap-4">
            <a
              href={`/booking?artist=${artist.id}`}
              class="px-8 py-4 bg-white text-black text-sm font-medium tracking-wide hover:bg-neutral-200 transition-all"
            >
              Book with {artist.data.name.split(' ')[0]}
            </a>

            {artist.data.instagram && (
              <a
                href={`https://instagram.com/${artist.data.instagram.replace('@', '')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="px-8 py-4 border border-white/10 text-white text-sm hover:bg-white/5 transition-all flex items-center gap-2"
              >
                <iconify-icon icon="mdi:instagram" class="text-base"></iconify-icon>
                {artist.data.instagram}
              </a>
            )}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio Gallery -->
  {portfolioImages.length > 0 && (
    <section class="px-6 md:px-20 mb-20">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-10 border-b border-white/5 pb-6">
          <div>
            <span class="section-label block mb-2">Portfolio</span>
            <h2 class="text-3xl font-normal tracking-tighter text-white italic">Recent Work</h2>
          </div>
          <span class="text-sm text-neutral-500">{portfolioImages.length} pieces</span>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
          {portfolioImages.map((image, index) => (
            <button
              type="button"
              class="group relative aspect-square overflow-hidden bg-neutral-950 cursor-pointer focus:outline-none focus:ring-2 focus:ring-white/20"
              data-lightbox-trigger
              data-image-src={image}
              data-image-alt={`${artist.data.name} portfolio work ${index + 1}`}
            >
              <img
                src={image}
                alt={`${artist.data.name} portfolio work ${index + 1}`}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors"></div>
            </button>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Flash Gallery -->
  {flashImages.length > 0 && (
    <section class="px-6 md:px-20 mb-20">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-10 border-b border-white/5 pb-6">
          <div>
            <span class="section-label block mb-2">Flash</span>
            <h2 class="text-3xl font-normal tracking-tighter text-white italic">Available Designs</h2>
          </div>
          <span class="text-sm text-neutral-500">{flashImages.length} designs</span>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-2">
          {flashImages.map((image, index) => (
            <button
              type="button"
              class="group relative aspect-square overflow-hidden bg-neutral-950 cursor-pointer focus:outline-none focus:ring-2 focus:ring-white/20"
              data-lightbox-trigger
              data-image-src={image}
              data-image-alt={`${artist.data.name} flash design ${index + 1}`}
            >
              <img
                src={image}
                alt={`${artist.data.name} flash design ${index + 1}`}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-black/0 group-hover:bg-black/10 transition-colors"></div>
            </button>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class="px-6 md:px-20 mt-20">
    <div class="max-w-7xl mx-auto">
      <div class="glass-card p-12 md:p-16 text-center">
        <span class="section-label block mb-6">Ready to Begin?</span>
        <h2 class="text-4xl md:text-5xl font-normal italic tracking-tighter text-white mb-6">
          Work with {artist.data.name.split(' ')[0]}
        </h2>
        <p class="text-neutral-400 text-base max-w-md mx-auto mb-10">
          Submit a booking request with your ideas and reference images.
        </p>
        <a
          href={`/booking?artist=${artist.id}`}
          class="inline-block px-10 py-5 bg-white text-black text-sm font-medium tracking-wide hover:bg-neutral-200 transition-all"
        >
          Book a Session
        </a>
      </div>
    </div>
  </section>

  <!-- Back to Artists -->
  <section class="px-6 md:px-20 mt-16 text-center">
    <a href="/artists" class="text-sm text-neutral-500 hover:text-white transition-colors">
      ← Back to All Artists
    </a>
  </section>

  <!-- Lightbox Modal -->
  <div
    id="lightbox"
    class="fixed inset-0 z-[100] bg-black/95 hidden items-center justify-center p-4 md:p-8"
    role="dialog"
    aria-modal="true"
    aria-label="Image viewer"
  >
    <button
      id="lightbox-close"
      class="absolute top-4 right-4 text-white/60 hover:text-white transition-colors p-2"
      aria-label="Close"
    >
      <iconify-icon icon="solar:close-circle-bold" class="text-3xl"></iconify-icon>
    </button>
    <button
      id="lightbox-prev"
      class="absolute left-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors p-2"
      aria-label="Previous image"
    >
      <iconify-icon icon="solar:arrow-left-bold" class="text-3xl"></iconify-icon>
    </button>
    <button
      id="lightbox-next"
      class="absolute right-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white transition-colors p-2"
      aria-label="Next image"
    >
      <iconify-icon icon="solar:arrow-right-bold" class="text-3xl"></iconify-icon>
    </button>
    <img
      id="lightbox-image"
      src=""
      alt=""
      class="max-h-[90vh] max-w-[90vw] object-contain"
    />
  </div>

  <script>
    // Lightbox functionality
    const lightbox = document.getElementById('lightbox');
    const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    const triggers = document.querySelectorAll('[data-lightbox-trigger]');

    let currentIndex = 0;
    const images: { src: string; alt: string }[] = [];

    triggers.forEach((trigger, index) => {
      const src = trigger.getAttribute('data-image-src') || '';
      const alt = trigger.getAttribute('data-image-alt') || '';
      images.push({ src, alt });

      trigger.addEventListener('click', () => {
        currentIndex = index;
        openLightbox();
      });
    });

    function openLightbox() {
      if (lightbox && lightboxImage && images[currentIndex]) {
        lightboxImage.src = images[currentIndex].src;
        lightboxImage.alt = images[currentIndex].alt;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      }
    }

    function closeLightbox() {
      if (lightbox) {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
        document.body.style.overflow = '';
      }
    }

    function showPrev() {
      currentIndex = (currentIndex - 1 + images.length) % images.length;
      if (lightboxImage && images[currentIndex]) {
        lightboxImage.src = images[currentIndex].src;
        lightboxImage.alt = images[currentIndex].alt;
      }
    }

    function showNext() {
      currentIndex = (currentIndex + 1) % images.length;
      if (lightboxImage && images[currentIndex]) {
        lightboxImage.src = images[currentIndex].src;
        lightboxImage.alt = images[currentIndex].alt;
      }
    }

    closeBtn?.addEventListener('click', closeLightbox);
    prevBtn?.addEventListener('click', showPrev);
    nextBtn?.addEventListener('click', showNext);

    lightbox?.addEventListener('click', (e) => {
      if (e.target === lightbox) closeLightbox();
    });

    document.addEventListener('keydown', (e) => {
      if (!lightbox?.classList.contains('flex')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') showPrev();
      if (e.key === 'ArrowRight') showNext();
    });
  </script>
</SiteLayout>
