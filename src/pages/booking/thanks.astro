---
import '../../styles/global.css';
import { SITE_TITLE } from '../../consts';

export const prerender = true;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Booking Request Submitted | {SITE_TITLE}</title>
		<meta name="description" content="Thank you for your booking request. We'll be in touch soon!" />
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<!-- Icons -->
		<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
	</head>
	<body class="bg-bg-deep text-text-main selection:bg-white/20 selection:text-white">
		<!-- Background Elements -->
		<div class="fixed inset-0 noise pointer-events-none z-50"></div>
		<div class="fixed inset-0 bg-grid pointer-events-none -z-10"></div>

		<!-- Technical Banner -->
		<div class="fixed top-0 left-0 w-full h-8 bg-[#0a0a0a] border-b border-white/5 z-[70] flex items-center justify-center overflow-hidden">
			<div class="flex items-center gap-4 animate-in fade-in slide-in-from-top-4 duration-700">
				<span class="relative flex h-1.5 w-1.5">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white/40 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span>
				</span>
				<p class="font-mono text-[9px] uppercase tracking-[0.2em] text-neutral-400">
					[System Status: <span class="text-white">Active</span>] &nbsp; | &nbsp; Now booking for <span class="text-white italic">February 2026</span>
				</p>
			</div>
		</div>

		<!-- Navigation -->
		<nav class="fixed top-8 left-0 w-full px-6 py-4 flex justify-between items-center z-[60] glass-card border-x-0 border-t-0 bg-black/40 backdrop-blur-md">
			<div class="flex items-center gap-4">
				<a href="/" class="font-display text-3xl font-normal tracking-tighter leading-none hover:opacity-70 transition-opacity italic">UNITED TATTOO</a>
				<div class="hidden lg:block w-[1px] h-4 bg-white/10 mx-2"></div>
				<span class="hidden lg:block font-mono text-[9px] text-neutral-500 tracking-[0.3em] uppercase">38.6942° N, 104.7008° W</span>
			</div>

			<div class="hidden md:flex gap-10 font-mono text-[10px] uppercase tracking-[0.25em] items-center text-neutral-400">
				<a href="/artists" class="hover:text-white transition-colors">[ Artists ]</a>
				<a href="/#process" class="hover:text-white transition-colors">[ Process ]</a>
				<a href="/booking" class="group relative px-6 py-2 bg-white text-black rounded-sm font-bold hover:bg-neutral-200 transition-all flex items-center gap-2">
					BOOK SESSION
					<iconify-icon icon="solar:arrow-right-up-linear" class="text-sm group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"></iconify-icon>
				</a>
			</div>

			<button class="md:hidden text-[10px] uppercase font-mono border border-white/20 px-4 py-1.5 rounded-sm bg-white/5">Menu</button>
		</nav>

		<main class="pt-32 pb-24 min-h-screen flex items-center justify-center">
			<section class="px-6 md:px-20 text-center max-w-2xl">
				<!-- Success Icon -->
				<div class="mb-8 flex justify-center">
					<div class="w-24 h-24 rounded-full border-2 border-white/20 flex items-center justify-center animate-in zoom-in duration-500">
						<iconify-icon icon="solar:check-circle-bold" class="text-5xl text-white"></iconify-icon>
					</div>
				</div>

				<div class="flex items-center justify-center gap-3 mb-6">
					<span class="font-mono text-[10px] text-white bg-white/10 px-2 py-0.5 rounded-sm uppercase tracking-widest">[ REQUEST_CONFIRMED ]</span>
				</div>

				<h1 class="text-5xl md:text-6xl font-normal tracking-tighter text-white italic mb-6 animate-in fade-in slide-in-from-bottom-4 duration-700">
					Request Received
				</h1>

				<p class="font-mono text-[11px] text-neutral-400 uppercase tracking-wider mb-4 animate-in fade-in duration-700 delay-200">
					Thank you for your booking request. We've received your submission and will review it shortly.
				</p>

				<p class="font-mono text-[11px] text-neutral-500 uppercase tracking-wider mb-12 animate-in fade-in duration-700 delay-300">
					Expect a response within 24-48 hours via your preferred contact method.
				</p>

				<!-- What's Next -->
				<div class="glass-card p-8 mb-10 text-left animate-in fade-in slide-in-from-bottom-4 duration-700 delay-400">
					<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-widest block mb-4">[ NEXT_STEPS ]</span>

					<div class="space-y-4">
						<div class="flex items-start gap-4">
							<span class="font-mono text-[9px] text-white bg-white/10 px-2 py-0.5 rounded-sm">01</span>
							<p class="font-mono text-[10px] text-neutral-300 uppercase tracking-wider">We'll review your request and reference images</p>
						</div>
						<div class="flex items-start gap-4">
							<span class="font-mono text-[9px] text-white bg-white/10 px-2 py-0.5 rounded-sm">02</span>
							<p class="font-mono text-[10px] text-neutral-300 uppercase tracking-wider">Your preferred artist will reach out to discuss the project</p>
						</div>
						<div class="flex items-start gap-4">
							<span class="font-mono text-[9px] text-white bg-white/10 px-2 py-0.5 rounded-sm">03</span>
							<p class="font-mono text-[10px] text-neutral-300 uppercase tracking-wider">Once approved, we'll schedule your appointment and collect a deposit</p>
						</div>
					</div>
				</div>

				<!-- Action Buttons -->
				<div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-in fade-in duration-700 delay-500">
					<a href="/" class="px-8 py-4 bg-white text-black font-mono font-bold uppercase text-[10px] tracking-[0.2em] hover:bg-neutral-200 transition-all flex items-center gap-3">
						RETURN HOME
						<iconify-icon icon="solar:home-2-bold" class="text-base"></iconify-icon>
					</a>
					<a href="/artists" class="px-8 py-4 border border-white/10 text-white font-mono uppercase text-[10px] tracking-[0.2em] hover:bg-white/5 transition-all flex items-center gap-3">
						VIEW ARTISTS
						<iconify-icon icon="solar:users-group-rounded-bold" class="text-base"></iconify-icon>
					</a>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="py-12 px-6 md:px-20 border-t border-white/5">
			<div class="flex flex-col md:flex-row justify-between items-center gap-8">
				<div class="flex items-center gap-4">
					<div class="w-2 h-2 rounded-full bg-white animate-pulse"></div>
					<span class="font-mono text-[9px] text-neutral-600 uppercase tracking-[0.3em]">System Verified © 2025 United Tattoo Collective.</span>
				</div>
				<div class="flex items-center gap-12">
					<a href="/privacy" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Privacy_Protocol</a>
					<a href="/terms" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Legal_Terms</a>
					<a href="/aftercare" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Aftercare</a>
				</div>
			</div>
		</footer>
	</body>
</html>

