---
import SiteLayout from '../../layouts/SiteLayout.astro';

export const prerender = true;
---

<SiteLayout
  title="Request Submitted"
  description="Thank you for your booking request. We'll be in touch soon!"
>
  <section class="min-h-[70vh] flex items-center justify-center px-6 md:px-20">
    <div class="text-center max-w-2xl">
      <!-- Success Icon -->
      <div class="mb-8 flex justify-center">
        <div class="w-20 h-20 rounded-full border border-white/20 flex items-center justify-center">
          <iconify-icon icon="solar:check-circle-bold" class="text-4xl text-white"></iconify-icon>
        </div>
      </div>

      <span class="section-label block mb-6">Request Confirmed</span>

      <h1 class="text-5xl md:text-6xl font-normal tracking-tighter text-white italic mb-6">
        Thank You
      </h1>

      <p class="text-neutral-400 text-base mb-4 leading-relaxed">
        We've received your booking request and will review it shortly.
      </p>

      <p class="text-neutral-500 text-sm mb-12">
        Expect a response within 24-48 hours via your preferred contact method.
      </p>

      <!-- What's Next -->
      <div class="glass-card p-8 mb-10 text-left">
        <h2 class="text-lg font-normal italic text-white mb-6">What Happens Next</h2>

        <div class="space-y-4">
          <div class="flex items-start gap-4">
            <span class="text-xs text-neutral-500 font-mono mt-0.5">01</span>
            <p class="text-sm text-neutral-400">We'll review your request and reference images</p>
          </div>
          <div class="flex items-start gap-4">
            <span class="text-xs text-neutral-500 font-mono mt-0.5">02</span>
            <p class="text-sm text-neutral-400">Your preferred artist will reach out to discuss the project</p>
          </div>
          <div class="flex items-start gap-4">
            <span class="text-xs text-neutral-500 font-mono mt-0.5">03</span>
            <p class="text-sm text-neutral-400">Once approved, we'll schedule your appointment and collect a deposit</p>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="px-8 py-4 bg-white text-black text-sm font-medium tracking-wide hover:bg-neutral-200 transition-all">
          Return Home
        </a>
        <a href="/artists" class="px-8 py-4 border border-white/10 text-white text-sm hover:bg-white/5 transition-all">
          View Artists
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
