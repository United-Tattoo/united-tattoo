---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import EditorialFooter from '../components/EditorialFooter.astro';
import SectionSidebar from '../components/SectionSidebar.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import GridBackground from '../components/GridBackground.astro';
import SectionHeader from '../components/SectionHeader.astro';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

const artists = await getCollection('artists');

// Collect portfolio images from all artists for the marquee & showcase
const publicDir = path.join(process.cwd(), 'public');
const allPortfolioImages: { src: string; artist: string }[] = [];

for (const artist of artists) {
  const portfolioPath = path.join(publicDir, artist.data.galleryDir, 'Portfolio');
  try {
    if (fs.existsSync(portfolioPath)) {
      const files = fs.readdirSync(portfolioPath)
        .filter((file) => /\.avif$/i.test(file))
        .slice(0, 5); // max 5 per artist
      for (const file of files) {
        allPortfolioImages.push({
          src: `/${artist.data.galleryDir}/Portfolio/${file}`,
          artist: artist.data.name,
        });
      }
    }
  } catch (_e) { /* skip */ }
}

// Shuffle deterministically and split into two rows for marquee
const shuffled = allPortfolioImages.sort((a, b) => a.src.localeCompare(b.src));
const marqueeRow1 = shuffled.filter((_, i) => i % 2 === 0).slice(0, 10);
const marqueeRow2 = shuffled.filter((_, i) => i % 2 === 1).slice(0, 10);

// Pick 6 varied images for the featured work mosaic
const showcaseImages = shuffled.slice(0, 6);
---

<SiteLayout title={SITE_DESCRIPTION} removeMainPadding={true} hideFooter={true}>

  <FloatingCTA href="/booking" label="Book a session" />

  <div class="relative main-content-wrapper">

  <!-- Hero Section: Balanced Composition -->
  <section class="hero-section min-h-screen relative flex flex-col" data-scroll-section>
    <!-- Grid Background -->
    <GridBackground opacity={40} class="hero-grid" />

    <!-- Dove - Positioned Right, Smaller -->
    <div class="absolute right-0 top-0 bottom-0 w-full lg:w-2/3 z-0 pointer-events-none overflow-hidden">
      <div class="absolute inset-0 mix-blend-screen opacity-70 hero-dove-layer">
        <img src="/dove.png" alt="" class="w-full h-full object-contain object-right grayscale contrast-125" />
      </div>
      <!-- Gradient fade to left - softer charcoal tones -->
      <div class="absolute inset-0 bg-gradient-to-r from-bg-deep via-bg-deep/70 to-transparent"></div>
    </div>

    <!-- Vignette overlay -->
    <div class="absolute inset-0 z-[1] pointer-events-none bg-gradient-to-t from-bg-deep via-transparent to-bg-deep/60"></div>

    <!-- Hero Content Grid -->
    <div class="relative z-10 flex-1 grid grid-cols-1 lg:grid-cols-12 pt-24 lg:pt-32">
      <!-- Left Content Column -->
      <div class="col-span-1 lg:col-span-7 flex flex-col justify-end px-6 md:px-12 lg:px-16 pb-16 md:pb-24 lg:pb-32">
        <!-- Label -->
        <div class="hero-reveal mb-6">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-neutral-300 font-medium">Custom · Flash · Freedom</span>
        </div>

        <!-- Title -->
        <h1 class="hero-title text-7xl md:text-8xl lg:text-9xl leading-[0.85] font-normal tracking-tight uppercase mb-8 md:mb-10">
          <span class="hero-title-line block overflow-hidden"><span class="inline-block text-white">United</span></span>
          <span class="hero-title-line block overflow-hidden"><span class="italic font-light text-neutral-500 inline-block">Tattoo</span></span>
        </h1>

        <!-- Tagline -->
        <p class="hero-reveal text-neutral-400 text-base md:text-lg lg:text-xl max-w-lg leading-relaxed font-light mb-10">
          A collective dedicated to the art of release. Where the timeless torch of tradition meets the modern expression of self.
        </p>

        <!-- Hero Info Bar -->
        <div class="hero-reveal flex flex-wrap items-center gap-8 pt-6 border-t" style="border-color: var(--color-burnt-orange);">
          <div>
            <span class="font-mono text-xs uppercase tracking-[0.2em] block mb-1" style="color: var(--color-moss);">Location</span>
            <span class="font-mono text-sm text-white">Fountain, CO</span>
          </div>
          <div>
            <span class="font-mono text-xs uppercase tracking-[0.2em] block mb-1" style="color: var(--color-moss);">Hours</span>
            <span class="font-mono text-sm text-white">Sun–Sat · 10am–8pm</span>
          </div>
          <div>
            <span class="font-mono text-xs uppercase tracking-[0.2em] block mb-1" style="color: var(--color-moss);">Artists</span>
            <span class="font-mono text-sm text-white">{artists.length} in residence</span>
          </div>
          <div class="hidden lg:block ml-auto">
             <a href="/booking" class="px-6 py-3 border border-white/20 hover:bg-white hover:text-black hover:border-white transition-all duration-300 font-mono text-xs uppercase tracking-widest">
               Book Consultation
             </a>
          </div>
        </div>

        <!-- Mobile CTA -->
        <div class="lg:hidden mt-10">
          <a href="/booking" class="group block w-full py-5 text-black text-center font-mono text-sm uppercase tracking-[0.15em] transition-all shadow-lg shadow-white/10" style="background-color: var(--color-burnt-orange);">
            <span class="flex items-center justify-center gap-3">
              <span class="group-hover:translate-x-1 transition-transform">Book a session</span>
              <span class="w-6 h-6 rounded-full flex items-center justify-center text-xs transition-colors" style="background-color: var(--color-burnt-dark); color: white;">→</span>
            </span>
          </a>
        </div>
      </div>

      <!-- Right Column - Empty space for dove -->
      <div class="hidden lg:block col-span-5"></div>
    </div>

    <!-- Scroll Indicator -->
    <ScrollIndicator class="hero-reveal" />
  </section>

  <!-- Work Marquee: Infinite Scroll Strip -->
  <section class="marquee-section relative z-20 overflow-hidden border-t border-white/10 py-8 md:py-12" data-scroll-section>
    <!-- Warm ambient glow behind marquee -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] rounded-full opacity-[0.07] pointer-events-none" style="background: radial-gradient(ellipse, var(--color-burnt-orange), transparent 70%);"></div>

    <!-- Row 1 - scrolls left -->
    <div class="marquee-track mb-4">
      <div class="marquee-scroll">
        {[...marqueeRow1, ...marqueeRow1].map((img) => (
          <div class="marquee-item">
            <img src={img.src} alt={`Tattoo by ${img.artist}`} loading="lazy" />
            <span class="marquee-credit">{img.artist}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Row 2 - scrolls right -->
    <div class="marquee-track marquee-reverse">
      <div class="marquee-scroll">
        {[...marqueeRow2, ...marqueeRow2].map((img) => (
          <div class="marquee-item">
            <img src={img.src} alt={`Tattoo by ${img.artist}`} loading="lazy" />
            <span class="marquee-credit">{img.artist}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Artists Section: The Index -->
  <section id="artists" class="artists-section relative z-20 border-t border-white/10" data-scroll-section>
    <SectionSidebar
      sectionNum="Section 01"
      label="The Team"
      description={`${artists.length} artists in residence, each with their own unique style and specialty.`}
    >
      <!-- Header Row -->
      <SectionHeader
        title="The team"
        meta={`${artists.length} artists`}
        titleClass="artists-title"
        class="artists-header"
      />

      <!-- Artists List -->
      <div class="artists-list">
        {artists.map((artist, index) => (
          <div class="artist-row group relative border-b border-white/10 hover:bg-white/[0.02] transition-colors duration-300">
            <a href={`/artists/${artist.id}`} class="block px-6 md:px-8 py-8 md:py-10 flex flex-col md:flex-row items-baseline md:items-center justify-between gap-4">
              <div class="flex items-center md:items-baseline gap-4 md:gap-8 md:w-1/2">
                <span class="font-mono text-sm text-neutral-700 group-hover:text-white transition-colors">
                  {(index + 1).toString().padStart(2, '0')}
                </span>
                
                <!-- Mobile Avatar -->
                <img 
                  src={artist.data.portrait} 
                  alt="" 
                  class="w-12 h-12 rounded-full object-cover lg:hidden border border-white/10" 
                />

                <h3 class="text-2xl md:text-3xl lg:text-4xl font-normal font-display italic text-white group-hover:translate-x-2 transition-transform duration-300">
                  {artist.data.name}
                </h3>
              </div>

              <div class="flex items-center justify-between w-full md:w-auto gap-6 md:gap-10">
                <div class="flex flex-col">
                  <span class="font-mono text-xs uppercase tracking-[0.2em] mb-1" style="color: var(--color-moss);">Specialty</span>
                  <span class="font-mono text-sm text-neutral-300">
                    {artist.data.specialties ? artist.data.specialties[0] : 'Custom'}
                  </span>
                </div>

                <span class="w-9 h-9 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-all duration-300" style="background-color: var(--color-terracotta);">
                  ↗
                </span>
              </div>
            </a>

            <!-- Hover Image Reveal (Desktop) -->
            <div class="hidden lg:block absolute top-1/2 right-24 -translate-y-1/2 w-[180px] aspect-[3/4] opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-10 bg-neutral-900 border border-white/5 rotate-2 group-hover:rotate-3 transition-transform shadow-2xl">
              <img
                src={artist.data.portrait}
                alt={artist.data.name}
                class="w-full h-full object-cover grayscale"
              />
            </div>
          </div>
        ))}
      </div>
    </SectionSidebar>
  </section>

  <!-- Featured Work: Visual Showcase -->
  <section class="showcase-section relative z-20 border-t border-white/10 py-16 md:py-24 px-6 md:px-12 lg:px-16" data-scroll-section>
    <!-- Ambient warm glow -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-[0.04] pointer-events-none" style="background: radial-gradient(ellipse, var(--color-terracotta), transparent 70%);"></div>

    <div class="max-w-7xl mx-auto">
      <div class="flex items-baseline justify-between mb-12">
        <div>
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-neutral-500 block mb-3">Recent Work</span>
          <h2 class="showcase-title font-display text-4xl md:text-5xl lg:text-6xl italic text-white">From the chair</h2>
        </div>
        <a href="/artists" class="hidden md:flex items-center gap-2 font-mono text-xs uppercase tracking-widest text-neutral-400 hover:text-white transition-colors group">
          View all artists
          <span class="w-6 h-6 rounded-full border border-white/20 flex items-center justify-center group-hover:bg-white group-hover:text-black transition-all text-[10px]">→</span>
        </a>
      </div>

      <!-- Bento Grid -->
      <div class="showcase-grid grid grid-cols-2 md:grid-cols-3 gap-2 md:gap-3">
        {showcaseImages.map((img, i) => (
          <div class:list={[
            "showcase-item group relative overflow-hidden",
            i === 0 ? "row-span-2" : "",
            i === 3 ? "md:col-span-2" : ""
          ]}>
            <img
              src={img.src}
              alt={`Tattoo by ${img.artist}`}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
            <span class="absolute bottom-3 left-3 font-mono text-[10px] uppercase tracking-widest text-white/90 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">{img.artist}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section: The Methodology -->
  <section id="process" class="process-section relative z-20 border-t border-white/10" data-scroll-section>
    <!-- Ambient warm glow behind methodology -->
    <div class="absolute bottom-0 left-1/4 w-[800px] h-[400px] rounded-full opacity-[0.03] pointer-events-none" style="background: radial-gradient(ellipse, var(--color-burnt-orange), transparent 60%);"></div>

    <SectionSidebar
      sectionNum="Section 02"
      label="Methodology"
      description="From first idea to healed artwork—our proven process."
    >
      <!-- Header -->
      <SectionHeader
        title="Methodology"
        meta="4 steps"
        titleClass="process-title"
        class="process-header"
      />

      <!-- Grid -->
      <div class="process-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-white/5 border-l border-white/5">
        {[
          { num: '01', title: 'Consultation', desc: 'Share your vision. We\'ll shape your idea together and match you with the right artist.', icon: 'solar:chat-line-linear' },
          { num: '02', title: 'Design', desc: 'Your artist creates a custom piece tailored to your body and style.', icon: 'solar:pen-new-square-linear' },
          { num: '03', title: 'Session', desc: 'Get inked in our clean, comfortable studio with experienced professionals.', icon: 'ph:needle' },
          { num: '04', title: 'Aftercare', desc: 'We guide you through healing so your artwork stays vibrant for life.', icon: 'solar:heart-linear' }
        ].map((step, i) => (
          <div class="process-step group px-6 py-10 lg:py-12 min-h-[280px] flex flex-col justify-between bg-bg-deep hover:bg-white/[0.02] transition-colors duration-300 border-b border-white/5 lg:border-b-0">
            <div class="flex justify-between items-start mb-6">
              <span class="process-num font-mono text-4xl lg:text-5xl font-light transition-colors" style="color: var(--color-burnt-orange);">
                {step.num}
              </span>
              <iconify-icon icon={step.icon} class="group-hover:text-white transition-colors text-xl lg:text-2xl" style="color: var(--color-sage);"></iconify-icon>
            </div>

            <div class="process-content">
              <h3 class="font-display text-xl lg:text-2xl italic text-white mb-3">{step.title}</h3>
              <p class="font-mono text-sm lg:text-base text-neutral-400 leading-relaxed">
                {step.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </SectionSidebar>
  </section>


  </div>

  <EditorialFooter />

  <!-- Micro-interactions & Hover Styles -->
  <style>
    /* === Marquee === */
    .marquee-track {
      overflow: hidden;
      mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }

    .marquee-scroll {
      display: flex;
      gap: 0.75rem;
      width: max-content;
      animation: marquee-left 40s linear infinite;
    }

    .marquee-reverse .marquee-scroll {
      animation: marquee-right 45s linear infinite;
    }

    .marquee-item {
      position: relative;
      width: 240px;
      height: 180px;
      flex-shrink: 0;
      overflow: hidden;
      border-radius: 2px;
    }

    @media (min-width: 768px) {
      .marquee-item {
        width: 320px;
        height: 220px;
      }
    }

    .marquee-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .marquee-item:hover img {
      transform: scale(1.08);
    }

    .marquee-credit {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 6px 10px;
      font-family: 'Geist Mono', monospace;
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: white;
      background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .marquee-item:hover .marquee-credit {
      opacity: 1;
    }

    @keyframes marquee-left {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    @keyframes marquee-right {
      0% { transform: translateX(-50%); }
      100% { transform: translateX(0); }
    }

    /* Pause marquee on hover */
    .marquee-track:hover .marquee-scroll {
      animation-play-state: paused;
    }

    /* === Showcase Grid === */
    .showcase-item {
      aspect-ratio: 1;
      border-radius: 2px;
    }

    .showcase-item.row-span-2 {
      aspect-ratio: auto;
    }

    .showcase-item img {
      border-radius: 2px;
    }

    /* Artist name underline on hover */
    .artist-row:hover h3 {
      background-image: linear-gradient(to right, var(--color-burnt-orange), var(--color-terracotta));
      background-size: 0 2px;
      background-position: 0 100%;
      background-repeat: no-repeat;
      animation: underlineSlide 0.3s ease-out forwards;
    }

    @keyframes underlineSlide {
      to {
        background-size: 100% 2px;
      }
    }

    /* Mobile CTA hover effect */
    .hero-section a[href="/booking"]:hover {
      background-color: var(--color-terracotta) !important;
      transform: translateY(-2px);
      box-shadow: 0 10px 40px rgba(230, 126, 80, 0.3);
    }

    /* Process step hover enhancements */
    .process-step {
      border-top: 2px solid transparent;
      transition: border-color 0.3s ease;
    }

    .process-step:hover {
      border-top-color: var(--color-terracotta);
    }

    .process-step:hover .process-num {
      transform: scale(1.1);
      color: var(--color-terracotta) !important;
    }
  </style>

  <!-- Scroll Animations -->
  <script>
    // Wait for GSAP to be available
    const initAnimations = () => {
      const gsap = window.gsap;
      const ScrollTrigger = window.ScrollTrigger;

      if (!gsap || !ScrollTrigger) {
        // Retry if global GSAP isn't ready yet (rare with astro:page-load but possible)
        setTimeout(initAnimations, 50);
        return;
      }

      // Set initial states for hero elements
      gsap.set('.hero-title-line > span', { y: '100%' });
      gsap.set('.hero-reveal', { opacity: 0, y: 30 });
      gsap.set('.hero-cta', { opacity: 0, y: 20 });

      // Parallax Mouse Effect for Hero Dove
      const heroSection = document.querySelector('.hero-section');
      const doveLayer = document.querySelector('.hero-dove-layer');
      
      if (heroSection && doveLayer) {
        heroSection.addEventListener('mousemove', (e) => {
          const xPos = (e.clientX / window.innerWidth - 0.5) * 20;
          const yPos = (e.clientY / window.innerHeight - 0.5) * 20;
          
          gsap.to(doveLayer, {
            x: xPos,
            y: yPos,
            duration: 1,
            ease: 'power2.out'
          });
        });
      }

      // Hero Title Animation on Load
      const heroTl = gsap.timeline({ delay: 0.3 });

      heroTl
        .to('.hero-title-line > span', {
          y: '0%',
          duration: 1.2,
          stagger: 0.15,
          ease: 'power4.out'
        })
        .to('.hero-reveal', {
          opacity: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.1,
          ease: 'power3.out'
        }, '-=0.8')
        .to('.hero-cta', {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: 'power2.out'
        }, '-=0.3');

      // Hero Parallax on Scroll
      gsap.to('.hero-grid', {
        yPercent: 30,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: 1
        }
      });

      gsap.to('.hero-title', {
        yPercent: 20,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: 1
        }
      });

      // Artists Section Animations
      gsap.set('.artist-row', { opacity: 0, y: 60 });
      gsap.set('.artists-title', { opacity: 0, y: 40 });

      gsap.to('.artists-title', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.artists-section',
          start: 'top 80%'
        }
      });

      gsap.to('.artist-row', {
        opacity: 1,
        y: 0,
        stagger: 0.1,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.artists-list',
          start: 'top 80%'
        }
      });

      // Showcase Section Animations
      gsap.set('.showcase-title', { opacity: 0, y: 30 });
      gsap.set('.showcase-item', { opacity: 0, y: 40, scale: 0.95 });

      gsap.to('.showcase-title', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.showcase-section',
          start: 'top 80%'
        }
      });

      gsap.to('.showcase-item', {
        opacity: 1,
        y: 0,
        scale: 1,
        stagger: 0.1,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.showcase-grid',
          start: 'top 85%'
        }
      });

      // Process Section Animations
      gsap.set('.process-step', { opacity: 0, y: 80, scale: 0.95 });
      gsap.set('.process-title', { opacity: 0, y: 40 });

      gsap.to('.process-title', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.process-section',
          start: 'top 80%'
        }
      });

      gsap.to('.process-step', {
        opacity: 1,
        y: 0,
        scale: 1,
        stagger: 0.15,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.process-grid',
          start: 'top 85%'
        }
      });

      // Process number parallax
      gsap.utils.toArray('.process-num').forEach((num) => {
        gsap.to(num, {
          yPercent: -30,
          ease: 'none',
          scrollTrigger: {
            trigger: num,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1
          }
        });
      });

      // Footer Animations
      gsap.set('.footer-title', { opacity: 0, scale: 0.8 });
      gsap.set('.footer-reveal', { opacity: 0, y: 40 });
      gsap.set('.footer-social', { opacity: 0, scale: 0.5 });

      const footerTl = gsap.timeline({
        scrollTrigger: {
          trigger: '.footer-section',
          start: 'top 80%'
        }
      });

      footerTl
        .to('.footer-title', {
          opacity: 1,
          scale: 1,
          duration: 1,
          ease: 'power4.out'
        })
        .to('.footer-reveal', {
          opacity: 1,
          y: 0,
          stagger: 0.1,
          duration: 0.8,
          ease: 'power3.out'
        }, '-=0.6')
        .to('.footer-social', {
          opacity: 1,
          scale: 1,
          stagger: 0.1,
          duration: 0.5,
          ease: 'back.out(2)'
        }, '-=0.4');

      console.log('Scroll animations initialized');
    };

    // Initialize when DOM is ready
    document.addEventListener('astro:page-load', initAnimations);

    // Hide floating CTA when footer is in view
    const initFloatingCTA = () => {
      const floatingCTA = document.getElementById('floating-cta');
      const footer = document.querySelector('.footer-section');

      if (!floatingCTA || !footer) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              floatingCTA.style.opacity = '0';
              floatingCTA.style.pointerEvents = 'none';
              floatingCTA.style.transform = 'translateY(20px)';
            } else {
              floatingCTA.style.opacity = '1';
              floatingCTA.style.pointerEvents = 'auto';
              floatingCTA.style.transform = 'translateY(0)';
            }
          });
        },
        { threshold: 0.1 }
      );

      observer.observe(footer);
    };

    document.addEventListener('astro:page-load', initFloatingCTA);
  </script>
</SiteLayout>
