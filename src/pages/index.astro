---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import SectionSidebar from '../components/SectionSidebar.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import GridBackground from '../components/GridBackground.astro';
import SectionHeader from '../components/SectionHeader.astro';

export const prerender = true;

const artists = await getCollection('artists');
---

<SiteLayout title={SITE_DESCRIPTION} removeMainPadding={true} hideNoise={true}>

  <FloatingCTA href="/booking" label="Book a session" />

  <div class="relative main-content-wrapper">

  <!-- Hero Section: Editorial Raw -->
  <section class="hero-section min-h-svh relative flex flex-col" data-scroll-section>

    <!-- Subtle grid texture -->
    <div class="absolute inset-0 hero-grid opacity-[0.03] pointer-events-none" data-speed="0.3">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 80px 80px;"></div>
    </div>

    <!-- Dove as atmospheric texture - bottom right, subtle -->
    <div class="absolute bottom-0 right-0 w-[60vw] h-[70vh] pointer-events-none overflow-hidden hero-dove-layer" data-speed="0.5">
      <img src="/dove.png" alt="" class="absolute bottom-0 right-0 w-full h-full object-contain object-right-bottom opacity-[0.07] grayscale" />
    </div>

    <!-- Main content wrapper -->
    <div class="relative z-10 flex-1 flex flex-col">

      <!-- Top bar - location pill -->
      <div class="hero-reveal px-6 md:px-10 lg:px-16 pt-32 lg:pt-40">
        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-white/10 bg-white/[0.02]">
          <span class="w-2 h-2 rounded-full bg-sage animate-pulse"></span>
          <span class="font-mono text-xs uppercase tracking-widest text-neutral-400">Fountain, Colorado</span>
        </div>
      </div>

      <!-- Title block - the main event -->
      <div class="flex-1 flex flex-col justify-center px-6 md:px-10 lg:px-16 py-12 lg:py-20">
        <h1 class="hero-title">
          <span class="hero-title-line block overflow-hidden">
            <span class="title-word" data-split-text>United</span>
          </span>
          <span class="hero-title-line block overflow-hidden">
            <span class="title-word title-word--italic" data-split-text>Tattoo</span>
          </span>
        </h1>

        <!-- Tagline - tucked under title -->
        <p class="hero-reveal hero-tagline mt-8 lg:mt-12 max-w-md text-neutral-500 text-base lg:text-lg leading-relaxed">
          A collective dedicated to the art of permanent expression.
        </p>
      </div>

      <!-- Bottom bar - info + CTA -->
      <div class="hero-reveal px-6 md:px-10 lg:px-16 pb-8 lg:pb-12">
        <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-8 lg:gap-16 pt-8 border-t border-white/10">

          <!-- Info clusters -->
          <div class="flex flex-wrap gap-x-12 gap-y-6">
            <div class="hero-info-block">
              <span class="hero-info-label">Open</span>
              <span class="hero-info-value">7 days · 10am–8pm</span>
            </div>
            <div class="hero-info-block">
              <span class="hero-info-label">Artists</span>
              <span class="hero-info-value">{artists.length} in residence</span>
            </div>
            <div class="hero-info-block">
              <span class="hero-info-label">Style</span>
              <span class="hero-info-value">Custom · Flash · Cover-ups</span>
            </div>
          </div>

          <!-- CTA -->
          <a href="/booking" class="hero-cta group inline-flex items-center gap-4">
            <span class="hero-cta-text">Book a consultation</span>
            <span class="hero-cta-arrow">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                <path d="M4 10h12M12 6l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        </div>
      </div>

    </div>

    <!-- Scroll hint -->
    <div class="hero-reveal absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-neutral-600">
      <span class="font-mono text-[10px] uppercase tracking-[0.3em]">Scroll</span>
      <div class="w-px h-8 bg-gradient-to-b from-neutral-600 to-transparent"></div>
    </div>
  </section>

  <!-- Artists Section: The Index -->
  <section id="artists" class="artists-section relative z-20 border-t border-white/10" data-scroll-section>
    <SectionSidebar
      sectionNum="Section 01"
      label="The Team"
      description={`${artists.length} artists in residence, each with their own unique style and specialty.`}
    >
      <!-- Header Row -->
      <SectionHeader
        title="The team"
        meta={`${artists.length} artists`}
        titleClass="artists-title"
        class="artists-header"
      />

      <!-- Artists List -->
      <div class="artists-list">
        {artists.map((artist, index) => (
          <div class="artist-row group relative border-b border-white/10 hover:bg-white/[0.02] transition-colors duration-300">
            <a href={`/artists/${artist.id}`} class="block px-6 md:px-8 py-8 md:py-10 flex flex-col md:flex-row items-baseline md:items-center justify-between gap-4">
              <div class="flex items-center md:items-baseline gap-4 md:gap-8 md:w-1/2">
                <span class="font-mono text-sm text-neutral-700 group-hover:text-white transition-colors">
                  {(index + 1).toString().padStart(2, '0')}
                </span>

                <!-- Mobile Avatar -->
                <img
                  src={artist.data.portrait}
                  alt=""
                  class="w-12 h-12 rounded-full object-cover lg:hidden border border-white/10"
                />

                <h3 class="text-2xl md:text-3xl lg:text-4xl font-normal font-display italic text-white group-hover:translate-x-2 transition-transform duration-300">
                  {artist.data.name}
                </h3>
              </div>

              <div class="flex items-center justify-between w-full md:w-auto gap-6 md:gap-10">
                <div class="flex flex-col">
                  <span class="font-mono text-xs uppercase tracking-[0.2em] mb-1" style="color: var(--color-sage);">Specialty</span>
                  <span class="font-mono text-sm text-neutral-300">
                    {artist.data.specialties ? artist.data.specialties[0] : 'Custom'}
                  </span>
                </div>

                <span class="w-9 h-9 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-all duration-300" style="background-color: var(--color-sage);">
                  ↗
                </span>
              </div>
            </a>

            <!-- Hover Image Reveal (Desktop) -->
            <div class="hidden lg:block absolute top-1/2 right-24 -translate-y-1/2 w-[180px] aspect-[3/4] opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-10 bg-neutral-900 border border-white/5 rotate-2 group-hover:rotate-3 transition-transform shadow-2xl">
              <img
                src={artist.data.portrait}
                alt={artist.data.name}
                class="w-full h-full object-cover grayscale"
              />
            </div>
          </div>
        ))}
      </div>
    </SectionSidebar>
  </section>

  <!-- Process Section: Editorial Timeline with Sticky Sidebar -->
  <section id="process" class="process-section relative z-20 border-t border-white/10" data-scroll-section>
    <SectionSidebar
      sectionNum="Section 02"
      label="The Process"
      description="Four steps from concept to healed artwork."
    >
      <!-- Section Header -->
      <div class="process-header-block px-6 md:px-8 py-16 lg:py-24 border-b border-white/10">
        <h2 class="process-title font-display text-5xl md:text-6xl lg:text-7xl italic text-white mb-6">
          From idea to ink
        </h2>
        <p class="font-mono text-sm text-neutral-400 max-w-lg leading-relaxed">
          Every piece begins with a conversation. Here's how we bring your vision to life.
        </p>
      </div>

      <!-- Timeline Steps -->
      <div class="process-timeline">
        {[
          { num: '01', title: 'Consultation', desc: 'Share your vision with us. We listen, ask questions, and help refine your concept. Then we match you with the artist whose style best fits your piece.' },
          { num: '02', title: 'Design', desc: 'Your artist brings your idea to life on paper first. Expect revisions, collaboration, and a final design you\'re excited to wear forever.' },
          { num: '03', title: 'Session', desc: 'The day arrives. Our studio is clean, comfortable, and calm. Your artist works with precision while you relax—or watch the magic happen.' },
          { num: '04', title: 'Aftercare', desc: 'Healing is part of the art. We send you home with clear instructions and check in to make sure your new piece stays vibrant for life.' }
        ].map((step, i) => (
          <div class="process-step group relative overflow-hidden border-b border-white/10 hover:bg-white/[0.015] transition-colors duration-500">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-0 px-6 md:px-8 py-16 md:py-20">
              <!-- Giant Number -->
              <div class="lg:col-span-4 flex items-start">
                <span class="process-giant-num font-display text-[8rem] md:text-[10rem] lg:text-[12rem] leading-none italic" style="color: var(--color-sage); opacity: 0.4;">
                  {step.num}
                </span>
              </div>

              <!-- Content -->
              <div class="lg:col-span-8 flex flex-col justify-center lg:pl-8">
                <h3 class="font-display text-3xl md:text-4xl lg:text-5xl italic text-white mb-4 group-hover:text-sage-light transition-colors duration-300">
                  {step.title}
                </h3>
                <p class="text-neutral-400 leading-relaxed text-base md:text-lg max-w-xl">
                  {step.desc}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </SectionSidebar>
  </section>


  </div>

  <!-- Micro-interactions & Hover Styles -->
  <style>
    /* Artist name underline on hover */
    .artist-row:hover h3 {
      background-image: linear-gradient(to right, var(--color-sage), var(--color-sage-light));
      background-size: 0 2px;
      background-position: 0 100%;
      background-repeat: no-repeat;
      animation: underlineSlide 0.3s ease-out forwards;
    }

    @keyframes underlineSlide {
      to {
        background-size: 100% 2px;
      }
    }

    /* ========================================
       HERO SECTION - Editorial Raw Design
       ======================================== */

    .hero-section {
      background: linear-gradient(180deg, var(--color-bg-deep) 0%, #0a0a0c 100%);
    }

    /* Hero Title - Bold editorial typography */
    .hero-title {
      font-family: 'Instrument Serif', serif;
      font-size: clamp(4rem, 18vw, 14rem);
      line-height: 0.85;
      letter-spacing: -0.04em;
      color: #fff;
    }

    .title-word {
      display: block;
      transform-origin: left center;
    }

    .title-word--italic {
      font-style: italic;
      color: var(--color-sage);
      margin-top: -0.05em;
    }

    /* Subtle hover effect on title */
    .hero-title:hover .title-word {
      transition: color 0.4s ease;
    }

    .hero-title:hover .title-word:not(.title-word--italic) {
      color: var(--color-stone);
    }

    .hero-title:hover .title-word--italic {
      color: var(--color-sage-light);
    }

    /* Info blocks */
    .hero-info-block {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .hero-info-label {
      font-family: 'Geist Mono', monospace;
      font-size: 0.625rem;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--color-sage);
    }

    .hero-info-value {
      font-family: 'Geist Mono', monospace;
      font-size: 0.8125rem;
      color: #fff;
    }

    /* CTA Button */
    .hero-cta {
      padding: 1rem 1.5rem;
      background: transparent;
      border: 1px solid var(--color-sage-dark);
      color: var(--color-stone);
      font-family: 'Geist Mono', monospace;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .hero-cta-arrow {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      border-radius: 50%;
      background: var(--color-sage-dark);
      color: #fff;
      transition: all 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .hero-cta:hover {
      background: var(--color-sage);
      border-color: var(--color-sage);
      color: var(--color-bg-deep);
      transform: translateY(-2px);
    }

    .hero-cta:hover .hero-cta-arrow {
      background: var(--color-bg-deep);
      color: var(--color-sage);
      transform: translateX(4px);
    }

    /* Sage color utility */
    .bg-sage {
      background-color: var(--color-sage);
    }

    /* ========================================
       PROCESS SECTION - Editorial Timeline
       ======================================== */

    .process-section {
      background: linear-gradient(180deg, #0a0a0c 0%, var(--color-bg-deep) 100%);
    }

    /* Giant outline numbers */
    .process-giant-num {
      font-style: italic;
      transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .process-step:hover .process-giant-num {
      -webkit-text-stroke: 1px rgba(156, 175, 148, 0.6);
      transform: scale(1.02);
    }

    /* Alternating layout backgrounds */
    .process-step:nth-child(odd) {
      background: transparent;
    }

    .process-step:nth-child(even) {
      background: rgba(255, 255, 255, 0.01);
    }

    /* Text color utilities */
    .text-sage {
      color: var(--color-sage);
    }

    .text-sage-light {
      color: var(--color-sage-light);
    }

    .group-hover\:text-sage-light:hover {
      color: var(--color-sage-light);
    }

    /* Border color utilities */
    .border-sage\/50 {
      border-color: rgba(156, 175, 148, 0.5);
    }

    /* Process CTA */
    .process-cta:hover {
      box-shadow: 0 0 40px rgba(156, 175, 148, 0.2);
    }

    /* Background utilities */
    .hover\:bg-sage:hover {
      background-color: var(--color-sage);
    }

    .hover\:border-sage:hover {
      border-color: var(--color-sage);
    }

    .hover\:text-bg-deep:hover {
      color: var(--color-bg-deep);
    }
  </style>

  <!-- Scroll Animations -->
  <script>
    // Wait for GSAP to be available
    const initAnimations = () => {
      const gsap = window.gsap;
      const ScrollTrigger = window.ScrollTrigger;

      if (!gsap || !ScrollTrigger) {
        // Retry if global GSAP isn't ready yet (rare with astro:page-load but possible)
        setTimeout(initAnimations, 50);
        return;
      }

      // Set initial states for hero elements
      gsap.set('.hero-title-line .title-word', { y: '110%', opacity: 0 });
      gsap.set('.hero-reveal', { opacity: 0, y: 20 });
      gsap.set('.hero-cta', { opacity: 0, y: 15 });

      // Hero Title Animation on Load - dramatic reveal
      const heroTl = gsap.timeline({ delay: 0.2 });

      heroTl
        .to('.hero-title-line .title-word', {
          y: '0%',
          opacity: 1,
          duration: 1.4,
          stagger: 0.12,
          ease: 'power4.out'
        })
        .to('.hero-reveal', {
          opacity: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.08,
          ease: 'power3.out'
        }, '-=0.9')
        .to('.hero-cta', {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: 'power3.out'
        }, '-=0.5');

      // Subtle parallax on scroll
      gsap.to('.hero-title', {
        yPercent: 15,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: 1.5
        }
      });

      gsap.to('.hero-dove-layer', {
        yPercent: -10,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: 1.5
        }
      });

      // Artists Section Animations - using gsap.from with immediateRender: false
      gsap.from('.artists-title', {
        opacity: 0,
        y: 40,
        duration: 0.8,
        ease: 'power3.out',
        immediateRender: false,
        scrollTrigger: {
          trigger: '.artists-section',
          start: 'top 80%'
        }
      });

      gsap.from('.artist-row', {
        opacity: 0,
        y: 40,
        stagger: 0.08,
        duration: 0.6,
        ease: 'power3.out',
        immediateRender: false,
        scrollTrigger: {
          trigger: '.artists-list',
          start: 'top 85%'
        }
      });

      // Process Section Animations - using gsap.from with immediateRender: false
      gsap.from('.process-title', {
        opacity: 0,
        y: 40,
        duration: 0.8,
        ease: 'power3.out',
        immediateRender: false,
        scrollTrigger: {
          trigger: '.process-section',
          start: 'top 80%'
        }
      });

      gsap.from('.process-step', {
        opacity: 0,
        y: 60,
        scale: 0.98,
        stagger: 0.1,
        duration: 0.8,
        ease: 'power3.out',
        immediateRender: false,
        scrollTrigger: {
          trigger: '.process-timeline',
          start: 'top 85%'
        }
      });

      // Footer Animations - using gsap.from with immediateRender: false
      gsap.from('.footer-title', {
        opacity: 0,
        scale: 0.8,
        duration: 1,
        ease: 'power4.out',
        immediateRender: false,
        scrollTrigger: {
          trigger: '.footer-section',
          start: 'top 80%'
        }
      });

      gsap.from('.footer-reveal', {
        opacity: 0,
        y: 40,
        stagger: 0.1,
        duration: 0.8,
        ease: 'power3.out',
        immediateRender: false,
        scrollTrigger: {
          trigger: '.footer-section',
          start: 'top 80%'
        }
      });

      gsap.from('.footer-social', {
        opacity: 0,
        scale: 0.5,
        stagger: 0.1,
        duration: 0.5,
        ease: 'back.out(2)',
        immediateRender: false,
        scrollTrigger: {
          trigger: '.footer-section',
          start: 'top 75%'
        }
      });

      console.log('Scroll animations initialized');
    };

    // Initialize when DOM is ready
    document.addEventListener('astro:page-load', initAnimations);

    // Hide floating CTA when footer is in view
    const initFloatingCTA = () => {
      const floatingCTA = document.getElementById('floating-cta');
      const footer = document.querySelector('.footer-section');

      if (!floatingCTA || !footer) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              floatingCTA.style.opacity = '0';
              floatingCTA.style.pointerEvents = 'none';
              floatingCTA.style.transform = 'translateY(20px)';
            } else {
              floatingCTA.style.opacity = '1';
              floatingCTA.style.pointerEvents = 'auto';
              floatingCTA.style.transform = 'translateY(0)';
            }
          });
        },
        { threshold: 0.1 }
      );

      observer.observe(footer);
    };

    document.addEventListener('astro:page-load', initFloatingCTA);
  </script>
</SiteLayout>
