---
import '../styles/global.css';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

export const prerender = true;

const artists = await getCollection('artists');
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{SITE_TITLE} | {SITE_DESCRIPTION}</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <!-- Icons -->
    <script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
	</head>
  <body class="bg-bg-deep text-text-main selection:bg-white/20 selection:text-white">
    <!-- Background Elements -->
    <div class="fixed inset-0 noise pointer-events-none z-50"></div>
    <div class="fixed inset-0 bg-grid pointer-events-none -z-10"></div>

    <!-- Technical Banner -->
    <div class="fixed top-0 left-0 w-full h-8 bg-[#0a0a0a] border-b border-white/5 z-[70] flex items-center justify-center overflow-hidden">
      <div class="flex items-center gap-4 animate-in fade-in slide-in-from-top-4 duration-700">
        <span class="relative flex h-1.5 w-1.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white/40 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span>
        </span>
        <p class="font-mono text-[9px] uppercase tracking-[0.2em] text-neutral-400">
          [System Status: <span class="text-white">Active</span>] &nbsp; | &nbsp; Now booking for <span class="text-white italic">February 2026</span>
        </p>
      </div>
    </div>

    <!-- Navigation -->
    <nav class="fixed top-8 left-0 w-full px-6 py-4 flex justify-between items-center z-[60] glass-card border-x-0 border-t-0 bg-black/40 backdrop-blur-md">
      <div class="flex items-center gap-4">
        <a href="/" class="font-display text-3xl font-normal tracking-tighter leading-none hover:opacity-70 transition-opacity italic">UNITED TATTOO</a>
        <div class="hidden lg:block w-[1px] h-4 bg-white/10 mx-2"></div>
        <span class="hidden lg:block font-mono text-[9px] text-neutral-500 tracking-[0.3em] uppercase">38.6942° N, 104.7008° W</span>
      </div>

      <div class="hidden md:flex gap-10 font-mono text-[10px] uppercase tracking-[0.25em] items-center text-neutral-400">
        <a href="#artists" class="hover:text-white transition-colors">[ Artists ]</a>
        <a href="#process" class="hover:text-white transition-colors">[ Process ]</a>
        <a href="/booking" class="group relative px-6 py-2 bg-white text-black rounded-sm font-bold hover:bg-neutral-200 transition-all flex items-center gap-2">
          BOOK SESSION
          <iconify-icon icon="solar:arrow-right-up-linear" class="text-sm group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform"></iconify-icon>
        </a>
      </div>

      <button class="md:hidden text-[10px] uppercase font-mono border border-white/20 px-4 py-1.5 rounded-sm bg-white/5">Menu</button>
    </nav>

    <main class="pt-24">
      <!-- Hero Section -->
      <section class="h-[90vh] relative flex flex-col justify-center items-center px-6 overflow-hidden">
        <!-- Giant Typography Background -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none z-0">
          <h2 class="text-[28vw] leading-none font-normal tracking-tighter text-white opacity-[0.03] mix-blend-overlay">
            UNITED
          </h2>
        </div>

        <!-- Horizontal Technical Line -->
        <div class="absolute top-[55%] left-0 w-full h-[1px] bg-white/10 z-10"></div>
        <div class="absolute top-[55%] left-[10%] w-24 h-[1px] bg-white/40 z-10 animate-pulse"></div>

        <!-- Hero Content -->
        <div class="relative z-20 text-center flex flex-col items-center">
          <div class="mb-4">
            <span class="font-mono text-[10px] uppercase tracking-[0.5em] text-neutral-500 block animate-in fade-in slide-in-from-bottom-2 duration-1000">
              SINCE MMXXIII
            </span>
          </div>

          <h1 class="text-[14vw] md:text-[11vw] leading-[0.75] font-normal tracking-tighter italic animate-in fade-in slide-in-from-bottom-10 duration-1000 mb-12">
            HIGH ART<br/><span class="text-stroke opacity-50">LOW LIFE</span>
          </h1>

          <div class="flex flex-col md:flex-row items-center justify-center gap-6 md:gap-16 animate-in fade-in duration-1000 delay-300">
            <div class="text-left space-y-2 border-l border-white/20 pl-6 max-w-[200px]">
              <span class="font-mono text-[9px] text-neutral-500 uppercase tracking-widest">[ SPECIFICATION ]</span>
              <p class="font-mono text-[10px] text-neutral-300 uppercase leading-relaxed tracking-wider">
                Precision needlework. Modern collective. Professional craftsmanship.
              </p>
            </div>

            <a href="/booking" class="group relative inline-flex items-center justify-center overflow-hidden border border-white/20 px-10 py-4 bg-white/5 backdrop-blur-sm hover:bg-white hover:text-black transition-all duration-500">
              <span class="text-[11px] font-mono tracking-[0.3em] uppercase">Initialize Project</span>
              <iconify-icon icon="solar:round-alt-arrow-right-bold" class="ml-3 text-lg transition-transform group-hover:translate-x-1"></iconify-icon>
            </a>
          </div>
        </div>

        <!-- Vertical Coordinates -->
        <div class="absolute right-8 top-1/2 -translate-y-1/2 hidden lg:flex flex-col gap-12 font-mono text-[9px] text-neutral-600 uppercase tracking-[0.4em] rotate-90 origin-right">
          <span>CO_COLORADO</span>
          <span>USA_80817</span>
        </div>

        <!-- Scroll Indicator -->
        <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-4 opacity-40">
          <div class="w-[1px] h-16 bg-gradient-to-b from-white to-transparent"></div>
          <span class="font-mono text-[9px] uppercase tracking-[0.3em] rotate-180 [writing-mode:vertical-lr]">Scroll Down</span>
        </div>
      </section>

      <!-- Artists Section -->
      <section id="artists" class="py-32 px-6 md:px-20 relative z-20">
        <div class="flex flex-col md:flex-row justify-between items-end mb-24 border-b border-white/5 pb-12">
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[10px] text-white bg-white/10 px-2 py-0.5 rounded-sm uppercase tracking-widest">[ ARCHIVE_01 ]</span>
              <div class="w-12 h-[1px] bg-white/20"></div>
            </div>
            <h2 class="text-7xl md:text-9xl font-normal tracking-tighter text-white italic">The Collective</h2>
          </div>
          <div class="hidden md:flex gap-8 font-mono text-[9px] text-neutral-500 uppercase tracking-[0.3em]">
            <span class="text-white">● ALL_RESIDENTS</span>
            <span class="hover:text-white cursor-pointer transition-all">TRADITIONAL_WORK</span>
            <span class="hover:text-white cursor-pointer transition-all">BLACK_MODERNISM</span>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          {artists.map((artist, index) => (
            <a href={`/artists/${artist.id}`} class="group relative aspect-[3/4] overflow-hidden bg-neutral-950 border border-white/10 hover:border-white/30 transition-all duration-500">
              <img
                src={artist.data.portrait}
                alt={artist.data.name}
                class="absolute inset-0 w-full h-full object-cover grayscale brightness-75 group-hover:grayscale-0 group-hover:brightness-100 group-hover:scale-[1.02] transition-all duration-1000 ease-out"
              />

              <!-- Glass Info Card -->
              <div class="absolute bottom-4 left-4 right-4 p-5 glass-card opacity-0 translate-y-4 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500 z-30">
                <div class="flex justify-between items-start mb-4">
                  <div>
                    <span class="font-mono text-[8px] text-neutral-500 uppercase tracking-widest block mb-1">[ ID: 00{index + 1} ]</span>
                    <h3 class="text-2xl font-normal text-white italic leading-none">{artist.data.name}</h3>
                  </div>
                  <div class="w-2 h-2 rounded-full bg-white/80 animate-pulse"></div>
                </div>

                {artist.data.specialties && (
                  <div class="flex flex-wrap gap-1 mb-4">
                    {artist.data.specialties.slice(0, 2).map((specialty: string) => (
                      <span class="font-mono text-[7px] text-neutral-400 uppercase tracking-wider bg-white/5 px-2 py-0.5 rounded-sm">{specialty}</span>
                    ))}
                  </div>
                )}

                <div class="flex items-center justify-between border-t border-white/10 pt-4">
                  <span class="font-mono text-[8px] text-neutral-400 uppercase tracking-widest">Resident Artist</span>
                  <div class="flex items-center gap-2">
                    <span class="font-mono text-[8px] text-white uppercase tracking-widest">Portfolio</span>
                    <iconify-icon icon="solar:arrow-right-up-linear" class="text-xs text-white"></iconify-icon>
                  </div>
                </div>
              </div>

              <!-- Initial State Overlay -->
              <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent opacity-60 group-hover:opacity-0 transition-opacity duration-700"></div>
              <div class="absolute bottom-6 left-6 group-hover:opacity-0 transition-opacity">
                <h3 class="text-2xl font-normal text-white italic tracking-tight">{artist.data.name}</h3>
              </div>
            </a>
          ))}
        </div>

        <!-- View All Artists Link -->
        <div class="mt-12 text-center">
          <a href="/artists" class="inline-flex items-center gap-2 font-mono text-[10px] text-neutral-500 uppercase tracking-widest hover:text-white transition-colors">
            View All Artists
            <iconify-icon icon="solar:arrow-right-linear" class="text-sm"></iconify-icon>
          </a>
        </div>
      </section>

      <!-- Process Section -->
      <section id="process" class="py-32 px-6 md:px-20 relative z-20 border-t border-white/5">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
          <div class="lg:col-span-4 space-y-8">
            <div class="sticky top-40">
              <div class="flex items-center gap-4 mb-8">
                <span class="font-mono text-[10px] text-white/40 uppercase tracking-[0.5em]">[ WORKFLOW_PROTOCOL ]</span>
              </div>
              <h2 class="text-7xl md:text-8xl font-normal italic tracking-tighter text-white leading-[0.85] mb-8">The<br/>Method</h2>

              <div class="p-6 glass-card space-y-4 max-w-sm">
                <p class="font-mono text-[10px] text-neutral-400 uppercase leading-relaxed tracking-wider">
                  Our studio operates on a precision-based model. Each session follows a rigorous quality protocol to ensure artistic excellence and clinical safety.
                </p>
                <div class="flex items-center gap-3 font-mono text-[9px] text-white/60">
                  <span class="animate-pulse">●</span>
                  <span>ISO_9001_COMPLIANT_STANDARDS</span>
                </div>
              </div>
            </div>
          </div>

          <div class="lg:col-span-8 relative">
            <!-- Vertical Protocol Line -->
            <div class="absolute left-0 top-0 w-[1px] h-full bg-gradient-to-b from-white/20 via-white/5 to-transparent hidden md:block"></div>

            <div class="flex flex-col">
              {[
                { id: 'PROC_01', title: 'Consultation', desc: 'Symmetry analysis and conceptual mapping. We translate abstract intent into technical design specifications.', tag: '[ ANALYSIS ]' },
                { id: 'PROC_02', title: 'Scheduling', desc: 'Slot allocation and security deposit. Formalizing the commitment to the artistic timeline.', tag: '[ LOGISTICS ]' },
                { id: 'PROC_03', title: 'Execution', desc: 'High-precision application in a sterile environment. Utilizing modern rotary technology and premium pigments.', tag: '[ SYNTHESIS ]' },
                { id: 'PROC_04', title: 'Recovery', desc: 'Biological healing protocol. We provide technical specifications for long-term pigment retention.', tag: '[ POST_CARE ]' }
              ].map((step, index) => (
                <div class="group relative pl-0 md:pl-16 py-16 border-b border-white/5 first:pt-0 last:border-b-0">
                  <!-- Timeline Node -->
                  <div class="absolute left-[-4px] top-[72px] w-2 h-2 rounded-full bg-white opacity-0 group-hover:opacity-100 transition-all duration-500 hidden md:block"></div>

                  <div class="flex flex-col md:flex-row md:items-baseline gap-4 md:gap-12 mb-6">
                    <span class="font-mono text-xs text-neutral-600 group-hover:text-white transition-colors duration-500">{step.id}</span>
                    <h3 class="text-5xl md:text-6xl font-normal italic text-neutral-400 group-hover:text-white transition-colors duration-700">{step.title}</h3>
                    <span class="font-mono text-[9px] text-neutral-700 uppercase tracking-widest">{step.tag}</span>
                  </div>

                  <p class="font-body text-neutral-500 text-sm md:text-base max-w-xl leading-relaxed group-hover:text-neutral-300 transition-colors duration-500">
                    {step.desc}
                  </p>

                  <div class="mt-8 flex gap-4 opacity-0 group-hover:opacity-100 transition-all duration-700 translate-y-2 group-hover:translate-y-0">
                    <div class="w-8 h-[1px] bg-white/20 my-auto"></div>
                    <span class="font-mono text-[8px] text-neutral-500 uppercase tracking-widest">Protocol Verified</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Footer -->
      <footer class="pt-32 pb-12 px-6 md:px-20 relative z-20 border-t border-white/5 bg-black overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none opacity-[0.015]">
          <span class="font-display text-[35vw] font-normal italic tracking-tighter whitespace-nowrap">UNITED</span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-20 relative z-10">
          <div class="lg:col-span-2 space-y-12">
            <div class="space-y-4">
              <span class="font-mono text-[9px] text-neutral-500 uppercase tracking-[0.4em]">[ CALL_TO_ACTION ]</span>
              <h2 class="text-6xl md:text-7xl font-normal italic tracking-tighter text-white leading-none uppercase">Begin Your<br/>Specimen</h2>
            </div>
            <div class="flex flex-wrap gap-6">
              <a href="/booking" class="px-10 py-5 bg-white text-black font-mono font-bold uppercase text-[10px] tracking-[0.2em] hover:bg-neutral-200 transition-all flex items-center gap-3">
                SECURE_DATE
                <iconify-icon icon="solar:calendar-bold" class="text-base"></iconify-icon>
              </a>
              <a href="mailto:ink@unitedtattoo.com" class="px-10 py-5 border border-white/10 font-mono text-white uppercase text-[10px] tracking-[0.2em] hover:bg-white/5 transition-all flex items-center gap-3">
                SEND_ENQUIRY
                <iconify-icon icon="solar:letter-bold" class="text-base"></iconify-icon>
              </a>
            </div>
          </div>

          <div class="space-y-8">
            <div class="space-y-4">
              <span class="font-mono text-[9px] text-neutral-500 uppercase tracking-[0.4em]">[ COORDINATES ]</span>
              <p class="font-mono text-[11px] text-neutral-300 leading-relaxed uppercase tracking-wider">
                712 S Santa Fe Ave<br/>
                Fountain, CO 80817<br/>
                38.6942° N, 104.7008° W
              </p>
            </div>
            <div class="space-y-4">
              <span class="font-mono text-[9px] text-neutral-500 uppercase tracking-[0.4em]">[ SCHEDULE ]</span>
              <p class="font-mono text-[11px] text-neutral-300 leading-relaxed uppercase tracking-wider">
                TUE—SAT: 12:00—20:00<br/>
                SUN—MON: CLOSED_
              </p>
            </div>
          </div>

          <div class="space-y-8">
            <div class="space-y-4">
              <span class="font-mono text-[9px] text-neutral-500 uppercase tracking-[0.4em]">[ NETWORK ]</span>
              <div class="flex flex-col gap-3">
                <a href="#" class="font-mono text-[11px] text-neutral-400 hover:text-white transition-colors uppercase tracking-widest flex items-center gap-2">
                  <span class="text-[8px]">→</span> INSTAGRAM
                </a>
                <a href="#" class="font-mono text-[11px] text-neutral-400 hover:text-white transition-colors uppercase tracking-widest flex items-center gap-2">
                  <span class="text-[8px]">→</span> FACEBOOK
                </a>
                <a href="#" class="font-mono text-[11px] text-neutral-400 hover:text-white transition-colors uppercase tracking-widest flex items-center gap-2">
                  <span class="text-[8px]">→</span> TIKTOK
                </a>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-40 pt-10 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-8 relative z-10">
          <div class="flex items-center gap-4">
            <div class="w-2 h-2 rounded-full bg-white animate-pulse"></div>
            <span class="font-mono text-[9px] text-neutral-600 uppercase tracking-[0.3em]">System Verified © 2025 United Tattoo Collective.</span>
          </div>
          <div class="flex items-center gap-12">
            <a href="/privacy" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Privacy_Protocol</a>
            <a href="/terms" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Legal_Terms</a>
            <a href="/aftercare" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Aftercare</a>
          </div>
        </div>
      </footer>
    </main>
	</body>
</html>
