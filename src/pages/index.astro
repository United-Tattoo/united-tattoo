---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

export const prerender = true;

const artists = await getCollection('artists');
---

<SiteLayout title={SITE_DESCRIPTION} removeMainPadding={true} hideFooter={true}>
  <!-- Pinned Columns Container - positioned relative for sticky fallback -->
  <div class="pinned-layout">
    <!-- Left Pinned Column -->
    <div class="pinned-left hidden lg:block fixed left-0 top-0 w-[16.666%] pt-20 z-30 pointer-events-none" style="height: calc(100vh - 80px);">
      <div class="h-full border-r border-white/10 bg-[#050505] p-6 flex flex-col justify-between pointer-events-auto">
        <div class="hero-reveal">
          <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500">
            Chapter 01
          </span>
          <p class="font-mono text-xs text-white mt-2">United Tattoo</p>
        </div>
        <div class="hero-reveal">
          <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500 block mb-2">
            Coordinates
          </span>
          <p class="font-mono text-xs text-neutral-400">[X] 38.68° N</p>
          <p class="font-mono text-xs text-neutral-400">[Y] 104.70° W</p>
        </div>
      </div>
    </div>

    <!-- Right Pinned Column -->
    <div class="pinned-right hidden lg:block fixed right-0 top-0 w-[25%] pt-20 z-30 pointer-events-none" style="height: calc(100vh - 80px);">
      <div class="h-full border-l border-white/10 bg-[#050505] flex flex-col pointer-events-auto">
        <div class="hero-reveal flex-1 p-6 border-b border-white/10">
          <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500 block mb-4">
            Active Ingredients
          </span>
          <ul class="space-y-2">
            <li class="ingredient-item flex items-center justify-between group">
              <span class="text-sm text-white font-mono">Ink</span>
              <span class="text-xs text-neutral-600 group-hover:text-white transition-colors">100%</span>
            </li>
            <li class="ingredient-item flex items-center justify-between group">
              <span class="text-sm text-white font-mono">Skin</span>
              <span class="text-xs text-neutral-600 group-hover:text-white transition-colors">Canvas</span>
            </li>
            <li class="ingredient-item flex items-center justify-between group">
              <span class="text-sm text-white font-mono">Soul</span>
              <span class="text-xs text-neutral-600 group-hover:text-white transition-colors">Infinite</span>
            </li>
          </ul>
        </div>
        <div class="hero-reveal p-6">
          <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500 block mb-4">
            Status
          </span>
          <div class="flex items-center gap-2">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
            </span>
            <span class="text-sm text-white font-mono uppercase">Booking Open</span>
          </div>
          <a href="/booking" class="hero-cta block mt-6 w-full py-3 bg-white text-black text-center font-mono text-xs uppercase tracking-wider hover:bg-neutral-200 transition-colors">
            Init Request
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Hero Section: The Manual Cover -->
  <section class="hero-section min-h-screen relative flex flex-col pt-20 border-b border-white/10" data-scroll-section>
    <!-- Grid Background -->
    <div class="hero-grid absolute inset-0 grid grid-cols-6 md:grid-cols-12 pointer-events-none select-none z-0">
      {Array.from({ length: 12 }).map((_, i) => (
        <div class={`h-full border-r border-white/5 ${i === 0 ? 'border-l' : ''} ${i >= 6 ? 'hidden md:block' : ''}`}></div>
      ))}
    </div>

    <div class="hero-content relative z-10 flex-1 grid grid-cols-1 lg:grid-cols-12">
      <!-- Left Spacer (for pinned column) -->
      <div class="hidden lg:block col-span-2"></div>

      <!-- Center: Main Title -->
      <div class="hero-main col-span-1 lg:col-span-7 p-6 lg:p-12 border-b lg:border-b-0 lg:border-r border-white/10 flex flex-col justify-center min-h-[50vh] lg:min-h-[80vh]">
        <div class="mb-4 hero-reveal">
           <span class="section-label">Creativity / Technicality</span>
        </div>
        <h1 class="hero-title text-7xl md:text-8xl lg:text-[9rem] leading-[0.85] font-normal tracking-tighter uppercase mb-8">
          <span class="hero-title-line block overflow-hidden"><span class="inline-block">High Art</span></span>
          <span class="hero-title-line block overflow-hidden"><span class="italic font-light text-neutral-500 inline-block">True Craft</span></span>
        </h1>
        <p class="hero-reveal text-neutral-400 text-lg md:text-xl max-w-xl leading-relaxed font-light">
          A collective of professional tattoo artists dedicated to creating exceptional custom work. We blend artistic vision with technical precision.
        </p>
      </div>

      <!-- Right Spacer (for pinned column) -->
      <div class="hidden lg:block col-span-3"></div>

      <!-- Mobile Only: Left & Right content -->
      <div class="lg:hidden col-span-1 p-6 border-b border-white/10">
        <div class="grid grid-cols-2 gap-6">
          <div>
            <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500">Chapter 01</span>
            <p class="font-mono text-xs text-white mt-2">United Tattoo</p>
          </div>
          <div>
            <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500 block mb-2">Status</span>
            <div class="flex items-center gap-2">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
              </span>
              <span class="text-xs text-white font-mono uppercase">Open</span>
            </div>
          </div>
        </div>
        <a href="/booking" class="block mt-6 w-full py-3 bg-white text-black text-center font-mono text-xs uppercase tracking-wider hover:bg-neutral-200 transition-colors">
          Init Request
        </a>
      </div>
    </div>
  </section>

  <!-- Artists Section: The Index -->
  <section id="artists" class="artists-section relative z-20" data-scroll-section>
    <!-- Header Row -->
    <div class="artists-header grid grid-cols-1 lg:grid-cols-12 border-b border-white/10">
      <div class="hidden lg:block col-span-2"></div>
      <div class="col-span-1 lg:col-span-7 p-6 border-r border-white/10">
        <h2 class="artists-title text-4xl md:text-5xl font-normal uppercase tracking-tight">The Collective</h2>
      </div>
      <div class="hidden lg:block col-span-3"></div>
    </div>

    <!-- Artists List -->
    <div class="grid grid-cols-1 lg:grid-cols-12">
      <div class="hidden lg:block col-span-2"></div>
      <div class="artists-list col-span-1 lg:col-span-7 border-r border-white/10">
        {artists.map((artist, index) => (
          <div class="artist-row group relative border-b border-white/10 hover:bg-white/5 transition-colors duration-300">
            <a href={`/artists/${artist.id}`} class="block p-6 md:p-8 flex flex-col md:flex-row items-baseline md:items-center justify-between gap-4">
              <div class="flex items-baseline gap-4 md:gap-8 md:w-1/2">
                <span class="font-mono text-xs text-neutral-600 group-hover:text-white transition-colors">
                  {(index + 1).toString().padStart(2, '0')}
                </span>
                <h3 class="text-3xl md:text-4xl font-normal font-display italic text-white group-hover:translate-x-2 transition-transform duration-300">
                  {artist.data.name}
                </h3>
              </div>

              <div class="flex items-center justify-between w-full md:w-1/2 gap-4">
                <div class="flex flex-col">
                  <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500 mb-1">Specialty</span>
                  <span class="font-mono text-sm text-neutral-300">
                    {artist.data.specialties ? artist.data.specialties[0] : 'Custom Tattoo'}
                  </span>
                </div>

                <span class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-all duration-300">
                  ↗
                </span>
              </div>
            </a>

            <!-- Hover Image Reveal (Desktop) - now positioned within center column -->
            <div class="hidden lg:block absolute top-1/2 right-8 -translate-y-1/2 w-[180px] aspect-[3/4] opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-10 bg-neutral-900 border border-white/10 rotate-3 group-hover:rotate-6 transition-transform">
              <img
                src={artist.data.portrait}
                alt={artist.data.name}
                class="w-full h-full object-cover grayscale"
              />
            </div>
          </div>
        ))}
      </div>
      <div class="hidden lg:block col-span-3"></div>
    </div>
  </section>

  <!-- Process Section: The Methodology -->
  <section id="process" class="process-section relative z-20 border-b border-white/10" data-scroll-section>
    <!-- Header -->
    <div class="process-header grid grid-cols-1 lg:grid-cols-12 border-b border-white/10">
      <div class="hidden lg:block col-span-2"></div>
      <div class="col-span-1 lg:col-span-7 p-6 border-r border-white/10 flex flex-col md:flex-row justify-between items-end gap-6">
        <h2 class="process-title text-4xl md:text-5xl font-normal uppercase tracking-tight">Methodology</h2>
        <p class="process-subtitle font-mono text-xs text-neutral-500 uppercase tracking-wide max-w-xs text-right">
          Standard Operating Procedures for custom engagement
        </p>
      </div>
      <div class="hidden lg:block col-span-3"></div>
    </div>

    <!-- Grid - Centered within the 7-column space -->
    <div class="grid grid-cols-1 lg:grid-cols-12">
      <div class="hidden lg:block col-span-2"></div>
      <div class="process-grid col-span-1 lg:col-span-7 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 border-r border-white/10">
      {[
        { num: '01', title: 'Consultation', desc: 'Concept alignment and placement analysis.' },
        { num: '02', title: 'Design', desc: 'Custom drafting and iterative refinement.' },
        { num: '03', title: 'Session', desc: 'Sterile environment execution and application.' },
        { num: '04', title: 'Aftercare', desc: 'Healing protocols and preservation guidance.' }
      ].map((step, i) => (
        <div class={`process-step group p-8 border-b md:border-b-0 border-white/10 min-h-[300px] flex flex-col justify-between hover:bg-white/5 transition-colors duration-300 ${i < 3 ? 'lg:border-r md:border-r' : ''} ${i === 1 ? 'md:border-r-0 lg:border-r' : ''}`}>
          <div class="flex justify-between items-start">
            <span class="process-num font-mono text-4xl text-neutral-700 font-light group-hover:text-white transition-colors">
              {step.num}
            </span>
            <iconify-icon icon="solar:arrow-right-up-linear" class="text-neutral-600 group-hover:text-white transition-colors"></iconify-icon>
          </div>

          <div class="process-content">
            <h3 class="font-display text-2xl italic text-white mb-3">{step.title}</h3>
            <p class="font-mono text-xs text-neutral-400 leading-relaxed">
              {step.desc}
            </p>
          </div>
        </div>
      ))}
      </div>
      <div class="hidden lg:block col-span-3"></div>
    </div>
  </section>

  <!-- Footer: Data Sheet -->
  <footer class="footer-section bg-black relative z-20" data-scroll-section>
    <div class="grid grid-cols-1 lg:grid-cols-12">
      <!-- Left Column: Branding -->
      <div class="footer-branding col-span-1 lg:col-span-4 p-8 lg:p-12 border-b lg:border-b-0 lg:border-r border-white/10 flex flex-col justify-between min-h-[300px]">
        <div class="footer-reveal">
          <h2 class="footer-title text-6xl md:text-8xl font-display uppercase tracking-tighter leading-none mb-2">United</h2>
          <span class="font-mono text-xs text-neutral-500 block">
            © 2025 United Tattoo Collective
          </span>
        </div>

        <div class="footer-reveal mt-8">
          <p class="font-mono text-xs text-neutral-400 max-w-xs mb-6">
            Pushing boundaries in skin art. Based in Fountain, Colorado.
          </p>
          <div class="flex gap-4">
            <a href="#" class="footer-social w-10 h-10 border border-white/20 rounded-full flex items-center justify-center hover:bg-white hover:text-black transition-all">
              <iconify-icon icon="mdi:instagram"></iconify-icon>
            </a>
            <a href="mailto:ink@unitedtattoo.com" class="footer-social w-10 h-10 border border-white/20 rounded-full flex items-center justify-center hover:bg-white hover:text-black transition-all">
              <iconify-icon icon="mdi:email"></iconify-icon>
            </a>
          </div>
        </div>
      </div>

      <!-- Right Column: Links Grid -->
      <div class="col-span-1 lg:col-span-8 grid grid-cols-1 md:grid-cols-3">
        <!-- Location -->
        <div class="footer-col footer-reveal p-8 border-b md:border-b-0 md:border-r border-white/10">
          <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500 block mb-6">
            [01] Location
          </span>
          <address class="not-italic font-mono text-sm text-neutral-300 space-y-1">
            <p>712 S Santa Fe Ave</p>
            <p>Fountain, CO 80817</p>
            <p class="text-neutral-500 mt-4">38.6826° N, 104.7005° W</p>
          </address>
        </div>

        <!-- Hours -->
        <div class="footer-col footer-reveal p-8 border-b md:border-b-0 md:border-r border-white/10">
          <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500 block mb-6">
            [02] Hours
          </span>
          <ul class="font-mono text-sm text-neutral-300 space-y-2">
            <li class="flex justify-between">
              <span>Tue - Sat</span>
              <span>12pm - 8pm</span>
            </li>
            <li class="flex justify-between text-neutral-500">
              <span>Sun - Mon</span>
              <span>Closed</span>
            </li>
          </ul>
        </div>

        <!-- Sitemap -->
        <div class="footer-col footer-reveal p-8">
          <span class="font-mono text-[10px] uppercase tracking-widest text-neutral-500 block mb-6">
            [03] Directory
          </span>
          <ul class="font-mono text-sm space-y-2">
            <li><a href="/artists" class="text-neutral-300 hover:text-white transition-colors">Artists</a></li>
            <li><a href="/booking" class="text-neutral-300 hover:text-white transition-colors">Booking</a></li>
            <li><a href="/faq" class="text-neutral-300 hover:text-white transition-colors">FAQ</a></li>
            <li><a href="/privacy" class="text-neutral-500 hover:text-white transition-colors">Privacy</a></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bar border-t border-white/10 p-4 flex justify-between items-center bg-neutral-900/50">
      <span class="font-mono text-[10px] text-neutral-600">SYSTEM STATUS: OPERATIONAL</span>
      <span class="font-mono text-[10px] text-neutral-600">V.2.0.25</span>
    </div>
  </footer>

  <!-- Scroll Animations -->
  <script>
    // Wait for GSAP to be available
    const initAnimations = () => {
      const gsap = window.gsap;
      const ScrollTrigger = window.ScrollTrigger;

      if (!gsap || !ScrollTrigger) {
        setTimeout(initAnimations, 100);
        return;
      }

      // Set initial states for hero elements
      gsap.set('.hero-title-line > span', { y: '100%' });
      gsap.set('.hero-reveal', { opacity: 0, y: 30 });
      gsap.set('.hero-cta', { opacity: 0, y: 20 });
      gsap.set('.ingredient-item', { opacity: 0, x: -20 });

      // Hero Title Animation on Load
      const heroTl = gsap.timeline({ delay: 0.3 });

      heroTl
        .to('.hero-title-line > span', {
          y: '0%',
          duration: 1.2,
          stagger: 0.15,
          ease: 'power4.out'
        })
        .to('.hero-reveal', {
          opacity: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.1,
          ease: 'power3.out'
        }, '-=0.8')
        .to('.ingredient-item', {
          opacity: 1,
          x: 0,
          duration: 0.6,
          stagger: 0.1,
          ease: 'power2.out'
        }, '-=0.5')
        .to('.hero-cta', {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: 'power2.out'
        }, '-=0.3');

      // Hero Parallax on Scroll
      gsap.to('.hero-grid', {
        yPercent: 30,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: 1
        }
      });

      gsap.to('.hero-title', {
        yPercent: 20,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: 1
        }
      });

      // Artists Section Animations
      gsap.set('.artist-row', { opacity: 0, y: 60 });
      gsap.set('.artists-title', { opacity: 0, y: 40 });

      gsap.to('.artists-title', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.artists-section',
          start: 'top 80%'
        }
      });

      gsap.to('.artist-row', {
        opacity: 1,
        y: 0,
        stagger: 0.1,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.artists-list',
          start: 'top 80%'
        }
      });

      // Pinned Columns: Lock in place when footer enters viewport
      const pinnedLeft = document.querySelector('.pinned-left');
      const pinnedRight = document.querySelector('.pinned-right');
      const footer = document.querySelector('.footer-section');

      if (pinnedLeft && pinnedRight && footer) {
        let lockedTop = null;

        ScrollTrigger.create({
          trigger: footer,
          start: 'top bottom',
          onEnter: () => {
            // Lock columns at their current screen position relative to document
            lockedTop = window.scrollY;
            pinnedLeft.style.position = 'absolute';
            pinnedLeft.style.top = `${lockedTop}px`;
            pinnedRight.style.position = 'absolute';
            pinnedRight.style.top = `${lockedTop}px`;
          },
          onLeaveBack: () => {
            // Restore fixed positioning
            pinnedLeft.style.position = 'fixed';
            pinnedLeft.style.top = '0';
            pinnedRight.style.position = 'fixed';
            pinnedRight.style.top = '0';
            lockedTop = null;
          }
        });
      }

      // Process Section Animations
      gsap.set('.process-step', { opacity: 0, y: 80, scale: 0.95 });
      gsap.set('.process-title', { opacity: 0, y: 40 });

      gsap.to('.process-title', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.process-section',
          start: 'top 80%'
        }
      });

      gsap.to('.process-step', {
        opacity: 1,
        y: 0,
        scale: 1,
        stagger: 0.15,
        duration: 1,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.process-grid',
          start: 'top 85%'
        }
      });

      // Process number parallax
      gsap.utils.toArray('.process-num').forEach((num) => {
        gsap.to(num, {
          yPercent: -30,
          ease: 'none',
          scrollTrigger: {
            trigger: num,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1
          }
        });
      });

      // Footer Animations
      gsap.set('.footer-title', { opacity: 0, scale: 0.8 });
      gsap.set('.footer-reveal', { opacity: 0, y: 40 });
      gsap.set('.footer-social', { opacity: 0, scale: 0.5 });

      const footerTl = gsap.timeline({
        scrollTrigger: {
          trigger: '.footer-section',
          start: 'top 80%'
        }
      });

      footerTl
        .to('.footer-title', {
          opacity: 1,
          scale: 1,
          duration: 1,
          ease: 'power4.out'
        })
        .to('.footer-reveal', {
          opacity: 1,
          y: 0,
          stagger: 0.1,
          duration: 0.8,
          ease: 'power3.out'
        }, '-=0.6')
        .to('.footer-social', {
          opacity: 1,
          scale: 1,
          stagger: 0.1,
          duration: 0.5,
          ease: 'back.out(2)'
        }, '-=0.4');

      console.log('Scroll animations initialized');
    };

    // Initialize when DOM is ready
    document.addEventListener('DOMContentLoaded', initAnimations);
  </script>
</SiteLayout>
