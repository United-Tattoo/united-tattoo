---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import EditorialFooter from '../components/EditorialFooter.astro';
import SectionSidebar from '../components/SectionSidebar.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import GridBackground from '../components/GridBackground.astro';
import SectionHeader from '../components/SectionHeader.astro';

export const prerender = true;

const artists = await getCollection('artists');
---

<SiteLayout title={SITE_DESCRIPTION} removeMainPadding={true} hideFooter={true}>

  <FloatingCTA href="/booking" label="Book a session" />

  <div class="relative main-content-wrapper">

  <!-- Hero Section: Dramatic Immersive Experience -->
  <section class="hero-section min-h-[110vh] relative flex flex-col overflow-hidden" data-scroll-section>
    <!-- Grid Background with parallax -->
    <GridBackground opacity={40} class="hero-grid" data-speed="0.3" />

    <!-- Dove - Positioned Right with Parallax Layers -->
    <div class="absolute right-0 top-0 bottom-0 w-full lg:w-3/4 z-0 pointer-events-none overflow-hidden" data-speed="0.5">
      <div class="absolute inset-0 mix-blend-screen opacity-60 hero-dove-layer" data-speed="0.7" data-parallax-layer="dove">
        <img src="/dove.png" alt="" class="w-full h-full object-contain object-right grayscale contrast-125 scale-110" />
      </div>
      <!-- Gradient fade to left - deeper, more dramatic -->
      <div class="absolute inset-0 bg-gradient-to-r from-bg-deep via-bg-deep/80 to-transparent"></div>
      <!-- Additional depth layer -->
      <div class="absolute inset-0 bg-gradient-to-t from-bg-deep/90 via-transparent to-bg-deep/40"></div>
    </div>

    <!-- Atmospheric overlays for depth -->
    <div class="absolute inset-0 z-[1] pointer-events-none bg-gradient-to-t from-bg-deep via-transparent to-bg-deep/70"></div>
    <div class="absolute inset-0 z-[2] pointer-events-none bg-gradient-to-br from-transparent via-transparent to-bg-deep/50"></div>

    <!-- Hero Content Grid -->
    <div class="relative z-10 flex-1 grid grid-cols-1 lg:grid-cols-12 pt-32 lg:pt-40">
      <!-- Left Content Column -->
      <div class="col-span-1 lg:col-span-8 flex flex-col justify-end px-6 md:px-12 lg:px-20 pb-20 md:pb-28 lg:pb-36">
        <!-- Label -->
        <div class="hero-reveal mb-8 lg:mb-10">
          <span class="font-mono text-xs uppercase tracking-[0.25em] font-medium" style="color: var(--color-sage);">Custom · Flash · Freedom</span>
        </div>

        <!-- Title - Dramatic Scale with Character Animation Ready -->
        <h1 class="hero-title leading-[0.8] font-normal tracking-tighter uppercase mb-12 md:mb-16" style="font-size: var(--text-display-xl);">
          <span class="hero-title-line block overflow-hidden">
            <span class="title-word inline-block text-white" data-split-text>
              <span class="title-char">U</span><span class="title-char">n</span><span class="title-char">i</span><span class="title-char">t</span><span class="title-char">e</span><span class="title-char">d</span>
            </span>
          </span>
          <span class="hero-title-line block overflow-hidden mt-[-0.05em]">
            <span class="title-word italic font-light inline-block" data-split-text style="color: var(--color-sage-light);">
              <span class="title-char">T</span><span class="title-char">a</span><span class="title-char">t</span><span class="title-char">t</span><span class="title-char">o</span><span class="title-char">o</span>
            </span>
          </span>
        </h1>

        <!-- Tagline -->
        <p class="hero-reveal text-neutral-400 text-lg md:text-xl lg:text-2xl max-w-2xl leading-relaxed font-light mb-14 lg:mb-16">
          A collective dedicated to the art of release. Where the timeless torch of tradition meets the modern expression of self.
        </p>

        <!-- Hero Info Bar -->
        <div class="hero-reveal flex flex-wrap items-center gap-10 lg:gap-12 pt-8 border-t" style="border-color: var(--color-sage-dark);">
          <div>
            <span class="font-mono text-xs uppercase tracking-[0.2em] block mb-2" style="color: var(--color-sage);">Location</span>
            <span class="font-mono text-sm text-white">Fountain, CO</span>
          </div>
          <div>
            <span class="font-mono text-xs uppercase tracking-[0.2em] block mb-2" style="color: var(--color-sage);">Hours</span>
            <span class="font-mono text-sm text-white">Sun–Sat · 10am–8pm</span>
          </div>
          <div>
            <span class="font-mono text-xs uppercase tracking-[0.2em] block mb-2" style="color: var(--color-sage);">Artists</span>
            <span class="font-mono text-sm text-white">{artists.length} in residence</span>
          </div>
          <div class="hidden lg:block ml-auto">
             <a href="/booking" class="hero-cta px-8 py-4 border transition-all duration-500 font-mono text-xs uppercase tracking-widest hover:translate-y-[-2px]" style="border-color: var(--color-sage-dark); color: var(--color-stone);">
               Book Consultation
             </a>
          </div>
        </div>

        <!-- Mobile CTA -->
        <div class="lg:hidden mt-12">
          <a href="/booking" class="hero-cta group block w-full py-5 text-center font-mono text-sm uppercase tracking-[0.15em] transition-all duration-500 shadow-lg" style="background-color: var(--color-sage); color: var(--color-bg-deep);">
            <span class="flex items-center justify-center gap-3">
              <span class="group-hover:translate-x-1 transition-transform duration-300">Book a session</span>
              <span class="w-6 h-6 rounded-full flex items-center justify-center text-xs transition-colors" style="background-color: var(--color-sage-dark); color: white;">→</span>
            </span>
          </a>
        </div>
      </div>

      <!-- Right Column - Empty space for dove -->
      <div class="hidden lg:block col-span-4"></div>
    </div>

    <!-- Scroll Indicator with sage accent -->
    <ScrollIndicator class="hero-reveal" style="--scroll-accent: var(--color-sage);" />
  </section>

  <!-- Artists Section: The Index -->
  <section id="artists" class="artists-section relative z-20 border-t border-white/10" data-scroll-section>
    <SectionSidebar
      sectionNum="Section 01"
      label="The Team"
      description={`${artists.length} artists in residence, each with their own unique style and specialty.`}
    >
      <!-- Header Row -->
      <SectionHeader
        title="The team"
        meta={`${artists.length} artists`}
        titleClass="artists-title"
        class="artists-header"
      />

      <!-- Artists List -->
      <div class="artists-list">
        {artists.map((artist, index) => (
          <div class="artist-row group relative border-b border-white/10 hover:bg-white/[0.02] transition-colors duration-300">
            <a href={`/artists/${artist.id}`} class="block px-6 md:px-8 py-8 md:py-10 flex flex-col md:flex-row items-baseline md:items-center justify-between gap-4">
              <div class="flex items-center md:items-baseline gap-4 md:gap-8 md:w-1/2">
                <span class="font-mono text-sm text-neutral-700 group-hover:text-white transition-colors">
                  {(index + 1).toString().padStart(2, '0')}
                </span>
                
                <!-- Mobile Avatar -->
                <img 
                  src={artist.data.portrait} 
                  alt="" 
                  class="w-12 h-12 rounded-full object-cover lg:hidden border border-white/10" 
                />

                <h3 class="text-2xl md:text-3xl lg:text-4xl font-normal font-display italic text-white group-hover:translate-x-2 transition-transform duration-300">
                  {artist.data.name}
                </h3>
              </div>

              <div class="flex items-center justify-between w-full md:w-auto gap-6 md:gap-10">
                <div class="flex flex-col">
                  <span class="font-mono text-xs uppercase tracking-[0.2em] mb-1" style="color: var(--color-moss);">Specialty</span>
                  <span class="font-mono text-sm text-neutral-300">
                    {artist.data.specialties ? artist.data.specialties[0] : 'Custom'}
                  </span>
                </div>

                <span class="w-9 h-9 rounded-full flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-all duration-300" style="background-color: var(--color-terracotta);">
                  ↗
                </span>
              </div>
            </a>

            <!-- Hover Image Reveal (Desktop) -->
            <div class="hidden lg:block absolute top-1/2 right-24 -translate-y-1/2 w-[180px] aspect-[3/4] opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-10 bg-neutral-900 border border-white/5 rotate-2 group-hover:rotate-3 transition-transform shadow-2xl">
              <img
                src={artist.data.portrait}
                alt={artist.data.name}
                class="w-full h-full object-cover grayscale"
              />
            </div>
          </div>
        ))}
      </div>
    </SectionSidebar>
  </section>

  <!-- Process Section: The Methodology - Horizontal Scroll Experience -->
  <section id="process" class="process-section relative z-20 border-t border-white/10 overflow-hidden" data-scroll-section data-horizontal-scroll>
    <!-- Section Header -->
    <div class="px-6 md:px-12 lg:px-16 py-12 md:py-16 border-b border-white/5">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <span class="section-label block mb-4">Section 02</span>
          <h2 class="process-title font-display text-4xl md:text-5xl lg:text-6xl italic text-white">Methodology</h2>
        </div>
        <p class="font-mono text-sm text-neutral-500 max-w-xs">From first idea to healed artwork—our proven process.</p>
      </div>
    </div>

    <!-- Horizontal Scroll Container -->
    <div class="horizontal-scroll process-scroll" data-horizontal-container>
      {[
        { num: '01', title: 'Consultation', desc: 'Share your vision. We shape your idea together and match you with the right artist.', icon: 'solar:chat-line-linear' },
        { num: '02', title: 'Design', desc: 'Your artist creates a custom piece tailored to your body and style.', icon: 'solar:pen-new-square-linear' },
        { num: '03', title: 'Session', desc: 'Get inked in our clean, comfortable studio with experienced professionals.', icon: 'ph:needle' },
        { num: '04', title: 'Aftercare', desc: 'We guide you through healing so your artwork stays vibrant for life.', icon: 'solar:heart-linear' }
      ].map((step, i) => (
        <div class="horizontal-scroll-item process-panel relative flex flex-col min-h-[70vh] md:min-h-[80vh] border-r border-white/5">
          <!-- Panel Inner Container -->
          <div class="flex-1 flex flex-col px-8 md:px-16 lg:px-24 py-12 md:py-16">
            <!-- Top Row: Number + Icon -->
            <div class="flex justify-between items-start mb-auto">
              <span class="section-number process-num">[{step.num}]</span>
              <iconify-icon icon={step.icon} class="text-3xl md:text-4xl opacity-40 hover:opacity-100 transition-opacity" style="color: var(--color-sage);"></iconify-icon>
            </div>

            <!-- Center/Bottom Content -->
            <div class="process-content mt-auto max-w-md">
              <h3 class="font-display italic text-white mb-6" style="font-size: var(--text-heading-lg);">{step.title}</h3>
              <p class="font-mono leading-relaxed text-neutral-400" style="font-size: var(--text-body-sm);">
                {step.desc}
              </p>
            </div>

            <!-- Step Indicator -->
            <div class="mt-12 pt-8 border-t border-white/5">
              <div class="flex items-center gap-4">
                <span class="font-mono text-xs uppercase tracking-widest text-neutral-600">Step</span>
                <div class="flex gap-2">
                  {[1,2,3,4].map((dot) => (
                    <span class={`w-2 h-2 rounded-full transition-colors ${dot === i + 1 ? 'bg-sage' : 'bg-white/10'}`}></span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Scroll Hint (Mobile) -->
    <div class="md:hidden px-6 py-4 border-t border-white/5 flex items-center justify-center gap-2 text-neutral-500">
      <iconify-icon icon="solar:arrow-right-linear" class="text-sm"></iconify-icon>
      <span class="font-mono text-xs uppercase tracking-widest">Swipe to explore</span>
    </div>
  </section>


  </div>

  <EditorialFooter />

  <!-- Micro-interactions & Hover Styles -->
  <style>
    /* Artist name underline on hover */
    .artist-row:hover h3 {
      background-image: linear-gradient(to right, var(--color-burnt-orange), var(--color-terracotta));
      background-size: 0 2px;
      background-position: 0 100%;
      background-repeat: no-repeat;
      animation: underlineSlide 0.3s ease-out forwards;
    }

    @keyframes underlineSlide {
      to {
        background-size: 100% 2px;
      }
    }

    /* Hero CTA hover effects */
    .hero-section .hero-cta:hover {
      background-color: var(--color-sage) !important;
      color: var(--color-bg-deep) !important;
      border-color: var(--color-sage) !important;
      transform: translateY(-2px);
      box-shadow: 0 10px 40px rgba(156, 175, 148, 0.25);
    }

    /* Title character animation base styles */
    .title-char {
      display: inline-block;
      transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
    }

    .title-word:hover .title-char {
      animation: charWave 0.6s ease-out forwards;
    }

    .title-char:nth-child(1) { animation-delay: 0s; }
    .title-char:nth-child(2) { animation-delay: 0.05s; }
    .title-char:nth-child(3) { animation-delay: 0.1s; }
    .title-char:nth-child(4) { animation-delay: 0.15s; }
    .title-char:nth-child(5) { animation-delay: 0.2s; }
    .title-char:nth-child(6) { animation-delay: 0.25s; }

    @keyframes charWave {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-8px); }
    }

    /* Process horizontal scroll enhancements */
    .process-scroll {
      scroll-behavior: smooth;
    }

    .process-panel {
      background: linear-gradient(180deg, var(--color-bg-deep) 0%, var(--color-bg-elevated) 100%);
      transition: background 0.4s ease;
    }

    .process-panel:hover {
      background: linear-gradient(180deg, var(--color-bg-elevated) 0%, var(--color-bg-surface) 100%);
    }

    .process-panel:hover .process-num {
      opacity: 0.8;
      transform: translateY(-4px);
    }

    .process-num {
      transition: opacity 0.4s ease, transform 0.4s ease;
    }

    .process-panel .process-content h3 {
      transition: color 0.3s ease;
    }

    .process-panel:hover .process-content h3 {
      color: var(--color-sage-light);
    }

    /* Scroll snap for touch devices */
    @media (hover: none) {
      .process-scroll {
        scroll-snap-type: x mandatory;
      }
    }

    /* Desktop: larger panels with more breathing room */
    @media (min-width: 1024px) {
      .process-panel {
        min-height: 85vh;
      }
    }
  </style>

  <!-- Scroll Animations -->
  <script>
    // Wait for GSAP to be available
    const initAnimations = () => {
      const gsap = window.gsap;
      const ScrollTrigger = window.ScrollTrigger;

      if (!gsap || !ScrollTrigger) {
        // Retry if global GSAP isn't ready yet (rare with astro:page-load but possible)
        setTimeout(initAnimations, 50);
        return;
      }

      // Set initial states for hero elements
      gsap.set('.hero-title-line > span', { y: '100%' });
      gsap.set('.hero-reveal', { opacity: 0, y: 30 });
      gsap.set('.hero-cta', { opacity: 0, y: 20 });
      gsap.set('.ingredient-item', { opacity: 0, x: -20 });

      // Parallax Mouse Effect for Hero Dove
      const heroSection = document.querySelector('.hero-section');
      const doveLayer = document.querySelector('.hero-dove-layer');
      
      if (heroSection && doveLayer) {
        heroSection.addEventListener('mousemove', (e) => {
          const xPos = (e.clientX / window.innerWidth - 0.5) * 20;
          const yPos = (e.clientY / window.innerHeight - 0.5) * 20;
          
          gsap.to(doveLayer, {
            x: xPos,
            y: yPos,
            duration: 1,
            ease: 'power2.out'
          });
        });
      }

      // Hero Title Animation on Load
      const heroTl = gsap.timeline({ delay: 0.3 });

      heroTl
        .to('.hero-title-line > span', {
          y: '0%',
          duration: 1.2,
          stagger: 0.15,
          ease: 'power4.out'
        })
        .to('.hero-reveal', {
          opacity: 1,
          y: 0,
          duration: 0.8,
          stagger: 0.1,
          ease: 'power3.out'
        }, '-=0.8')
        .to('.ingredient-item', {
          opacity: 1,
          x: 0,
          duration: 0.6,
          stagger: 0.1,
          ease: 'power2.out'
        }, '-=0.5')
        .to('.hero-cta', {
          opacity: 1,
          y: 0,
          duration: 0.6,
          ease: 'power2.out'
        }, '-=0.3');

      // Hero Parallax on Scroll
      gsap.to('.hero-grid', {
        yPercent: 30,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: 1
        }
      });

      gsap.to('.hero-title', {
        yPercent: 20,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: 1
        }
      });

      // Artists Section Animations
      gsap.set('.artist-row', { opacity: 0, y: 60 });
      gsap.set('.artists-title', { opacity: 0, y: 40 });

      gsap.to('.artists-title', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.artists-section',
          start: 'top 80%'
        }
      });

      gsap.to('.artist-row', {
        opacity: 1,
        y: 0,
        stagger: 0.1,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.artists-list',
          start: 'top 80%'
        }
      });

      // Process Section Animations - Horizontal Scroll
      gsap.set('.process-panel', { opacity: 0, x: 100 });
      gsap.set('.process-title', { opacity: 0, y: 40 });
      gsap.set('.process-num', { opacity: 0, scale: 0.8 });
      gsap.set('.process-content', { opacity: 0, y: 30 });

      // Header animation
      gsap.to('.process-title', {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.process-section',
          start: 'top 80%'
        }
      });

      // Panel reveal animation
      const processTl = gsap.timeline({
        scrollTrigger: {
          trigger: '.process-section',
          start: 'top 70%'
        }
      });

      processTl
        .to('.process-panel', {
          opacity: 1,
          x: 0,
          stagger: 0.1,
          duration: 0.8,
          ease: 'power3.out'
        })
        .to('.process-num', {
          opacity: 0.4,
          scale: 1,
          stagger: 0.1,
          duration: 0.6,
          ease: 'back.out(1.5)'
        }, '-=0.6')
        .to('.process-content', {
          opacity: 1,
          y: 0,
          stagger: 0.1,
          duration: 0.6,
          ease: 'power2.out'
        }, '-=0.4');

      // Horizontal scroll indicator - subtle X parallax on numbers
      gsap.utils.toArray('.process-panel').forEach((panel, i) => {
        const num = panel.querySelector('.process-num');
        if (num) {
          gsap.to(num, {
            yPercent: -20,
            ease: 'none',
            scrollTrigger: {
              trigger: panel,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1
            }
          });
        }
      });

      // Footer Animations
      gsap.set('.footer-title', { opacity: 0, scale: 0.8 });
      gsap.set('.footer-reveal', { opacity: 0, y: 40 });
      gsap.set('.footer-social', { opacity: 0, scale: 0.5 });

      const footerTl = gsap.timeline({
        scrollTrigger: {
          trigger: '.footer-section',
          start: 'top 80%'
        }
      });

      footerTl
        .to('.footer-title', {
          opacity: 1,
          scale: 1,
          duration: 1,
          ease: 'power4.out'
        })
        .to('.footer-reveal', {
          opacity: 1,
          y: 0,
          stagger: 0.1,
          duration: 0.8,
          ease: 'power3.out'
        }, '-=0.6')
        .to('.footer-social', {
          opacity: 1,
          scale: 1,
          stagger: 0.1,
          duration: 0.5,
          ease: 'back.out(2)'
        }, '-=0.4');

      console.log('Scroll animations initialized');
    };

    // Initialize when DOM is ready
    document.addEventListener('astro:page-load', initAnimations);

    // Hide floating CTA when footer is in view
    const initFloatingCTA = () => {
      const floatingCTA = document.getElementById('floating-cta');
      const footer = document.querySelector('.footer-section');

      if (!floatingCTA || !footer) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              floatingCTA.style.opacity = '0';
              floatingCTA.style.pointerEvents = 'none';
              floatingCTA.style.transform = 'translateY(20px)';
            } else {
              floatingCTA.style.opacity = '1';
              floatingCTA.style.pointerEvents = 'auto';
              floatingCTA.style.transform = 'translateY(0)';
            }
          });
        },
        { threshold: 0.1 }
      );

      observer.observe(footer);
    };

    document.addEventListener('astro:page-load', initFloatingCTA);
  </script>
</SiteLayout>
