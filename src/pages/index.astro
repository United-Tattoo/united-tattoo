---
import SiteLayout from '../layouts/SiteLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

export const prerender = true;

const artists = await getCollection('artists');
---

<SiteLayout title={SITE_DESCRIPTION}>
  <!-- Hero Section -->
  <section class="min-h-[85vh] relative flex flex-col justify-center items-center px-6 overflow-hidden -mt-8">
    <!-- Giant Typography Background -->
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none z-0">
      <h2 class="text-[28vw] leading-none font-normal tracking-tighter text-white opacity-[0.02]">
        UNITED
      </h2>
    </div>

    <!-- Decorative line -->
    <div class="absolute top-[55%] left-0 w-full h-[1px] bg-white/5 z-10"></div>

    <!-- Hero Content -->
    <div class="relative z-20 text-center flex flex-col items-center max-w-4xl">
      <span class="section-label mb-6">
        Est. 2023 · Fountain, Colorado
      </span>

      <h1 class="text-[12vw] md:text-[9vw] leading-[0.85] font-normal tracking-tighter italic mb-8">
        High Art,<br/><span class="text-stroke opacity-60">True Craft</span>
      </h1>

      <p class="text-neutral-400 text-lg md:text-xl max-w-lg mb-12 leading-relaxed">
        A collective of professional tattoo artists dedicated to creating exceptional custom work.
      </p>

      <div class="flex flex-col sm:flex-row items-center gap-4">
        <a href="/booking" class="px-8 py-4 bg-white text-black text-sm font-medium tracking-wide hover:bg-neutral-200 transition-all">
          Book a Session
        </a>
        <a href="#artists" class="px-8 py-4 text-neutral-400 text-sm hover:text-white transition-colors">
          Meet the Artists
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-20 flex flex-col items-center gap-3 opacity-30">
      <div class="w-[1px] h-12 bg-gradient-to-b from-white to-transparent"></div>
    </div>
  </section>

  <!-- Artists Section -->
  <section id="artists" class="py-32 px-6 md:px-20 relative z-20">
    <div class="max-w-7xl mx-auto">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-16 gap-6">
        <div>
          <span class="section-label block mb-4">The Collective</span>
          <h2 class="text-5xl md:text-7xl font-normal tracking-tighter text-white italic">Our Artists</h2>
        </div>
        <a href="/artists" class="text-sm text-neutral-500 hover:text-white transition-colors">
          View all →
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {artists.slice(0, 6).map((artist, index) => (
          <a href={`/artists/${artist.id}`} class="group relative aspect-[4/5] overflow-hidden bg-neutral-950">
            <img
              src={artist.data.portrait}
              alt={artist.data.name}
              class="absolute inset-0 w-full h-full object-cover grayscale-[30%] group-hover:grayscale-0 group-hover:scale-[1.02] transition-all duration-700 ease-out"
            />

            <!-- Gradient overlay -->
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

            <!-- Info -->
            <div class="absolute bottom-0 left-0 right-0 p-6">
              <h3 class="text-2xl font-normal text-white italic tracking-tight mb-2">
                {artist.data.name}
              </h3>
              {artist.data.specialties && (
                <p class="text-sm text-neutral-400">
                  {artist.data.specialties.slice(0, 2).join(' · ')}
                </p>
              )}
            </div>

            <!-- Hover indicator -->
            <div class="absolute top-6 right-6 opacity-0 group-hover:opacity-100 transition-opacity">
              <span class="text-xs text-white/60">View Portfolio →</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section id="process" class="py-32 px-6 md:px-20 relative z-20 border-t border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        <div class="lg:col-span-4">
          <div class="lg:sticky lg:top-40">
            <span class="section-label block mb-4">How It Works</span>
            <h2 class="text-5xl md:text-6xl font-normal italic tracking-tighter text-white leading-[0.9] mb-8">
              The<br/>Process
            </h2>

            <p class="text-neutral-400 text-base leading-relaxed max-w-sm">
              From initial consultation to healed artwork, we guide you through every step of creating your custom piece.
            </p>
          </div>
        </div>

        <div class="lg:col-span-8">
          <div class="flex flex-col">
            {[
              { num: '01', title: 'Consultation', desc: 'Share your vision with us. We\'ll discuss placement, size, style, and work together to refine your concept into a design that\'s uniquely yours.' },
              { num: '02', title: 'Design', desc: 'Your artist creates custom artwork based on our consultation. You\'ll have the opportunity to review and request adjustments before your appointment.' },
              { num: '03', title: 'Session', desc: 'On the day of your appointment, your artist brings the design to life. We prioritize your comfort throughout the process.' },
              { num: '04', title: 'Aftercare', desc: 'We provide detailed care instructions to ensure your tattoo heals beautifully. Touch-ups are available if needed.' }
            ].map((step) => (
              <div class="group py-12 border-b border-white/5 last:border-b-0">
                <div class="flex flex-col md:flex-row md:items-baseline gap-4 md:gap-8 mb-4">
                  <span class="text-xs text-neutral-600 font-mono">{step.num}</span>
                  <h3 class="text-4xl md:text-5xl font-normal italic text-neutral-500 group-hover:text-white transition-colors duration-500">
                    {step.title}
                  </h3>
                </div>
                <p class="text-neutral-500 text-base max-w-xl md:ml-16 group-hover:text-neutral-400 transition-colors duration-500">
                  {step.desc}
                </p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-32 px-6 md:px-20 relative z-20 bg-black">
    <div class="max-w-4xl mx-auto text-center">
      <span class="section-label block mb-6">Ready to Begin?</span>
      <h2 class="text-5xl md:text-7xl font-normal italic tracking-tighter text-white leading-[0.9] mb-8">
        Let's Create<br/>Something Beautiful
      </h2>
      <p class="text-neutral-400 text-lg max-w-lg mx-auto mb-12">
        Submit a booking request and one of our artists will be in touch within 48 hours.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/booking" class="px-10 py-5 bg-white text-black text-sm font-medium tracking-wide hover:bg-neutral-200 transition-all">
          Book a Session
        </a>
        <a href="mailto:ink@unitedtattoo.com" class="px-10 py-5 border border-white/10 text-white text-sm hover:bg-white/5 transition-all">
          Send an Email
        </a>
      </div>
    </div>
  </section>

  <!-- Location Info -->
  <section class="py-20 px-6 md:px-20 border-t border-white/5">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div>
          <h4 class="text-xs uppercase tracking-widest text-neutral-500 mb-4">Location</h4>
          <address class="text-base text-neutral-300 not-italic leading-relaxed">
            712 S Santa Fe Ave<br/>
            Fountain, CO 80817
          </address>
        </div>
        <div>
          <h4 class="text-xs uppercase tracking-widest text-neutral-500 mb-4">Hours</h4>
          <p class="text-base text-neutral-300">
            Tuesday – Saturday<br/>
            12:00 pm – 8:00 pm
          </p>
        </div>
        <div>
          <h4 class="text-xs uppercase tracking-widest text-neutral-500 mb-4">Contact</h4>
          <p class="text-base text-neutral-300">
            <a href="mailto:ink@unitedtattoo.com" class="hover:text-white transition-colors">ink@unitedtattoo.com</a>
          </p>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
