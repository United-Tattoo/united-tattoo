---
import SiteLayout from '../layouts/SiteLayout.astro';
import {
  ADDRESS_LINE_1,
  ADDRESS_LINE_2,
  GOOGLE_MAPS_URL,
  SITE_DESCRIPTION,
} from '../consts';
import { getCollection } from 'astro:content';
import EditorialFooter from '../components/EditorialFooter.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import fs from 'node:fs';
import path from 'node:path';

export const prerender = true;

const artists = await getCollection('artists');
const featuredArtists = artists.slice(0, 4);

// Collect portfolio images from all artists for the marquee & showcase
const publicDir = path.join(process.cwd(), 'public');
const SUPPORTED_PORTFOLIO_IMAGE = /\.(avif|webp|jpe?g|png)$/i;
const MAX_IMAGES_PER_ARTIST = 5;
const portfolioImagesByArtist: { artist: string; artistId: string; images: { src: string; artist: string; artistId: string }[] }[] = [];

for (const artist of artists) {
  const portfolioPath = path.join(publicDir, artist.data.galleryDir, 'Portfolio');
  try {
    if (fs.existsSync(portfolioPath)) {
      const files = fs.readdirSync(portfolioPath)
        .filter((file) => SUPPORTED_PORTFOLIO_IMAGE.test(file))
        .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
        .slice(0, MAX_IMAGES_PER_ARTIST);

      if (files.length === 0) {
        continue;
      }

      portfolioImagesByArtist.push({
        artist: artist.data.name,
        artistId: artist.id,
        images: files.map((file) => ({
          src: `/${artist.data.galleryDir}/Portfolio/${file}`,
          artist: artist.data.name,
          artistId: artist.id,
        })),
      });
    }
  } catch (_e) { /* skip */ }
}

// Round-robin by artist so homepage features do not collapse onto one portfolio.
const balancedPortfolioImages: { src: string; artist: string; artistId: string }[] = [];
for (let imageIndex = 0; imageIndex < MAX_IMAGES_PER_ARTIST; imageIndex += 1) {
  for (const artistPortfolio of portfolioImagesByArtist) {
    const image = artistPortfolio.images[imageIndex];
    if (image) {
      balancedPortfolioImages.push(image);
    }
  }
}

// Split into two rows for marquee
const marqueeRow1 = balancedPortfolioImages.filter((_, i) => i % 2 === 0).slice(0, 10);
const marqueeRow2 = balancedPortfolioImages.filter((_, i) => i % 2 === 1).slice(0, 10);

// Pick varied images for the featured work mosaic, filling complete desktop rows.
const showcaseColumns = 3;
const showcaseMinimumImages = Math.max(6, portfolioImagesByArtist.length);
const showcaseImageCount = Math.ceil(showcaseMinimumImages / showcaseColumns) * showcaseColumns;
const showcaseImages = balancedPortfolioImages.slice(0, showcaseImageCount);
const showStudioIntro = false;
---

<SiteLayout title={SITE_DESCRIPTION} removeMainPadding={true} hideFooter={true}>

  <FloatingCTA href="/booking" label="Request a consult" eventLocation="home_floating" />

  <div class="relative main-content-wrapper max-w-[1800px] mx-auto border-l border-r border-border">

  <!-- Persistent page grid lines -->
  <div class="page-grid-lines absolute inset-0 z-[1] pointer-events-none hidden lg:block">
    <div class="absolute top-0 bottom-0 left-[25%] w-px bg-border/40"></div>
    <div class="absolute top-0 bottom-0 left-[50%] w-px bg-border/15"></div>
    <div class="absolute top-0 bottom-0 left-[75%] w-px bg-border/40"></div>
  </div>

  <!-- Hero Section -->
  <section class="hero-section min-h-screen relative flex flex-col overflow-hidden" data-scroll-section>

    <!-- Full-bleed photo with desaturated treatment -->
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden hero-photo-wrap">
      <div class="absolute inset-0 hero-photo-layer scale-[1.03]">
        <img src="/images/united-exterior.avif" alt="United Tattoo storefront" class="w-full h-full object-cover object-center grayscale brightness-[0.62] contrast-[1.12]" />
      </div>
      <div class="absolute inset-0 bg-black/48"></div>
      <div class="absolute inset-0 hero-vignette"></div>
    </div>

    <!-- Film grain -->
    <div class="absolute inset-0 z-[2] pointer-events-none hero-grain"></div>

    <!-- Hero Content -->
    <div class="relative z-10 flex min-h-screen items-end">
      <div class="hero-copy w-full px-6 pb-20 pt-32 md:px-12 md:pb-24 lg:px-20 lg:pb-28">
        <div class="max-w-5xl">
          <p class="hero-reveal hero-kicker font-mono text-[10px] uppercase tracking-[0.32em] text-white/65 mb-5">
            Fountain, Colorado
          </p>
          <h1 class="hero-title text-white" style="font-family: var(--font-display), 'Playfair Display', serif; font-weight: 400;">
            <span class="hero-title-line block overflow-hidden">
              <span class="inline-block">United</span>
            </span>
            <span class="hero-title-line block overflow-hidden">
              <span class="inline-block">Tattoo</span>
            </span>
          </h1>
          <div class="hero-reveal mt-7 h-px w-full max-w-xl bg-white/35"></div>
          <div class="hero-reveal mt-6 flex max-w-3xl flex-col gap-6 md:flex-row md:items-end md:justify-between">
            <p class="max-w-lg font-mono text-sm md:text-base text-white/72 tracking-wide">
              Custom tattoos in Fountain, Colorado. Built around the artist, the client, and the work.
            </p>
            <div class="flex shrink-0 flex-col items-start gap-3">
              <div class="flex items-center gap-4">
                <a
                  href="/booking"
                  class="inline-flex items-center gap-2 px-5 py-3 bg-primary text-primary-foreground font-mono text-xs uppercase tracking-[0.15em] border border-primary hover:brightness-110 transition-all"
                  data-analytics-event="booking_cta_click"
                  data-analytics-location="home_hero"
                  data-analytics-label="Request a Consult"
                  data-analytics-href="/booking"
                >
                  Request a Consult
                </a>
                <a href="/artists" class="font-mono text-xs uppercase tracking-[0.15em] text-white/72 border-b border-white/30 pb-0.5 hover:text-white hover:border-white transition-all">
                  View Artists
                </a>
              </div>
              <p class="max-w-xs font-mono text-[10px] uppercase tracking-[0.18em] text-white/52">
                No deposit to request · 24-48h response
              </p>
            </div>
            </div>
          <div class="hero-reveal mt-5 flex flex-wrap items-center gap-x-3 gap-y-2 font-mono text-[10px] uppercase tracking-[0.2em] text-white/58">
            <span>{ADDRESS_LINE_1}</span>
            <span class="hidden h-px w-6 bg-white/25 sm:inline-block" aria-hidden="true"></span>
            <span>{ADDRESS_LINE_2}</span>
            <span class="h-px w-6 bg-white/25" aria-hidden="true"></span>
            <a href={GOOGLE_MAPS_URL} target="_blank" rel="noopener noreferrer" class="text-white/72 hover:text-white transition-colors">
              Get Directions
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {showStudioIntro && (
  <section class="studio-intro relative z-20 border-t border-b border-border" data-scroll-section>
    <!-- Grid dots -->
    <div class="grid-dot" style="left:25%;top:0"></div>
    <div class="grid-dot" style="left:50%;top:0"></div>
    <div class="grid-dot" style="left:75%;top:0"></div>
    <div class="grid-dot" style="left:25%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="grid-dot" style="left:50%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="grid-dot" style="left:75%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>

    <!-- Ghost logo -->
    <div class="studio-ghost-image" aria-hidden="true">
      <img src="/images/united-logo-full.avif" alt="" loading="lazy" />
    </div>

    <!-- Two-column editorial layout -->
    <div class="intro-layout">
      <!-- Left: statement -->
      <div class="intro-statement">
        <span class="intro-kicker intro-reveal">Custom work, built with you</span>
        <h2 class="intro-headline intro-reveal">
          Bring your idea. We will shape it into work that fits now and ages well.
        </h2>
        <div class="intro-actions intro-reveal">
          <a href="/booking" class="intro-cta-primary">
            <span>Request booking</span>
            <span class="intro-cta-arrow" aria-hidden="true">→</span>
          </a>
          <a href="/artists" class="intro-cta-secondary">View artists</a>
        </div>
      </div>

      <!-- Right: metadata sidebar -->
      <div class="intro-sidebar">
        <span class="intro-sidebar-label intro-reveal">Studio snapshot</span>
        <div class="intro-meta-stack">
          <div class="intro-meta intro-reveal">
            <span class="intro-meta-label">Location</span>
            <span class="intro-meta-value">Fountain, CO</span>
          </div>
          <div class="intro-meta intro-reveal">
            <span class="intro-meta-label">Studio</span>
            <span class="intro-meta-value">{artists.length} Artists in Residence</span>
          </div>
          <div class="intro-meta intro-reveal">
            <span class="intro-meta-label">Hours</span>
            <span class="intro-meta-value">Sun — Sat, 10a–8p</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  )}

  <!-- Work Marquee: Infinite Scroll Strip -->
  <section class="marquee-section relative z-20 overflow-hidden border-t border-border py-8 md:py-12" data-scroll-section>
    <div class="grid-dot" style="left:25%;top:0"></div>
    <div class="grid-dot" style="left:50%;top:0"></div>
    <div class="grid-dot" style="left:75%;top:0"></div>

    <!-- Row 1 - scrolls left -->
    <div class="marquee-track mb-4">
      <div class="marquee-scroll">
        {[...marqueeRow1, ...marqueeRow1].map((img) => (
          <div class="marquee-item">
            <img src={img.src} alt={`Tattoo by ${img.artist}`} loading="lazy" />
            <span class="marquee-credit">{img.artist}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Row 2 - scrolls right -->
    <div class="marquee-track marquee-reverse">
      <div class="marquee-scroll">
        {[...marqueeRow2, ...marqueeRow2].map((img) => (
          <div class="marquee-item">
            <img src={img.src} alt={`Tattoo by ${img.artist}`} loading="lazy" />
            <span class="marquee-credit">{img.artist}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Section Title Banner: Artists -->
  <div class="section-banner section-banner--image section-banner--team relative z-20 border-t border-b border-border overflow-hidden" data-scroll-section>
    <!-- Grid dots at intersections -->
    <div class="grid-dot" style="left:25%;top:0"></div>
    <div class="grid-dot" style="left:50%;top:0"></div>
    <div class="grid-dot" style="left:75%;top:0"></div>
    <div class="grid-dot" style="left:25%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="grid-dot" style="left:50%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="grid-dot" style="left:75%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <!-- Subtle noise bg -->
    <div class="absolute inset-0 noise pointer-events-none"></div>
    <div class="section-banner-image" aria-hidden="true">
      <img src="/artists/Christy-Lumberg/Portfolio/26-01-02%2019-25-03%2048.jpg" alt="" loading="lazy" />
    </div>
    <div class="section-banner-inner">
      <div class="section-banner-meta">
        <span>01 / Artists</span>
      </div>
      <h2 class="artists-title section-banner-title">The Team</h2>
      <div class="section-banner-footer">
        <span>{artists.length} artists in residence</span>
        <a href="/artists">Explore portfolios <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </div>

  <!-- Artists Section: The Index -->
  <section id="artists" class="artists-section relative z-20" data-scroll-section>
    <div class="artists-list">
      {artists.map((artist, index) => {
        const firstName = artist.data.name.split(' ')[0];
        return (
          <div class="artist-row group relative border-b border-border hover:bg-secondary/50 transition-colors duration-300">
            <a href={`/artists/${artist.id}`} class="block px-6 md:px-10 lg:px-16 py-8 md:py-10 flex flex-col md:flex-row items-baseline md:items-center justify-between gap-4">
            <div class="flex items-center md:items-baseline gap-4 md:gap-8 md:w-1/2">
              <span class="font-mono text-sm text-muted-foreground/40 group-hover:text-primary/60 transition-colors tabular-nums">
                {(index + 1).toString().padStart(2, '0')}
              </span>

              <!-- Mobile Avatar -->
              <img
                src={artist.data.portrait}
                alt=""
                class="w-12 h-12 rounded-full object-cover lg:hidden border border-border"
              />

              <h3 class="text-2xl md:text-3xl lg:text-4xl font-extralight font-sans text-foreground group-hover:translate-x-2 transition-transform duration-300">
                {artist.data.name}
              </h3>
            </div>

            <div class="flex items-center justify-between w-full md:w-auto gap-6 md:gap-10">
              <div class="flex flex-col">
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] mb-1 text-muted-foreground/60">Specialty</span>
                <span class="font-mono text-sm text-secondary-foreground">
                  {artist.data.specialties ? artist.data.specialties[0] : 'Custom'}
                </span>
              </div>

              <span class="w-9 h-9 rounded-full flex items-center justify-center text-primary-foreground opacity-0 group-hover:opacity-100 transition-all duration-300 bg-primary">
                ↗
                </span>
              </div>
            </a>

            <a
              href={`/booking?artist=${artist.id}`}
              class="artist-row-booking"
              data-analytics-event="booking_cta_click"
              data-analytics-location="home_artist_row"
              data-analytics-label={`Request with ${firstName}`}
              data-analytics-artist={artist.id}
              data-analytics-href={`/booking?artist=${artist.id}`}
            >
              Request with {firstName}
            </a>

            <!-- Hover Image Reveal (Desktop) -->
            <div class="hidden lg:block absolute top-1/2 right-24 -translate-y-1/2 w-[180px] aspect-[3/4] opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none z-10 bg-card border border-border rotate-2 group-hover:rotate-3 transition-transform shadow-2xl">
            <img
              src={artist.data.portrait}
              alt={artist.data.name}
              class="w-full h-full object-cover grayscale"
            />
            </div>
          </div>
        )})}
    </div>
  </section>

  <!-- Section Title Banner: Work -->
  <div class="section-banner section-banner--image section-banner--work relative z-20 border-t border-b border-border overflow-hidden" data-scroll-section>
    <div class="grid-dot" style="left:25%;top:0"></div>
    <div class="grid-dot" style="left:50%;top:0"></div>
    <div class="grid-dot" style="left:75%;top:0"></div>
    <div class="grid-dot" style="left:25%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="grid-dot" style="left:50%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="grid-dot" style="left:75%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="absolute inset-0 noise pointer-events-none"></div>
    <div class="section-banner-image" aria-hidden="true">
      <img src="/artists/Christy-Lumberg/Portfolio/26-01-02%2019-25-22%20127.jpg" alt="" loading="lazy" />
    </div>
    <div class="section-banner-inner">
      <div class="section-banner-meta">
        <span>02 / Portfolio</span>
      </div>
      <h2 class="showcase-title section-banner-title">Recent Work</h2>
      <div class="section-banner-footer">
        <span>{showcaseImages.length} featured pieces</span>
        <a href="/artists">View all artists <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </div>

  <!-- Featured Work: Visual Showcase -->
  <section class="showcase-section relative z-20" data-scroll-section>
    <!-- Bordered image cells grid -->
    <div class="showcase-grid grid grid-cols-2 md:grid-cols-3">
	      {showcaseImages.map((img) => (
          <a
            href={`/artists/${img.artistId}`}
            class="showcase-item group relative block border-b border-r border-border p-2 md:p-3"
            data-analytics-event="portfolio_image_click"
            data-analytics-location="home_recent_work"
            data-analytics-artist={img.artistId}
            data-analytics-href={`/artists/${img.artistId}`}
          >
            <div class="relative overflow-hidden aspect-[4/5]">
              <img
                src={img.src}
              alt={`Tattoo by ${img.artist}`}
              loading="lazy"
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
              <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <span class="absolute bottom-3 left-3 font-mono text-[10px] uppercase tracking-widest text-white/90 opacity-0 group-hover:opacity-100 translate-y-2 group-hover:translate-y-0 transition-all duration-300">{img.artist} · View artist</span>
            </div>
          </a>
        ))}
    </div>
  </section>

  <!-- Section Title Banner: Process -->
  <div class="section-banner section-banner--image section-banner--process relative z-20 border-t border-b border-border overflow-hidden" data-scroll-section>
    <div class="grid-dot" style="left:25%;top:0"></div>
    <div class="grid-dot" style="left:50%;top:0"></div>
    <div class="grid-dot" style="left:75%;top:0"></div>
    <div class="grid-dot" style="left:25%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="grid-dot" style="left:50%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="grid-dot" style="left:75%;bottom:0;top:auto;transform:translate(-50%,50%)"></div>
    <div class="absolute inset-0 noise pointer-events-none"></div>
    <div class="section-banner-image" aria-hidden="true">
      <img src="/artists/Christy-Lumberg/Portfolio/26-01-02%2019-30-50%20139.jpg" alt="" loading="lazy" />
    </div>
    <div class="section-banner-inner">
      <div class="section-banner-meta">
        <span>03 / Process</span>
      </div>
      <h2 class="process-title section-banner-title">The Process</h2>
      <div class="section-banner-footer">
        <span>From idea to ink</span>
        <a
          href="/booking"
          data-analytics-event="booking_cta_click"
          data-analytics-location="home_process_banner"
          data-analytics-label="Request a Consult"
          data-analytics-href="/booking"
        >
          Request a consult <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Process Section: Bordered Grid -->
  <section id="process" class="process-section relative z-20" data-scroll-section>
    <div class="process-grid grid grid-cols-1 md:grid-cols-2">
      {[
        { num: '01', title: 'Consultation', desc: 'Share your vision. We shape your idea together and match you with the right artist.' },
        { num: '02', title: 'Design', desc: 'Your artist creates a custom piece tailored to your body and style.' },
        { num: '03', title: 'Session', desc: 'Get inked in our clean, comfortable studio with experienced professionals.' },
        { num: '04', title: 'Aftercare', desc: 'We guide you through healing so your artwork stays vibrant for life.' }
      ].map((step, i) => (
        <div class="process-step group relative border-b border-r border-border p-8 md:p-12 lg:p-16 flex flex-col justify-between min-h-[280px] md:min-h-[360px] hover:bg-secondary/20 transition-colors duration-500">
          <!-- Corner dot -->
          <div class="absolute top-0 right-0 w-1.5 h-1.5 rounded-full bg-primary/25 translate-x-1/2 -translate-y-1/2"></div>

          <div class="flex items-start justify-between">
            <span class="process-num font-mono text-[11px] text-primary/40 tabular-nums tracking-wider">
              {step.num}
            </span>
          </div>

          <div>
            <h3 class="font-sans text-3xl md:text-4xl lg:text-5xl font-extralight text-foreground tracking-tight mb-5">
              {step.title}
            </h3>
            <p class="font-mono text-sm text-muted-foreground leading-relaxed max-w-sm">
              {step.desc}
            </p>
          </div>
        </div>
      ))}
    </div>
  </section>


  <EditorialFooter />

  </div>

  <!-- Micro-interactions & Hover Styles -->
  <style>
    /* === Marquee === */
    .marquee-track {
      overflow: hidden;
      mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
      -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    }

    .marquee-scroll {
      display: flex;
      gap: 0.75rem;
      width: max-content;
      animation: marquee-left 40s linear infinite;
    }

    .marquee-reverse .marquee-scroll {
      animation: marquee-right 45s linear infinite;
    }

    .marquee-item {
      position: relative;
      width: 240px;
      height: 180px;
      flex-shrink: 0;
      overflow: hidden;
      border-radius: 2px;
    }

    @media (min-width: 768px) {
      .marquee-item {
        width: 320px;
        height: 220px;
      }
    }

    .marquee-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .marquee-item:hover img {
      transform: scale(1.08);
    }

    .marquee-credit {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 6px 10px;
      font-family: 'Geist Mono', monospace;
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: white;
      background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .marquee-item:hover .marquee-credit {
      opacity: 1;
    }

    @keyframes marquee-left {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    @keyframes marquee-right {
      0% { transform: translateX(-50%); }
      100% { transform: translateX(0); }
    }

    /* Pause marquee on hover */
    .marquee-track:hover .marquee-scroll {
      animation-play-state: paused;
    }

    /* === Showcase Grid === */
    .showcase-item:nth-child(3n) {
      border-right: none;
    }

    .showcase-item {
      color: inherit;
    }

    @media (max-width: 767px) {
      .showcase-item:nth-child(3n) {
        border-right: 1px solid var(--border);
      }
      .showcase-item:nth-child(2n) {
        border-right: none;
      }
    }

    /* === Section Banners === */
    .section-banner {
      position: relative;
      min-height: clamp(280px, 30vw, 420px);
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--brand-paper) 2%, transparent), transparent 46%),
        var(--background);
    }

    .section-banner::before {
      display: none;
    }

    .section-banner::after {
      display: none;
    }

    .section-banner-image {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
      opacity: 0.34;
      mix-blend-mode: screen;
      mask-image:
        linear-gradient(90deg, transparent 0 14%, black 34%, black 78%, transparent 100%),
        linear-gradient(180deg, transparent 0 8%, black 28%, black 76%, transparent 100%);
      -webkit-mask-image:
        linear-gradient(90deg, transparent 0 14%, black 34%, black 78%, transparent 100%),
        linear-gradient(180deg, transparent 0 8%, black 28%, black 76%, transparent 100%);
      mask-composite: intersect;
      -webkit-mask-composite: source-in;
    }

    .section-banner-image::after {
      content: '';
