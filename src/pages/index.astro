  <!-- Scroll Animations -->
  <script>
    // Wait for GSAP to be available
    const initAnimations = () => {
      const gsap = window.gsap;
      const ScrollTrigger = window.ScrollTrigger;

      if (!gsap || !ScrollTrigger) {
        // Retry if global GSAP isn't ready yet (rare with astro:page-load but possible)
        setTimeout(initAnimations, 50);
        return;
      }

      // Set initial states for hero elements
      gsap.set('.hero-title-line > span', { y: '110%' });
      gsap.set('.hero-reveal', { opacity: 0, y: 30 });
      const studioIntro = document.querySelector('.studio-intro');
      if (studioIntro) {
        gsap.set('.intro-reveal', { opacity: 0, y: 22 });
      }

      // Subtle parallax on hero exterior photo
      const heroSection = document.querySelector('.hero-section');
      const photoLayer = document.querySelector('.hero-photo-layer');

      if (heroSection && photoLayer) {
        heroSection.addEventListener('mousemove', (e) => {
          const xPos = (e.clientX / window.innerWidth - 0.5) * 12;
          const yPos = (e.clientY / window.innerHeight - 0.5) * 8;

          gsap.to(photoLayer, {
            x: xPos,
            y: yPos,
            duration: 1.8,
            ease: 'power2.out'
          });
        });
      }

      // Hero photo reveal - cinematic fade up
      gsap.set('.hero-photo-wrap', { scale: 1.15, opacity: 0 });
      gsap.to('.hero-photo-wrap', {
        scale: 1,
        opacity: 1,
        duration: 2.4,
        ease: 'power3.out',
        delay: 0.1
      });

      // Hero Title Animation on Load
      const heroTl = gsap.timeline({ delay: 0.4 });

      heroTl
        // Title lines sweep up
        .to('.hero-title-line > span', {
          y: '0%',
          duration: 1.4,
          stagger: 0.2,
          ease: 'power4.out'
        })
        // Reveal elements stagger in
        .to('.hero-reveal', {
          opacity: 1,
          y: 0,
          duration: 1,
          stagger: 0.12,
          ease: 'power3.out'
        }, '-=0.8');

      if (studioIntro) {
        gsap.to('.intro-reveal', {
          opacity: 1,
          y: 0,
          stagger: 0.08,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: studioIntro,
            start: 'top 82%'
          }
        });
      }

      // Hero Parallax on Scroll
      gsap.to('.hero-title', {
        yPercent: 20,
        ease: 'none',
        scrollTrigger: {
          trigger: '.hero-section',
          start: 'top top',
          end: 'bottom top',
          scrub: 1
        }
      });

      // Section Banner Animations
      gsap.utils.toArray('.section-banner h2').forEach((title) => {
        gsap.set(title, { opacity: 0, y: 40 });
        gsap.to(title, {
          opacity: 1,
          y: 0,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: title.closest('.section-banner'),
            start: 'top 85%'
          }
        });
      });

      // Artists Section Animations
      gsap.set('.artist-row', { opacity: 0, y: 40 });

      gsap.to('.artist-row', {
        opacity: 1,
        y: 0,
        stagger: 0.08,
        duration: 0.7,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.artists-list',
          start: 'top 80%'
        }
      });

      // Showcase Section Animations
      gsap.set('.showcase-item', { opacity: 0, y: 30, scale: 0.97 });

      gsap.to('.showcase-item', {
        opacity: 1,
        y: 0,
        scale: 1,
        stagger: 0.08,
        duration: 0.7,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.showcase-grid',
          start: 'top 85%'
        }
      });

      // Process Section Animations
      gsap.set('.process-step', { opacity: 0, y: 30 });

      gsap.to('.process-step', {
        opacity: 1,
        y: 0,
        stagger: 0.1,
        duration: 0.8,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: '.process-grid',
          start: 'top 85%'
        }
      });

      // Footer Animations
      gsap.set('.footer-title', { opacity: 0, scale: 0.8 });
      gsap.set('.footer-reveal', { opacity: 0, y: 40 });
      gsap.set('.footer-social', { opacity: 0, scale: 0.5 });

      const footerTl = gsap.timeline({
        scrollTrigger: {
          trigger: '.footer-section',
          start: 'top 80%'
        }
      });

      footerTl
        .to('.footer-title', {
          opacity: 1,
          scale: 1,
          duration: 1,
          ease: 'power4.out'
        })
        .to('.footer-reveal', {
          opacity: 1,
          y: 0,
          stagger: 0.1,
          duration: 0.8,
          ease: 'power3.out'
        }, '-=0.6')
        .to('.footer-social', {
          opacity: 1,
          scale: 1,
          stagger: 0.1,
          duration: 0.5,
          ease: 'back.out(2)'
        }, '-=0.4');

      console.log('Scroll animations initialized');
    };

    // Initialize when DOM is ready
    document.addEventListener('astro:page-load', initAnimations);

    // FloatingCTA visibility is handled by the FloatingCTA component itself
  </script>
</SiteLayout>
