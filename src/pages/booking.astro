---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const artists = await getCollection('artists');
const preselectedArtist = Astro.url.searchParams.get('artist') || '';
---

<SiteLayout
  title="Book a Session"
  description="Request a tattoo appointment with one of our talented artists at United Tattoo in Fountain, CO."
>
  <!-- Page Header -->
  <section class="px-6 md:px-20 mb-12">
    <div class="max-w-3xl">
      <span class="section-label block mb-4">Booking Request</span>
      <h1 class="text-5xl md:text-6xl font-normal tracking-tighter text-white italic mb-6">
        Book a Session
      </h1>
      <p class="text-neutral-400 text-base leading-relaxed max-w-lg">
        Tell us about your tattoo idea. Include reference images and details about placement and size. We'll get back to you within 24–48 hours.
      </p>
    </div>
  </section>

  <!-- Booking Form -->
  <section class="px-6 md:px-20">
    <form
      id="booking-form"
      action="/api/booking"
      method="POST"
      enctype="multipart/form-data"
      class="max-w-3xl space-y-10"
    >
      <!-- Artist Selection -->
      <div class="space-y-6">
        <div class="flex items-center gap-4 border-b border-white/5 pb-4">
          <span class="text-xs text-neutral-500 font-mono">01</span>
          <h2 class="text-xl font-normal italic text-white">Select an Artist</h2>
        </div>

        <div class="space-y-2">
          <label for="artist" class="block text-sm text-neutral-400">Preferred Artist</label>
          <select
            id="artist"
            name="artist"
            required
            class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white focus:border-white/30 focus:outline-none transition-colors"
          >
            <option value="">Select an artist...</option>
            {artists.map((artist) => (
              <option value={artist.id} selected={artist.id === preselectedArtist}>
                {artist.data.name}
              </option>
            ))}
            <option value="no-preference">No preference</option>
          </select>
        </div>
      </div>

      <!-- Contact Information -->
      <div class="space-y-6">
        <div class="flex items-center gap-4 border-b border-white/5 pb-4">
          <span class="text-xs text-neutral-500 font-mono">02</span>
          <h2 class="text-xl font-normal italic text-white">Your Information</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="name" class="block text-sm text-neutral-400">Full Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors"
              placeholder="Your name"
            />
          </div>

          <div class="space-y-2">
            <label for="email" class="block text-sm text-neutral-400">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors"
              placeholder="you@example.com"
            />
          </div>

          <div class="space-y-2">
            <label for="phone" class="block text-sm text-neutral-400">Phone Number</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors"
              placeholder="(555) 123-4567"
            />
          </div>

          <div class="space-y-2">
            <label for="preferred-contact" class="block text-sm text-neutral-400">Preferred Contact Method</label>
            <select
              id="preferred-contact"
              name="preferredContact"
              class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white focus:border-white/30 focus:outline-none transition-colors"
            >
              <option value="email">Email</option>
              <option value="phone">Phone</option>
              <option value="text">Text Message</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Project Details -->
      <div class="space-y-6">
        <div class="flex items-center gap-4 border-b border-white/5 pb-4">
          <span class="text-xs text-neutral-500 font-mono">03</span>
          <h2 class="text-xl font-normal italic text-white">About Your Tattoo</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-2">
            <label for="style" class="block text-sm text-neutral-400">Style</label>
            <select
              id="style"
              name="style"
              required
              class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white focus:border-white/30 focus:outline-none transition-colors"
            >
              <option value="">Select a style...</option>
              <option value="traditional">Traditional</option>
              <option value="neo-traditional">Neo-Traditional</option>
              <option value="realism">Realism</option>
              <option value="black-and-grey">Black and Grey</option>
              <option value="fine-line">Fine Line</option>
              <option value="blackwork">Blackwork</option>
              <option value="japanese">Japanese</option>
              <option value="chicano">Chicano</option>
              <option value="geometric">Geometric</option>
              <option value="illustrative">Illustrative</option>
              <option value="script">Script/Lettering</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="space-y-2">
            <label for="placement" class="block text-sm text-neutral-400">Body Placement</label>
            <input
              type="text"
              id="placement"
              name="placement"
              required
              class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors"
              placeholder="e.g., Inner forearm, left side"
            />
          </div>

          <div class="space-y-2">
            <label for="size" class="block text-sm text-neutral-400">Approximate Size</label>
            <select
              id="size"
              name="size"
              required
              class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white focus:border-white/30 focus:outline-none transition-colors"
            >
              <option value="">Select a size...</option>
              <option value="small">Small (2-3 inches)</option>
              <option value="medium">Medium (4-6 inches)</option>
              <option value="large">Large (7-10 inches)</option>
              <option value="extra-large">Extra Large (11+ inches)</option>
              <option value="half-sleeve">Half Sleeve</option>
              <option value="full-sleeve">Full Sleeve</option>
              <option value="back-piece">Back Piece</option>
            </select>
          </div>

          <div class="space-y-2">
            <label for="budget" class="block text-sm text-neutral-400">Budget Range <span class="text-neutral-600">(optional)</span></label>
            <select
              id="budget"
              name="budget"
              class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white focus:border-white/30 focus:outline-none transition-colors"
            >
              <option value="">Prefer not to say</option>
              <option value="under-200">Under $200</option>
              <option value="200-500">$200 - $500</option>
              <option value="500-1000">$500 - $1,000</option>
              <option value="1000-2000">$1,000 - $2,000</option>
              <option value="2000-plus">$2,000+</option>
            </select>
          </div>
        </div>

        <div class="space-y-2">
          <label for="description" class="block text-sm text-neutral-400">Describe Your Idea</label>
          <textarea
            id="description"
            name="description"
            required
            rows="5"
            class="w-full bg-black/50 border border-white/10 px-4 py-3 text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors resize-none"
            placeholder="Tell us about your tattoo idea. Include any specific elements, colors, or themes you want incorporated..."
          ></textarea>
        </div>
      </div>

      <!-- Reference Images -->
      <div class="space-y-6">
        <div class="flex items-center gap-4 border-b border-white/5 pb-4">
          <span class="text-xs text-neutral-500 font-mono">04</span>
          <h2 class="text-xl font-normal italic text-white">Reference Images</h2>
        </div>

        <div class="space-y-4">
          <p class="text-sm text-neutral-500">
            Upload up to 5 reference images (max 10MB each). Accepted formats: JPG, PNG, WebP, GIF.
          </p>

          <div class="relative">
            <input
              type="file"
              id="references"
              name="references"
              multiple
              accept="image/jpeg,image/png,image/webp,image/gif"
              class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
            />
            <div id="upload-zone" class="border border-dashed border-white/10 p-8 text-center hover:border-white/30 transition-colors">
              <iconify-icon icon="solar:upload-minimalistic-bold" class="text-2xl text-neutral-500 mb-3"></iconify-icon>
              <p class="text-sm text-neutral-400 mb-1">
                Drag & drop images here or click to browse
              </p>
              <p class="text-xs text-neutral-600">
                JPG, PNG, WebP, GIF · Max 5 files · 10MB each
              </p>
            </div>
          </div>

          <div id="file-list" class="space-y-2 hidden">
            <!-- File items will be added here via JavaScript -->
          </div>
        </div>
      </div>

      <!-- Terms & Consent -->
      <div class="space-y-6">
        <div class="flex items-center gap-4 border-b border-white/5 pb-4">
          <span class="text-xs text-neutral-500 font-mono">05</span>
          <h2 class="text-xl font-normal italic text-white">Terms & Consent</h2>
        </div>

        <div class="space-y-4">
          <label class="flex items-start gap-3 cursor-pointer group">
            <input
              type="checkbox"
              name="acceptTerms"
              required
              class="mt-1 w-4 h-4 bg-black/50 border border-white/20 checked:bg-white checked:border-white focus:ring-0"
            />
            <span class="text-sm text-neutral-400 group-hover:text-neutral-300 transition-colors">
              I have read and agree to the <a href="/terms" class="text-white underline hover:no-underline" target="_blank">Terms of Service</a> and <a href="/privacy" class="text-white underline hover:no-underline" target="_blank">Privacy Policy</a>.
            </span>
          </label>

          <label class="flex items-start gap-3 cursor-pointer group">
            <input
              type="checkbox"
              name="acceptAge"
              required
              class="mt-1 w-4 h-4 bg-black/50 border border-white/20 checked:bg-white checked:border-white focus:ring-0"
            />
            <span class="text-sm text-neutral-400 group-hover:text-neutral-300 transition-colors">
              I confirm that I am 18 years of age or older, or will have a parent/guardian present at the appointment.
            </span>
          </label>

          <label class="flex items-start gap-3 cursor-pointer group">
            <input
              type="checkbox"
              name="acceptDeposit"
              class="mt-1 w-4 h-4 bg-black/50 border border-white/20 checked:bg-white checked:border-white focus:ring-0"
            />
            <span class="text-sm text-neutral-400 group-hover:text-neutral-300 transition-colors">
              I understand that a non-refundable deposit may be required to secure my appointment.
            </span>
          </label>
        </div>
      </div>

      <!-- Submit Button -->
      <div class="flex flex-col items-center gap-4 pt-4">
        <button
          type="submit"
          id="submit-btn"
          class="w-full md:w-auto px-12 py-5 bg-white text-black text-sm font-medium tracking-wide hover:bg-neutral-200 transition-all flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          <span id="submit-text">Submit Request</span>
          <iconify-icon id="submit-icon" icon="solar:arrow-right-bold" class="text-lg"></iconify-icon>
          <iconify-icon id="loading-icon" icon="solar:refresh-bold" class="text-lg animate-spin hidden"></iconify-icon>
        </button>

        <p class="text-xs text-neutral-500 text-center">
          We typically respond within 24–48 hours
        </p>
      </div>

      <!-- Error Message -->
      <div id="error-message" class="hidden glass-card p-4 border border-red-500/30 bg-red-500/5">
        <p class="text-sm text-red-400 text-center"></p>
      </div>
    </form>
  </section>

  <script>
    // File upload handling
    const fileInput = document.getElementById('references') as HTMLInputElement;
    const fileList = document.getElementById('file-list') as HTMLDivElement;
    const uploadZone = document.getElementById('upload-zone') as HTMLDivElement;
    const form = document.getElementById('booking-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitText = document.getElementById('submit-text') as HTMLSpanElement;
    const submitIcon = document.getElementById('submit-icon') as HTMLElement;
    const loadingIcon = document.getElementById('loading-icon') as HTMLElement;
    const errorMessage = document.getElementById('error-message') as HTMLDivElement;

    const MAX_FILES = 5;
    const MAX_SIZE = 10 * 1024 * 1024; // 10MB

    let selectedFiles: File[] = [];

    fileInput?.addEventListener('change', () => {
      const files = Array.from(fileInput.files || []);
      handleFiles(files);
    });

    function handleFiles(files: File[]) {
      // Filter valid files
      const validFiles = files.filter(file => {
        if (!file.type.match(/^image\/(jpeg|png|webp|gif)$/)) {
          showError(`Invalid file type: ${file.name}. Only JPG, PNG, WebP, and GIF are allowed.`);
          return false;
        }
        if (file.size > MAX_SIZE) {
          showError(`File too large: ${file.name}. Maximum size is 10MB.`);
          return false;
        }
        return true;
      });

      // Check total count
      const totalFiles = selectedFiles.length + validFiles.length;
      if (totalFiles > MAX_FILES) {
        showError(`Too many files. Maximum is ${MAX_FILES} images.`);
        const allowed = MAX_FILES - selectedFiles.length;
        selectedFiles = [...selectedFiles, ...validFiles.slice(0, allowed)];
      } else {
        selectedFiles = [...selectedFiles, ...validFiles];
      }

      updateFileList();
    }

    function updateFileList() {
      if (selectedFiles.length === 0) {
        fileList.classList.add('hidden');
        return;
      }

      fileList.classList.remove('hidden');
      fileList.innerHTML = selectedFiles.map((file, index) => `
        <div class="flex items-center justify-between bg-white/5 border border-white/10 px-4 py-3">
          <div class="flex items-center gap-3">
            <iconify-icon icon="solar:image-bold" class="text-neutral-400"></iconify-icon>
            <span class="text-sm text-neutral-300 truncate max-w-[200px]">${file.name}</span>
            <span class="text-xs text-neutral-500">${(file.size / 1024 / 1024).toFixed(2)} MB</span>
          </div>
          <button type="button" data-index="${index}" class="remove-file text-neutral-500 hover:text-red-400 transition-colors">
            <iconify-icon icon="solar:close-circle-bold" class="text-lg"></iconify-icon>
          </button>
        </div>
      `).join('');

      // Add remove handlers
      document.querySelectorAll('.remove-file').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
          selectedFiles.splice(index, 1);
          updateFileList();
        });
      });
    }

    function showError(message: string) {
      const errorP = errorMessage.querySelector('p');
      if (errorP) {
        errorP.textContent = message;
      }
      errorMessage.classList.remove('hidden');
      setTimeout(() => {
        errorMessage.classList.add('hidden');
      }, 5000);
    }

    // Form submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Disable button and show loading
      submitBtn.disabled = true;
      submitText.textContent = 'Sending...';
      submitIcon.classList.add('hidden');
      loadingIcon.classList.remove('hidden');
      errorMessage.classList.add('hidden');

      try {
        const formData = new FormData(form);

        // Clear existing file inputs and add our managed files
        formData.delete('references');
        selectedFiles.forEach(file => {
          formData.append('references', file);
        });

        const response = await fetch('/api/booking', {
          method: 'POST',
          body: formData,
        });

        const result = await response.json();

        if (response.ok && result.success) {
          // Redirect to thank you page
          window.location.href = '/booking/thanks';
        } else {
          showError(result.error || 'Something went wrong. Please try again.');
          resetButton();
        }
      } catch (error) {
        showError('Network error. Please check your connection and try again.');
        resetButton();
      }
    });

    function resetButton() {
      submitBtn.disabled = false;
      submitText.textContent = 'Submit Request';
      submitIcon.classList.remove('hidden');
      loadingIcon.classList.add('hidden');
    }
  </script>
</SiteLayout>
