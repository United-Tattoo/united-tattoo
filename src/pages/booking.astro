---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import CustomSelect from '../components/CustomSelect.astro';
import EditorialFooter from '../components/EditorialFooter.astro';
import ScrollIndicator from '../components/ScrollIndicator.astro';
import GridBackground from '../components/GridBackground.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

export const prerender = true;

const artists = await getCollection('artists');
const preselectedArtist = Astro.url.searchParams.get('artist') || '';

// Prepare options for selects
const artistOptions = [
  ...artists.map((artist) => ({
    value: artist.id,
    label: artist.data.name,
    selected: artist.id === preselectedArtist
  })),
  { value: 'no-preference', label: 'No preference', selected: false }
];

const contactOptions = [
  { value: 'email', label: 'Email', selected: true },
  { value: 'phone', label: 'Phone', selected: false },
  { value: 'text', label: 'Text Message', selected: false }
];

const styleOptions = [
  { value: 'traditional', label: 'Traditional', selected: false },
  { value: 'neo-traditional', label: 'Neo-Traditional', selected: false },
  { value: 'realism', label: 'Realism', selected: false },
  { value: 'black-and-grey', label: 'Black and Grey', selected: false },
  { value: 'fine-line', label: 'Fine Line', selected: false },
  { value: 'blackwork', label: 'Blackwork', selected: false },
  { value: 'japanese', label: 'Japanese', selected: false },
  { value: 'chicano', label: 'Chicano', selected: false },
  { value: 'geometric', label: 'Geometric', selected: false },
  { value: 'illustrative', label: 'Illustrative', selected: false },
  { value: 'script', label: 'Script/Lettering', selected: false },
  { value: 'other', label: 'Other', selected: false }
];

const sizeOptions = [
  { value: 'small', label: 'Small (2-3 inches)', selected: false },
  { value: 'medium', label: 'Medium (4-6 inches)', selected: false },
  { value: 'large', label: 'Large (7-10 inches)', selected: false },
  { value: 'extra-large', label: 'Extra Large (11+ inches)', selected: false },
  { value: 'half-sleeve', label: 'Half Sleeve', selected: false },
  { value: 'full-sleeve', label: 'Full Sleeve', selected: false },
  { value: 'back-piece', label: 'Back Piece', selected: false }
];

const budgetOptions = [
  { value: 'under-200', label: 'Under $200', selected: false },
  { value: '200-500', label: '$200 - $500', selected: false },
  { value: '500-1000', label: '$500 - $1,000', selected: false },
  { value: '1000-2000', label: '$1,000 - $2,000', selected: false },
  { value: '2000-plus', label: '$2,000+', selected: false }
];
---

<SiteLayout
  title="Book a Session"
  description="Request a tattoo appointment with one of our talented artists at United Tattoo in Fountain, CO."
  removeMainPadding={true}
  hideFooter={true}
>
  <!-- Hero Section -->
  <section class="booking-hero-section relative min-h-[70vh] flex flex-col justify-center px-6 md:px-12 lg:px-24 pt-32 pb-24 overflow-hidden" data-scroll-section>
    <!-- Background Elements -->
    <div class="absolute inset-0 z-0 pointer-events-none">
      <GridBackground opacity={20} />
      <div class="absolute inset-0 bg-gradient-to-b from-bg-deep via-transparent to-bg-deep/80"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto w-full">
      <div class="booking-hero-reveal mb-12">
        <Breadcrumb
          items={[
            { label: 'Home', href: '/' },
            { label: 'Booking' }
          ]}
        />
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24 items-end">
        <div class="lg:col-span-8">
          <h1 class="booking-hero-title text-[15vw] lg:text-[11vw] leading-[0.85] font-display font-medium tracking-tighter text-white uppercase mb-8">
            <span class="booking-hero-title-line block overflow-hidden"><span class="inline-block">Start</span></span>
            <span class="booking-hero-title-line block overflow-hidden"><span class="inline-block text-neutral-500 italic">Your</span></span>
            <span class="booking-hero-title-line block overflow-hidden"><span class="inline-block">Project</span></span>
          </h1>
        </div>

        <div class="lg:col-span-4 booking-hero-reveal">
          <p class="text-neutral-400 text-lg leading-relaxed font-light max-w-md border-l border-terracotta/50 pl-6">
            Tell us about your idea. We'll match you with the right artist and help bring your vision to life.
          </p>
        </div>
      </div>
    </div>
    
    <ScrollIndicator class="booking-hero-reveal absolute bottom-12 right-12" />
  </section>

  <!-- Form Section -->
  <section class="booking-form-section relative z-20 pb-32" data-scroll-section>
    <form
      id="booking-form"
      action="/api/booking"
      method="POST"
      enctype="multipart/form-data"
      class="max-w-7xl mx-auto px-6 md:px-12 lg:px-24"
    >
      <!-- Section 01: Artist -->
      <div class="form-section-wrapper py-20 lg:py-32 border-t border-white/10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        <div class="lg:col-span-4">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-terracotta block mb-4">01 // Artist</span>
          <h2 class="text-4xl md:text-5xl font-display text-white">Who are you looking to work with?</h2>
        </div>
        <div class="lg:col-span-8 lg:pt-8">
          <CustomSelect
            id="artist"
            name="artist"
            label="Select Artist"
            options={artistOptions}
            required={true}
            placeholder="Choose an artist..."
            hint="Select 'No preference' if you'd like us to recommend an artist based on your style."
          />
        </div>
      </div>

      <!-- Section 02: Contact -->
      <div class="form-section-wrapper py-20 lg:py-32 border-t border-white/10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        <div class="lg:col-span-4">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-terracotta block mb-4">02 // Contact</span>
          <h2 class="text-4xl md:text-5xl font-display text-white">How can we reach you?</h2>
        </div>
        <div class="lg:col-span-8 lg:pt-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16">
            <div class="form-field group">
              <label for="name" class="block font-mono text-[10px] uppercase tracking-widest text-neutral-500 mb-2 group-focus-within:text-white transition-colors">Full Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-transparent border-b border-white/20 py-4 text-white placeholder:text-neutral-700 focus:border-terracotta focus:outline-none transition-colors font-mono text-sm rounded-none"
                placeholder="Enter your full name"
              />
            </div>

            <div class="form-field group">
              <label for="email" class="block font-mono text-[10px] uppercase tracking-widest text-neutral-500 mb-2 group-focus-within:text-white transition-colors">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-transparent border-b border-white/20 py-4 text-white placeholder:text-neutral-700 focus:border-terracotta focus:outline-none transition-colors font-mono text-sm rounded-none"
                placeholder="email@example.com"
              />
            </div>

            <div class="form-field group">
              <label for="phone" class="block font-mono text-[10px] uppercase tracking-widest text-neutral-500 mb-2 group-focus-within:text-white transition-colors">Phone Number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full bg-transparent border-b border-white/20 py-4 text-white placeholder:text-neutral-700 focus:border-terracotta focus:outline-none transition-colors font-mono text-sm rounded-none"
                placeholder="(555) 123-4567"
              />
            </div>

            <div class="form-field">
              <CustomSelect
                id="preferred-contact"
                name="preferredContact"
                label="Preferred Contact Method"
                options={contactOptions}
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Section 03: Details -->
      <div class="form-section-wrapper py-20 lg:py-32 border-t border-white/10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        <div class="lg:col-span-4">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-terracotta block mb-4">03 // Details</span>
          <h2 class="text-4xl md:text-5xl font-display text-white">Tell us about the piece</h2>
        </div>
        <div class="lg:col-span-8 lg:pt-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16 mb-16">
            <div class="form-field">
              <CustomSelect
                id="style"
                name="style"
                label="Tattoo Style"
                options={styleOptions}
                required={true}
                placeholder="Select style..."
              />
            </div>

            <div class="form-field group">
              <label for="placement" class="block font-mono text-[10px] uppercase tracking-widest text-neutral-500 mb-2 group-focus-within:text-white transition-colors">Body Placement</label>
              <input
                type="text"
                id="placement"
                name="placement"
                required
                class="w-full bg-transparent border-b border-white/20 py-4 text-white placeholder:text-neutral-700 focus:border-terracotta focus:outline-none transition-colors font-mono text-sm rounded-none"
                placeholder="e.g. Inner forearm"
              />
            </div>

            <div class="form-field">
              <CustomSelect
                id="size"
                name="size"
                label="Approximate Size"
                options={sizeOptions}
                required={true}
                placeholder="Select size..."
              />
            </div>

            <div class="form-field">
              <CustomSelect
                id="budget"
                name="budget"
                label="Budget Range"
                options={budgetOptions}
                placeholder="Optional"
              />
            </div>
          </div>

          <div class="form-field group mb-16">
            <label for="availability" class="block font-mono text-[10px] uppercase tracking-widest text-neutral-500 mb-2 group-focus-within:text-white transition-colors">Preferred Dates / Times</label>
            <input
              type="text"
              id="availability"
              name="availability"
              class="w-full bg-transparent border-b border-white/20 py-4 text-white placeholder:text-neutral-700 focus:border-terracotta focus:outline-none transition-colors font-mono text-sm rounded-none"
              placeholder="e.g. Weekends in March, Tuesdays after 4pm"
            />
          </div>

          <div class="form-field group">
            <label for="description" class="block font-mono text-[10px] uppercase tracking-widest text-neutral-500 mb-2 group-focus-within:text-white transition-colors">Description</label>
            <textarea
              id="description"
              name="description"
              required
              rows="4"
              class="w-full bg-transparent border-b border-white/20 py-4 text-white placeholder:text-neutral-700 focus:border-terracotta focus:outline-none transition-colors resize-none font-mono text-sm leading-relaxed rounded-none"
              placeholder="Describe your idea in detail..."
            ></textarea>
          </div>
        </div>
      </div>

      <!-- Section 04: References -->
      <div class="form-section-wrapper py-20 lg:py-32 border-t border-white/10 grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        <div class="lg:col-span-4">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-terracotta block mb-4">04 // Visuals</span>
          <h2 class="text-4xl md:text-5xl font-display text-white">Reference Images</h2>
          <p class="mt-6 text-neutral-400 font-light leading-relaxed">
            Upload up to 5 images to help us understand your vision. These can be photos of other tattoos, artwork, or placement photos.
          </p>
        </div>
        <div class="lg:col-span-8 lg:pt-8">
          <div class="relative group">
            <input
              type="file"
              id="references"
              name="references"
              multiple
              accept="image/jpeg,image/png,image/webp,image/gif"
              class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
            />
            <div id="upload-zone" class="border border-dashed border-white/20 p-12 lg:p-20 text-center transition-all duration-300 group-hover:border-terracotta/50 group-hover:bg-white/[0.02]">
              <div class="mb-6 inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/5 border border-white/10 group-hover:scale-110 group-hover:border-terracotta/50 transition-all duration-300">
                <iconify-icon icon="solar:upload-minimalistic-bold" class="text-2xl text-neutral-400 group-hover:text-terracotta transition-colors"></iconify-icon>
              </div>
              <p class="font-display text-xl text-white mb-2">Click or drag images here</p>
              <p class="font-mono text-xs text-neutral-500">Max 5 files (JPG, PNG, WebP) · 10MB limit</p>
            </div>
          </div>
          <div id="file-list" class="space-y-3 mt-6 hidden"></div>
        </div>
      </div>

      <!-- Section 05: Submit -->
      <div class="form-section-wrapper py-20 border-t border-white/10">
        <div class="max-w-3xl mx-auto">
          <div class="space-y-6 mb-16">
            <label class="flex items-start gap-4 cursor-pointer group">
              <div class="relative mt-1">
                <input type="checkbox" name="acceptTerms" required class="peer sr-only" />
                <div class="w-5 h-5 border border-white/20 peer-checked:bg-terracotta peer-checked:border-terracotta transition-all flex items-center justify-center">
                  <iconify-icon icon="solar:check-bold" class="text-white text-xs opacity-0 peer-checked:opacity-100"></iconify-icon>
                </div>
              </div>
              <span class="font-mono text-xs text-neutral-400 group-hover:text-neutral-300 transition-colors leading-relaxed">
                I agree to the <a href="/terms" class="text-white underline decoration-white/30 hover:decoration-white underline-offset-4">Terms of Service</a> & <a href="/privacy" class="text-white underline decoration-white/30 hover:decoration-white underline-offset-4">Privacy Policy</a>.
              </span>
            </label>
            
            <label class="flex items-start gap-4 cursor-pointer group">
              <div class="relative mt-1">
                <input type="checkbox" name="acceptAge" required class="peer sr-only" />
                <div class="w-5 h-5 border border-white/20 peer-checked:bg-terracotta peer-checked:border-terracotta transition-all flex items-center justify-center">
                  <iconify-icon icon="solar:check-bold" class="text-white text-xs opacity-0 peer-checked:opacity-100"></iconify-icon>
                </div>
              </div>
              <span class="font-mono text-xs text-neutral-400 group-hover:text-neutral-300 transition-colors leading-relaxed">
                I confirm I am 18+ years old.
              </span>
            </label>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-white text-black font-mono text-sm uppercase tracking-[0.2em] py-6 hover:bg-terracotta hover:text-white transition-all duration-300 flex items-center justify-center gap-4 disabled:opacity-50 disabled:cursor-not-allowed group"
          >
            <span id="submit-text">Send Request</span>
            <iconify-icon id="submit-icon" icon="solar:arrow-right-linear" class="text-lg group-hover:translate-x-1 transition-transform"></iconify-icon>
            <iconify-icon id="loading-icon" icon="solar:refresh-bold" class="text-lg animate-spin hidden"></iconify-icon>
          </button>
          
          <div id="error-message" class="hidden mt-8 p-4 border border-red-500/20 bg-red-500/5 text-center">
            <p class="font-mono text-xs text-red-400"></p>
          </div>
        </div>
      </div>
    </form>
  </section>

  <EditorialFooter />

  <script>
    // File upload and Form handling
    const fileInput = document.getElementById('references') as HTMLInputElement;
    const fileList = document.getElementById('file-list') as HTMLDivElement;
    const uploadZone = document.getElementById('upload-zone') as HTMLDivElement;
    const form = document.getElementById('booking-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const submitText = document.getElementById('submit-text') as HTMLSpanElement;
    const submitIcon = document.getElementById('submit-icon') as HTMLElement;
    const loadingIcon = document.getElementById('loading-icon') as HTMLElement;
    const errorMessage = document.getElementById('error-message') as HTMLDivElement;

    const MAX_FILES = 5;
    const MAX_SIZE = 10 * 1024 * 1024; // 10MB
    let selectedFiles: File[] = [];

    fileInput?.addEventListener('change', () => {
      const files = Array.from(fileInput.files || []);
      handleFiles(files);
    });

    // Drag and drop visual feedback
    uploadZone?.addEventListener('dragover', (e) => {
      e.preventDefault();
      uploadZone.classList.add('border-terracotta', 'bg-white/5');
    });

    uploadZone?.addEventListener('dragleave', (e) => {
      e.preventDefault();
      uploadZone.classList.remove('border-terracotta', 'bg-white/5');
    });

    uploadZone?.addEventListener('drop', (e) => {
      e.preventDefault();
      uploadZone.classList.remove('border-terracotta', 'bg-white/5');
      if (e.dataTransfer?.files) {
        handleFiles(Array.from(e.dataTransfer.files));
      }
    });

    function handleFiles(files: File[]) {
      const validFiles = files.filter(file => {
        if (!file.type.match(/^image\/(jpeg|png|webp|gif)$/)) {
          showError(`Invalid type: ${file.name}`);
          return false;
        }
        if (file.size > MAX_SIZE) {
          showError(`Too large: ${file.name}`);
          return false;
        }
        return true;
      });

      const totalFiles = selectedFiles.length + validFiles.length;
      if (totalFiles > MAX_FILES) {
        showError(`Max ${MAX_FILES} images allowed`);
        const allowed = MAX_FILES - selectedFiles.length;
        selectedFiles = [...selectedFiles, ...validFiles.slice(0, allowed)];
      } else {
        selectedFiles = [...selectedFiles, ...validFiles];
      }
      updateFileList();
    }

    function updateFileList() {
      if (selectedFiles.length === 0) {
        fileList.classList.add('hidden');
        return;
      }
      fileList.classList.remove('hidden');
      fileList.innerHTML = selectedFiles.map((file, index) => `
        <div class="flex items-center justify-between bg-white/5 border border-white/10 px-4 py-3 group hover:border-white/20 transition-colors">
          <div class="flex items-center gap-3">
            <iconify-icon icon="solar:gallery-bold" class="text-neutral-500 group-hover:text-terracotta transition-colors"></iconify-icon>
            <span class="font-mono text-xs text-neutral-300 truncate max-w-[200px]">${file.name}</span>
          </div>
          <button type="button" data-index="${index}" class="remove-file text-neutral-500 hover:text-red-400 transition-colors p-1">
            <iconify-icon icon="solar:trash-bin-minimalistic-bold"></iconify-icon>
          </button>
        </div>
      `).join('');

      document.querySelectorAll('.remove-file').forEach(btn => {
        btn.addEventListener('click', (e) => {
          const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
          selectedFiles.splice(index, 1);
          updateFileList();
        });
      });
    }

    function showError(message: string) {
      const errorP = errorMessage.querySelector('p');
      if (errorP) errorP.textContent = message;
      errorMessage.classList.remove('hidden');
      setTimeout(() => errorMessage.classList.add('hidden'), 5000);
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitText.textContent = 'Processing...';
      submitIcon.classList.add('hidden');
      loadingIcon.classList.remove('hidden');
      errorMessage.classList.add('hidden');

      try {
        const formData = new FormData(form);
        formData.delete('references');
        selectedFiles.forEach(file => formData.append('references', file));

        const response = await fetch('/api/booking', { method: 'POST', body: formData });
        const result = await response.json();

        if (response.ok && result.success) {
          window.location.href = '/booking/thanks';
        } else {
          showError(result.error || 'Something went wrong');
          resetButton();
        }
      } catch (error) {
        showError('Network error');
        resetButton();
      }
    });

    function resetButton() {
      submitBtn.disabled = false;
      submitText.textContent = 'Send Request';
      submitIcon.classList.remove('hidden');
      loadingIcon.classList.add('hidden');
    }

    // Animations
    const initAnimations = () => {
      const gsap = (window as any).gsap;
      const ScrollTrigger = (window as any).ScrollTrigger;
      if (!gsap || !ScrollTrigger) { setTimeout(initAnimations, 100); return; }

      gsap.set('.booking-hero-title-line > span', { y: '100%' });
      gsap.set('.booking-hero-reveal', { opacity: 0, y: 20 });
      
      const tl = gsap.timeline({ delay: 0.2 });
      tl.to('.booking-hero-title-line > span', { y: '0%', duration: 1, stagger: 0.1, ease: 'power3.out' })
        .to('.booking-hero-reveal', { opacity: 1, y: 0, duration: 0.8, stagger: 0.05, ease: 'power2.out' }, '-=0.5');

      gsap.utils.toArray('.form-section-wrapper').forEach((section: any) => {
        gsap.from(section, {
          opacity: 0,
          y: 40,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: { trigger: section, start: 'top 80%' }
        });
      });
    };
    document.addEventListener('DOMContentLoaded', initAnimations);
  </script>
</SiteLayout>