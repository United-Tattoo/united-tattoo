---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';

export const prerender = true;

const artists = await getCollection('artists');
const preselectedArtist = Astro.url.searchParams.get('artist') || '';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Book a Session | {SITE_TITLE}</title>
		<meta name="description" content="Request a tattoo appointment with one of our talented artists at United Tattoo in Fountain, CO." />
		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<!-- Icons -->
		<script src="https://code.iconify.design/iconify-icon/1.0.7/iconify-icon.min.js"></script>
	</head>
	<body class="bg-bg-deep text-text-main selection:bg-white/20 selection:text-white">
		<!-- Background Elements -->
		<div class="fixed inset-0 noise pointer-events-none z-50"></div>
		<div class="fixed inset-0 bg-grid pointer-events-none -z-10"></div>

		<!-- Technical Banner -->
		<div class="fixed top-0 left-0 w-full h-8 bg-[#0a0a0a] border-b border-white/5 z-[70] flex items-center justify-center overflow-hidden">
			<div class="flex items-center gap-4 animate-in fade-in slide-in-from-top-4 duration-700">
				<span class="relative flex h-1.5 w-1.5">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white/40 opacity-75"></span>
					<span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span>
				</span>
				<p class="font-mono text-[9px] uppercase tracking-[0.2em] text-neutral-400">
					[System Status: <span class="text-white">Active</span>] &nbsp; | &nbsp; Now booking for <span class="text-white italic">February 2026</span>
				</p>
			</div>
		</div>

		<!-- Navigation -->
		<nav class="fixed top-8 left-0 w-full px-6 py-4 flex justify-between items-center z-[60] glass-card border-x-0 border-t-0 bg-black/40 backdrop-blur-md">
			<div class="flex items-center gap-4">
				<a href="/" class="font-display text-3xl font-normal tracking-tighter leading-none hover:opacity-70 transition-opacity italic">UNITED TATTOO</a>
				<div class="hidden lg:block w-[1px] h-4 bg-white/10 mx-2"></div>
				<span class="hidden lg:block font-mono text-[9px] text-neutral-500 tracking-[0.3em] uppercase">38.6942° N, 104.7008° W</span>
			</div>

			<div class="hidden md:flex gap-10 font-mono text-[10px] uppercase tracking-[0.25em] items-center text-neutral-400">
				<a href="/artists" class="hover:text-white transition-colors">[ Artists ]</a>
				<a href="/#process" class="hover:text-white transition-colors">[ Process ]</a>
				<span class="relative px-6 py-2 bg-white text-black rounded-sm font-bold flex items-center gap-2">
					BOOK SESSION
					<iconify-icon icon="solar:arrow-right-up-linear" class="text-sm"></iconify-icon>
				</span>
			</div>

			<button class="md:hidden text-[10px] uppercase font-mono border border-white/20 px-4 py-1.5 rounded-sm bg-white/5">Menu</button>
		</nav>

		<main class="pt-32 pb-24">
			<!-- Page Header -->
			<section class="px-6 md:px-20 mb-16">
				<div class="space-y-4 max-w-3xl">
					<div class="flex items-center gap-3">
						<span class="font-mono text-[10px] text-white bg-white/10 px-2 py-0.5 rounded-sm uppercase tracking-widest">[ BOOKING_REQUEST ]</span>
						<div class="w-12 h-[1px] bg-white/20"></div>
					</div>
					<h1 class="text-5xl md:text-7xl font-normal tracking-tighter text-white italic">Book a Session</h1>
					<p class="font-mono text-[11px] text-neutral-400 uppercase tracking-wider max-w-lg">
						Submit your booking request below. Include reference images and your vision for the piece. We'll get back to you within 48 hours.
					</p>
				</div>
			</section>

			<!-- Booking Form -->
			<section class="px-6 md:px-20">
				<form
					id="booking-form"
					action="/api/booking"
					method="POST"
					enctype="multipart/form-data"
					class="max-w-3xl space-y-8"
				>
					<!-- Artist Selection -->
					<div class="glass-card p-6 space-y-6">
						<div class="flex items-center gap-3 mb-4">
							<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-widest">[ STEP_01 ]</span>
							<span class="font-mono text-[11px] text-white uppercase tracking-wider">Select Artist</span>
						</div>

						<div class="space-y-2">
							<label for="artist" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Preferred Artist *</label>
							<select
								id="artist"
								name="artist"
								required
								class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white focus:border-white/30 focus:outline-none transition-colors"
							>
								<option value="">Select an artist...</option>
								{artists.map((artist) => (
									<option value={artist.id} selected={artist.id === preselectedArtist}>
										{artist.data.name}
									</option>
								))}
								<option value="no-preference">No preference</option>
							</select>
						</div>
					</div>

					<!-- Contact Information -->
					<div class="glass-card p-6 space-y-6">
						<div class="flex items-center gap-3 mb-4">
							<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-widest">[ STEP_02 ]</span>
							<span class="font-mono text-[11px] text-white uppercase tracking-wider">Contact Information</span>
						</div>

						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div class="space-y-2">
								<label for="name" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Full Name *</label>
								<input
									type="text"
									id="name"
									name="name"
									required
									class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors"
									placeholder="John Doe"
								/>
							</div>

							<div class="space-y-2">
								<label for="email" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Email *</label>
								<input
									type="email"
									id="email"
									name="email"
									required
									class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors"
									placeholder="john@example.com"
								/>
							</div>

							<div class="space-y-2">
								<label for="phone" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Phone Number *</label>
								<input
									type="tel"
									id="phone"
									name="phone"
									required
									class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors"
									placeholder="(555) 123-4567"
								/>
							</div>

							<div class="space-y-2">
								<label for="preferred-contact" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Preferred Contact Method</label>
								<select
									id="preferred-contact"
									name="preferredContact"
									class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white focus:border-white/30 focus:outline-none transition-colors"
								>
									<option value="email">Email</option>
									<option value="phone">Phone</option>
									<option value="text">Text Message</option>
								</select>
							</div>
						</div>
					</div>

					<!-- Project Details -->
					<div class="glass-card p-6 space-y-6">
						<div class="flex items-center gap-3 mb-4">
							<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-widest">[ STEP_03 ]</span>
							<span class="font-mono text-[11px] text-white uppercase tracking-wider">Project Details</span>
						</div>

						<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
							<div class="space-y-2">
								<label for="style" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Tattoo Style *</label>
								<select
									id="style"
									name="style"
									required
									class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white focus:border-white/30 focus:outline-none transition-colors"
								>
									<option value="">Select a style...</option>
									<option value="traditional">Traditional</option>
									<option value="neo-traditional">Neo-Traditional</option>
									<option value="realism">Realism</option>
									<option value="black-and-grey">Black and Grey</option>
									<option value="fine-line">Fine Line</option>
									<option value="blackwork">Blackwork</option>
									<option value="japanese">Japanese</option>
									<option value="chicano">Chicano</option>
									<option value="geometric">Geometric</option>
									<option value="illustrative">Illustrative</option>
									<option value="script">Script/Lettering</option>
									<option value="other">Other</option>
								</select>
							</div>

							<div class="space-y-2">
								<label for="placement" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Body Placement *</label>
								<input
									type="text"
									id="placement"
									name="placement"
									required
									class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors"
									placeholder="e.g., Inner forearm, left side"
								/>
							</div>

							<div class="space-y-2">
								<label for="size" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Approximate Size *</label>
								<select
									id="size"
									name="size"
									required
									class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white focus:border-white/30 focus:outline-none transition-colors"
								>
									<option value="">Select a size...</option>
									<option value="small">Small (2-3 inches)</option>
									<option value="medium">Medium (4-6 inches)</option>
									<option value="large">Large (7-10 inches)</option>
									<option value="extra-large">Extra Large (11+ inches)</option>
									<option value="half-sleeve">Half Sleeve</option>
									<option value="full-sleeve">Full Sleeve</option>
									<option value="back-piece">Back Piece</option>
								</select>
							</div>

							<div class="space-y-2">
								<label for="budget" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Budget Range</label>
								<select
									id="budget"
									name="budget"
									class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white focus:border-white/30 focus:outline-none transition-colors"
								>
									<option value="">Prefer not to say</option>
									<option value="under-200">Under $200</option>
									<option value="200-500">$200 - $500</option>
									<option value="500-1000">$500 - $1,000</option>
									<option value="1000-2000">$1,000 - $2,000</option>
									<option value="2000-plus">$2,000+</option>
								</select>
							</div>
						</div>

						<div class="space-y-2">
							<label for="description" class="block font-mono text-[10px] text-neutral-400 uppercase tracking-widest">Description of Your Idea *</label>
							<textarea
								id="description"
								name="description"
								required
								rows="5"
								class="w-full bg-black/50 border border-white/10 rounded-sm px-4 py-3 font-mono text-sm text-white placeholder:text-neutral-600 focus:border-white/30 focus:outline-none transition-colors resize-none"
								placeholder="Describe your tattoo idea in detail. Include any specific elements, colors, or themes you want incorporated..."
							></textarea>
						</div>
					</div>

					<!-- Reference Images -->
					<div class="glass-card p-6 space-y-6">
						<div class="flex items-center gap-3 mb-4">
							<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-widest">[ STEP_04 ]</span>
							<span class="font-mono text-[11px] text-white uppercase tracking-wider">Reference Images</span>
						</div>

						<div class="space-y-4">
							<p class="font-mono text-[10px] text-neutral-400 uppercase tracking-wider">
								Upload up to 5 reference images (max 10MB each). Accepted formats: JPG, PNG, WebP, GIF.
							</p>

							<div class="relative">
								<input
									type="file"
									id="references"
									name="references"
									multiple
									accept="image/jpeg,image/png,image/webp,image/gif"
									class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
								/>
								<div id="upload-zone" class="border-2 border-dashed border-white/10 rounded-sm p-8 text-center hover:border-white/30 transition-colors">
									<iconify-icon icon="solar:upload-minimalistic-bold" class="text-3xl text-neutral-500 mb-4"></iconify-icon>
									<p class="font-mono text-[11px] text-neutral-400 uppercase tracking-wider mb-2">
										Drag & drop images here or click to browse
									</p>
									<p class="font-mono text-[9px] text-neutral-600 uppercase tracking-wider">
										JPG, PNG, WebP, GIF • Max 5 files • 10MB each
									</p>
								</div>
							</div>

							<div id="file-list" class="space-y-2 hidden">
								<!-- File items will be added here via JavaScript -->
							</div>
						</div>
					</div>

					<!-- Terms & Consent -->
					<div class="glass-card p-6 space-y-6">
						<div class="flex items-center gap-3 mb-4">
							<span class="font-mono text-[9px] text-neutral-500 uppercase tracking-widest">[ STEP_05 ]</span>
							<span class="font-mono text-[11px] text-white uppercase tracking-wider">Terms & Consent</span>
						</div>

						<div class="space-y-4">
							<label class="flex items-start gap-3 cursor-pointer group">
								<input
									type="checkbox"
									name="acceptTerms"
									required
									class="mt-1 w-4 h-4 bg-black/50 border border-white/20 rounded-sm checked:bg-white checked:border-white focus:ring-0 focus:ring-offset-0"
								/>
								<span class="font-mono text-[10px] text-neutral-400 uppercase tracking-wider leading-relaxed group-hover:text-neutral-300 transition-colors">
									I have read and agree to the <a href="/terms" class="text-white underline hover:no-underline" target="_blank">Terms of Service</a> and <a href="/privacy" class="text-white underline hover:no-underline" target="_blank">Privacy Policy</a>. *
								</span>
							</label>

							<label class="flex items-start gap-3 cursor-pointer group">
								<input
									type="checkbox"
									name="acceptAge"
									required
									class="mt-1 w-4 h-4 bg-black/50 border border-white/20 rounded-sm checked:bg-white checked:border-white focus:ring-0 focus:ring-offset-0"
								/>
								<span class="font-mono text-[10px] text-neutral-400 uppercase tracking-wider leading-relaxed group-hover:text-neutral-300 transition-colors">
									I confirm that I am 18 years of age or older, or will have a parent/guardian present at the appointment. *
								</span>
							</label>

							<label class="flex items-start gap-3 cursor-pointer group">
								<input
									type="checkbox"
									name="acceptDeposit"
									class="mt-1 w-4 h-4 bg-black/50 border border-white/20 rounded-sm checked:bg-white checked:border-white focus:ring-0 focus:ring-offset-0"
								/>
								<span class="font-mono text-[10px] text-neutral-400 uppercase tracking-wider leading-relaxed group-hover:text-neutral-300 transition-colors">
									I understand that a non-refundable deposit may be required to secure my appointment.
								</span>
							</label>
						</div>
					</div>

					<!-- Submit Button -->
					<div class="flex flex-col items-center gap-4">
						<button
							type="submit"
							id="submit-btn"
							class="w-full md:w-auto px-12 py-5 bg-white text-black font-mono font-bold uppercase text-[11px] tracking-[0.2em] hover:bg-neutral-200 transition-all flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed"
						>
							<span id="submit-text">Submit Booking Request</span>
							<iconify-icon id="submit-icon" icon="solar:arrow-right-up-bold" class="text-lg"></iconify-icon>
							<iconify-icon id="loading-icon" icon="solar:refresh-bold" class="text-lg animate-spin hidden"></iconify-icon>
						</button>

						<p class="font-mono text-[9px] text-neutral-500 uppercase tracking-widest text-center">
							We typically respond within 24-48 hours
						</p>
					</div>

					<!-- Error Message -->
					<div id="error-message" class="hidden glass-card p-4 border border-red-500/30 bg-red-500/5">
						<p class="font-mono text-[10px] text-red-400 uppercase tracking-wider text-center"></p>
					</div>
				</form>
			</section>
		</main>

		<!-- Footer -->
		<footer class="py-12 px-6 md:px-20 border-t border-white/5">
			<div class="flex flex-col md:flex-row justify-between items-center gap-8">
				<div class="flex items-center gap-4">
					<div class="w-2 h-2 rounded-full bg-white animate-pulse"></div>
					<span class="font-mono text-[9px] text-neutral-600 uppercase tracking-[0.3em]">System Verified © 2025 United Tattoo Collective.</span>
				</div>
				<div class="flex items-center gap-12">
					<a href="/privacy" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Privacy_Protocol</a>
					<a href="/terms" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Legal_Terms</a>
					<a href="/aftercare" class="font-mono text-[9px] text-neutral-600 hover:text-neutral-400 transition-colors uppercase tracking-[0.3em]">Aftercare</a>
				</div>
			</div>
		</footer>

		<script>
			// File upload handling
			const fileInput = document.getElementById('references') as HTMLInputElement;
			const fileList = document.getElementById('file-list') as HTMLDivElement;
			const uploadZone = document.getElementById('upload-zone') as HTMLDivElement;
			const form = document.getElementById('booking-form') as HTMLFormElement;
			const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
			const submitText = document.getElementById('submit-text') as HTMLSpanElement;
			const submitIcon = document.getElementById('submit-icon') as HTMLElement;
			const loadingIcon = document.getElementById('loading-icon') as HTMLElement;
			const errorMessage = document.getElementById('error-message') as HTMLDivElement;

			const MAX_FILES = 5;
			const MAX_SIZE = 10 * 1024 * 1024; // 10MB

			let selectedFiles: File[] = [];

			fileInput?.addEventListener('change', () => {
				const files = Array.from(fileInput.files || []);
				handleFiles(files);
			});

			function handleFiles(files: File[]) {
				// Filter valid files
				const validFiles = files.filter(file => {
					if (!file.type.match(/^image\/(jpeg|png|webp|gif)$/)) {
						showError(`Invalid file type: ${file.name}. Only JPG, PNG, WebP, and GIF are allowed.`);
						return false;
					}
					if (file.size > MAX_SIZE) {
						showError(`File too large: ${file.name}. Maximum size is 10MB.`);
						return false;
					}
					return true;
				});

				// Check total count
				const totalFiles = selectedFiles.length + validFiles.length;
				if (totalFiles > MAX_FILES) {
					showError(`Too many files. Maximum is ${MAX_FILES} images.`);
					const allowed = MAX_FILES - selectedFiles.length;
					selectedFiles = [...selectedFiles, ...validFiles.slice(0, allowed)];
				} else {
					selectedFiles = [...selectedFiles, ...validFiles];
				}

				updateFileList();
			}

			function updateFileList() {
				if (selectedFiles.length === 0) {
					fileList.classList.add('hidden');
					return;
				}

				fileList.classList.remove('hidden');
				fileList.innerHTML = selectedFiles.map((file, index) => `
					<div class="flex items-center justify-between bg-white/5 border border-white/10 rounded-sm px-4 py-3">
						<div class="flex items-center gap-3">
							<iconify-icon icon="solar:image-bold" class="text-neutral-400"></iconify-icon>
							<span class="font-mono text-[10px] text-neutral-300 uppercase tracking-wider truncate max-w-[200px]">${file.name}</span>
							<span class="font-mono text-[9px] text-neutral-500">${(file.size / 1024 / 1024).toFixed(2)} MB</span>
						</div>
						<button type="button" data-index="${index}" class="remove-file text-neutral-500 hover:text-red-400 transition-colors">
							<iconify-icon icon="solar:close-circle-bold" class="text-lg"></iconify-icon>
						</button>
					</div>
				`).join('');

				// Add remove handlers
				document.querySelectorAll('.remove-file').forEach(btn => {
					btn.addEventListener('click', (e) => {
						const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
						selectedFiles.splice(index, 1);
						updateFileList();
					});
				});
			}

			function showError(message: string) {
				const errorP = errorMessage.querySelector('p');
				if (errorP) {
					errorP.textContent = message;
				}
				errorMessage.classList.remove('hidden');
				setTimeout(() => {
					errorMessage.classList.add('hidden');
				}, 5000);
			}

			// Form submission
			form?.addEventListener('submit', async (e) => {
				e.preventDefault();

				// Disable button and show loading
				submitBtn.disabled = true;
				submitText.textContent = 'Sending...';
				submitIcon.classList.add('hidden');
				loadingIcon.classList.remove('hidden');
				errorMessage.classList.add('hidden');

				try {
					const formData = new FormData(form);

					// Clear existing file inputs and add our managed files
					formData.delete('references');
					selectedFiles.forEach(file => {
						formData.append('references', file);
					});

					const response = await fetch('/api/booking', {
						method: 'POST',
						body: formData,
					});

					const result = await response.json();

					if (response.ok && result.success) {
						// Redirect to thank you page
						window.location.href = '/booking/thanks';
					} else {
						showError(result.error || 'Something went wrong. Please try again.');
						resetButton();
					}
				} catch (error) {
					showError('Network error. Please check your connection and try again.');
					resetButton();
				}
			});

			function resetButton() {
				submitBtn.disabled = false;
				submitText.textContent = 'Submit Booking Request';
				submitIcon.classList.remove('hidden');
				loadingIcon.classList.add('hidden');
			}
		</script>
	</body>
</html>

