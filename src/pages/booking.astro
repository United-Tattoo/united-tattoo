---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import CustomSelect from '../components/CustomSelect.astro';
import EditorialFooter from '../components/EditorialFooter.astro';
import CalendarPicker from '../components/CalendarPicker.astro';
import PageHero from '../components/PageHero.astro';

export const prerender = true;

const artists = await getCollection('artists');
const preselectedArtist = Astro.url.searchParams.get('artist') || '';

// Prepare options for selects
const artistOptions = [
  ...artists.map((artist) => ({
    value: artist.id,
    label: artist.data.name,
    selected: artist.id === preselectedArtist
  })),
  { value: 'no-preference', label: 'No preference', selected: false }
];

const contactOptions = [
  { value: 'email', label: 'Email', selected: true },
  { value: 'phone', label: 'Phone', selected: false },
  { value: 'text', label: 'Text Message', selected: false }
];

const styleOptions = [
  { value: 'traditional', label: 'Traditional', selected: false },
  { value: 'neo-traditional', label: 'Neo-Traditional', selected: false },
  { value: 'realism', label: 'Realism', selected: false },
  { value: 'black-and-grey', label: 'Black and Grey', selected: false },
  { value: 'fine-line', label: 'Fine Line', selected: false },
  { value: 'blackwork', label: 'Blackwork', selected: false },
  { value: 'japanese', label: 'Japanese', selected: false },
  { value: 'chicano', label: 'Chicano', selected: false },
  { value: 'geometric', label: 'Geometric', selected: false },
  { value: 'illustrative', label: 'Illustrative', selected: false },
  { value: 'script', label: 'Script/Lettering', selected: false },
  { value: 'other', label: 'Other', selected: false }
];

const sizeOptions = [
  { value: 'small', label: 'Small (2-3 inches)', selected: false },
  { value: 'medium', label: 'Medium (4-6 inches)', selected: false },
  { value: 'large', label: 'Large (7-10 inches)', selected: false },
  { value: 'extra-large', label: 'Extra Large (11+ inches)', selected: false },
  { value: 'half-sleeve', label: 'Half Sleeve', selected: false },
  { value: 'full-sleeve', label: 'Full Sleeve', selected: false },
  { value: 'back-piece', label: 'Back Piece', selected: false }
];

const budgetOptions = [
  { value: 'under-200', label: 'Under $200', selected: false },
  { value: '200-500', label: '$200 - $500', selected: false },
  { value: '500-1000', label: '$500 - $1,000', selected: false },
  { value: '1000-2000', label: '$1,000 - $2,000', selected: false },
  { value: '2000-plus', label: '$2,000+', selected: false }
];
---

<SiteLayout
  title="Book a Session"
  description="Request a tattoo appointment with one of our talented artists at United Tattoo in Fountain, CO."
  removeMainPadding={true}
  hideFooter={true}
>
  <div class="relative max-w-[1800px] mx-auto border-l border-r border-border">

  <!-- Persistent page grid lines -->
  <div class="page-grid-lines absolute inset-0 z-[1] pointer-events-none hidden lg:block">
    <div class="absolute top-0 bottom-0 left-[25%] w-px bg-border/40"></div>
    <div class="absolute top-0 bottom-0 left-[50%] w-px bg-border/15"></div>
    <div class="absolute top-0 bottom-0 left-[75%] w-px bg-border/40"></div>
  </div>

  <PageHero
    eyebrow="Booking"
    title="Book a Session"
    description="Tell us about your tattoo idea, preferred artist, placement, and timing. We will review the request and follow up with next steps."
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Booking' },
    ]}
    image="/images/united-studio-main.avif"
    imagePosition="center 45%"
    stats={[
      { value: artists.length, label: 'Artists' },
      { value: '24-48h', label: 'Response' },
    ]}
  />

  <!-- Progress Indicator -->
  <div id="booking-progress" class="fixed bottom-5 left-1/2 z-50 w-[calc(100%-2rem)] max-w-2xl -translate-x-1/2 translate-y-24 bg-background/90 backdrop-blur-sm border border-border px-4 py-3 shadow-2xl transition-transform duration-500">
    <div class="flex items-center justify-between gap-4">
      <div class="flex min-w-0 items-center gap-3">
        <a href="/" class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.18em] text-muted-foreground hover:text-foreground transition-colors">
          <iconify-icon icon="solar:arrow-left-linear" class="text-sm"></iconify-icon>
          Home
        </a>
        <span class="hidden sm:block h-4 w-px bg-border"></span>
        <div class="flex min-w-0 items-center gap-2">
          <span class="hidden sm:inline font-mono text-xs text-muted-foreground">YOUR BOOKING</span>
          <span class="font-mono text-xs text-primary truncate" id="progress-step-label">01 — ARTIST</span>
        </div>
      </div>
      <div class="flex items-center gap-1" id="progress-dots">
        <div class="w-2 h-2 rounded-full bg-primary transition-all duration-300" data-step="0"></div>
        <div class="w-2 h-2 rounded-full bg-muted-foreground/40 transition-all duration-300" data-step="1"></div>
        <div class="w-2 h-2 rounded-full bg-muted-foreground/40 transition-all duration-300" data-step="2"></div>
        <div class="w-2 h-2 rounded-full bg-muted-foreground/40 transition-all duration-300" data-step="3"></div>
        <div class="w-2 h-2 rounded-full bg-muted-foreground/40 transition-all duration-300" data-step="4"></div>
      </div>
    </div>
  </div>

  <!-- Form Section -->
  <section class="booking-form-section relative z-20 pb-32" data-scroll-section>
    <form
      id="booking-form"
      action="/api/booking"
      method="POST"
      enctype="multipart/form-data"
      class="max-w-7xl mx-auto px-6 md:px-12 lg:px-24"
    >
      <!-- Section 01: Artist -->
      <div class="form-section-wrapper relative z-[50] py-12 md:py-20 lg:py-32 border-t border-border grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        <div class="lg:col-span-4">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-primary block mb-4">01 // Artist</span>
          <h2 class="text-4xl md:text-5xl font-sans font-extralight text-foreground tracking-tight">Who are you looking to work with?</h2>
        </div>
        <div class="lg:col-span-8 lg:pt-8">
          <CustomSelect
            id="artist"
            name="artist"
            label="Select Artist"
            options={artistOptions}
            required={true}
            placeholder="Choose an artist..."
            hint="Select 'No preference' if you'd like us to recommend an artist based on your style."
          />

          <!-- Calendar Picker (shown when artist is selected) -->
          <div id="calendar-container" class="mt-8 hidden animate-fade-in">
             <label class="block font-mono text-[10px] uppercase tracking-widest text-muted-foreground mb-3 group-focus-within:text-foreground transition-colors">Select Availability</label>
             <CalendarPicker artistId="" />
             <div class="mt-3 text-center">
                <button type="button" id="use-manual-time" class="text-[10px] text-muted-foreground hover:text-primary underline decoration-neutral-500/30 underline-offset-4 transition-colors">
                   Can't find a suitable time? Enter manually
                </button>
             </div>
          </div>

          <!-- Manual Availability Input (shown when no artist selected or manual entry chosen) -->
          <div id="manual-availability-container" class="form-field group mt-8">
            <label for="availability" class="block font-mono text-[10px] uppercase tracking-widest text-muted-foreground mb-2 group-focus-within:text-foreground transition-colors">Preferred Dates / Times</label>
            <input
              type="text"
              id="availability"
              name="availability"
              class="w-full bg-transparent border-b border-input py-4 text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none transition-colors font-mono text-sm rounded-none appearance-none"
              placeholder="e.g. Weekends in March, Tuesdays after 4pm"
            />
          </div>
        </div>
      </div>

      <!-- Section 02: Contact -->
      <div class="form-section-wrapper relative z-[40] py-12 md:py-20 lg:py-32 border-t border-border grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        <div class="lg:col-span-4">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-primary block mb-4">02 // Contact</span>
          <h2 class="text-4xl md:text-5xl font-sans font-extralight text-foreground tracking-tight">How can we reach you?</h2>
        </div>
        <div class="lg:col-span-8 lg:pt-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10 md:gap-y-16">
            <div class="form-field group">
              <label for="name" class="block font-mono text-[10px] uppercase tracking-widest text-muted-foreground mb-2 group-focus-within:text-foreground transition-colors">Full Name</label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full bg-transparent border-b border-input py-4 text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none transition-colors font-mono text-sm rounded-none appearance-none"
                placeholder="Enter your full name"
              />
            </div>

            <div class="form-field group">
              <label for="email" class="block font-mono text-[10px] uppercase tracking-widest text-muted-foreground mb-2 group-focus-within:text-foreground transition-colors">Email Address</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full bg-transparent border-b border-input py-4 text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none transition-colors font-mono text-sm rounded-none appearance-none"
                placeholder="email@example.com"
              />
            </div>

            <div class="form-field group">
              <label for="phone" class="block font-mono text-[10px] uppercase tracking-widest text-muted-foreground mb-2 group-focus-within:text-foreground transition-colors">Phone Number</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                required
                class="w-full bg-transparent border-b border-input py-4 text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none transition-colors font-mono text-sm rounded-none appearance-none"
                placeholder="(555) 123-4567"
              />
            </div>

            <div class="form-field">
              <CustomSelect
                id="preferred-contact"
                name="preferredContact"
                label="Preferred Contact Method"
                options={contactOptions}
              />
            </div>
          </div>
        </div>
      </div>

      <!-- Section 03: Details -->
      <div class="form-section-wrapper relative z-[30] py-12 md:py-20 lg:py-32 border-t border-border grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        <div class="lg:col-span-4">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-primary block mb-4">03 // Details</span>
          <h2 class="text-4xl md:text-5xl font-sans font-extralight text-foreground tracking-tight">Tell us about the piece</h2>
        </div>
        <div class="lg:col-span-8 lg:pt-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10 md:gap-y-16 mb-16">
            <div class="form-field">
              <CustomSelect
                id="style"
                name="style"
                label="Tattoo Style"
                options={styleOptions}
                required={true}
                placeholder="Select style..."
              />
            </div>

            <div class="form-field group">
              <label for="placement" class="block font-mono text-[10px] uppercase tracking-widest text-muted-foreground mb-2 group-focus-within:text-foreground transition-colors">Body Placement</label>
              <input
                type="text"
                id="placement"
                name="placement"
                required
                class="w-full bg-transparent border-b border-input py-4 text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none transition-colors font-mono text-sm rounded-none appearance-none"
                placeholder="e.g. Inner forearm"
              />
            </div>

            <div class="form-field">
              <CustomSelect
                id="size"
                name="size"
                label="Approximate Size"
                options={sizeOptions}
                required={true}
                placeholder="Select size..."
              />
            </div>

            <div class="form-field">
              <CustomSelect
                id="budget"
                name="budget"
                label="Budget Range"
                options={budgetOptions}
                placeholder="Optional"
              />
            </div>
          </div>

          <div class="form-field group">
            <label for="description" class="block font-mono text-[10px] uppercase tracking-widest text-muted-foreground mb-2 group-focus-within:text-foreground transition-colors">Description</label>
            <textarea
              id="description"
              name="description"
              required
              rows="4"
              class="w-full bg-transparent border-b border-input py-4 text-foreground placeholder:text-muted-foreground focus:border-ring focus:outline-none transition-colors resize-none font-mono text-sm leading-relaxed rounded-none appearance-none"
              placeholder="Describe your idea in detail..."
            ></textarea>
          </div>
        </div>
      </div>

      <!-- Section 04: References -->
      <div class="form-section-wrapper relative z-[20] py-12 md:py-20 lg:py-32 border-t border-border grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-24">
        <div class="lg:col-span-4">
          <span class="font-mono text-xs uppercase tracking-[0.2em] text-primary block mb-4">04 // Visuals</span>
          <h2 class="text-4xl md:text-5xl font-sans font-extralight text-foreground tracking-tight">Reference Images</h2>
          <p class="mt-6 text-muted-foreground font-light leading-relaxed">
            Upload up to 5 images to help us understand your vision. These can be photos of other tattoos, artwork, or placement photos.
          </p>
        </div>
        <div class="lg:col-span-8 lg:pt-8">
          <div class="relative group">
            <input
              type="file"
              id="references"
              name="references"
              multiple
              accept="image/jpeg,image/png,image/webp,image/gif"
              class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
            />
            <div id="upload-zone" class="border border-dashed border-input p-12 lg:p-16 text-center transition-all duration-500 group-hover:border-primary/50 group-hover:bg-secondary rounded-lg">
              <div class="mb-6 inline-flex items-center justify-center w-20 h-20 rounded-full bg-secondary border border-border group-hover:scale-110 group-hover:border-primary/50 transition-all duration-500">
                <iconify-icon icon="solar:upload-minimalistic-bold" class="text-3xl text-muted-foreground group-hover:text-primary transition-colors"></iconify-icon>
              </div>
              <p class="font-sans font-extralight text-2xl text-foreground mb-3 group-hover:text-primary/80 transition-colors tracking-tight">Drop your inspiration</p>
              <p class="font-mono text-xs text-muted-foreground tracking-widest uppercase">or click to browse · Max 5 images · 10MB each</p>
              
              <!-- File type badges -->
              <div class="flex justify-center gap-3 mt-6">
                <span class="px-3 py-1 bg-secondary rounded-full font-mono text-[10px] text-muted-foreground">JPG</span>
                <span class="px-3 py-1 bg-secondary rounded-full font-mono text-[10px] text-muted-foreground">PNG</span>
                <span class="px-3 py-1 bg-secondary rounded-full font-mono text-[10px] text-muted-foreground">WEBP</span>
                <span class="px-3 py-1 bg-secondary rounded-full font-mono text-[10px] text-muted-foreground">HEIC</span>
              </div>
            </div>
          </div>
          
          <!-- File Previews -->
          <div id="file-previews" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mt-6 hidden">
            <!-- Thumbnails will be inserted here -->
          </div>
          
          <div id="file-list" class="space-y-3 mt-6 hidden"></div>
        </div>
      </div>

      <!-- Section 05: Submit -->
      <div class="form-section-wrapper relative z-[10] py-12 md:py-20 border-t border-border">
        <div class="max-w-3xl mx-auto">
          <div class="space-y-6 mb-16">
            <label class="flex items-start gap-4 cursor-pointer group">
              <div class="relative mt-1">
                <input type="checkbox" name="acceptTerms" required class="peer sr-only" />
                <div class="w-5 h-5 border border-input peer-checked:bg-primary peer-checked:border-primary transition-all flex items-center justify-center">
                  <iconify-icon icon="solar:check-bold" class="text-foreground text-xs opacity-0 peer-checked:opacity-100"></iconify-icon>
                </div>
              </div>
              <span class="font-mono text-xs text-muted-foreground group-hover:text-secondary-foreground transition-colors leading-relaxed">
                I agree to the <a href="/terms" class="text-foreground underline decoration-white/30 hover:decoration-white underline-offset-4">Terms of Service</a> & <a href="/privacy" class="text-foreground underline decoration-white/30 hover:decoration-white underline-offset-4">Privacy Policy</a>.
              </span>
            </label>
            
            <label class="flex items-start gap-4 cursor-pointer group">
              <div class="relative mt-1">
                <input type="checkbox" name="acceptAge" required class="peer sr-only" />
                <div class="w-5 h-5 border border-input peer-checked:bg-primary peer-checked:border-primary transition-all flex items-center justify-center">
                  <iconify-icon icon="solar:check-bold" class="text-foreground text-xs opacity-0 peer-checked:opacity-100"></iconify-icon>
                </div>
              </div>
              <span class="font-mono text-xs text-muted-foreground group-hover:text-secondary-foreground transition-colors leading-relaxed">
                I confirm I am 18+ years old.
              </span>
            </label>

            <!-- Newsletter Opt-in (Optional) -->
            <label class="flex items-start gap-4 cursor-pointer group">
              <div class="relative mt-1">
                <input type="checkbox" name="subscribeToNewsletter" class="peer sr-only" />
                <div class="w-5 h-5 border border-input peer-checked:bg-primary peer-checked:border-primary transition-all flex items-center justify-center">
                  <iconify-icon icon="solar:check-bold" class="text-foreground text-xs opacity-0 peer-checked:opacity-100"></iconify-icon>
                </div>
              </div>
              <span class="font-mono text-xs text-muted-foreground group-hover:text-secondary-foreground transition-colors leading-relaxed">
                Stay informed about promotions, events, and tattoo inspiration from United Tattoo.
              </span>
            </label>
          </div>

            <button
              type="submit"
              id="submit-btn"
              class="relative w-full bg-foreground text-background font-mono text-sm uppercase tracking-[0.2em] py-6 hover:bg-primary hover:text-primary-foreground transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed group overflow-hidden"
            >
              <span class="relative z-10 flex items-center justify-center gap-4">
                <span id="submit-text">Send Request</span>
                <iconify-icon id="submit-icon" icon="solar:arrow-right-linear" class="text-lg group-hover:translate-x-1 transition-transform"></iconify-icon>
              </span>
              <iconify-icon id="loading-icon" icon="solar:refresh-bold" class="relative z-10 text-lg animate-spin hidden"></iconify-icon>
              <!-- Loading bar -->
              <span id="loading-bar" class="absolute bottom-0 left-0 h-1 bg-primary transition-all duration-300" style="width: 0%"></span>
            </button>
          
          <div id="error-message" class="hidden mt-8 p-4 border border-red-500/20 bg-red-500/5 text-center">
            <p class="font-mono text-xs text-red-400"></p>
          </div>
        </div>
      </div>
    </form>
  </section>

  <!-- Success Modal -->
  <div id="success-modal" class="fixed inset-0 z-[200] bg-background/95 backdrop-blur-sm flex items-center justify-center opacity-0 invisible transition-all duration-700">
    <div class="max-w-2xl mx-auto px-6 text-center transform scale-95 transition-all duration-700" id="success-content">
      <!-- Success Icon with Ring Animation -->
      <div class="mb-10 flex justify-center relative">
        <div class="relative w-32 h-32">
          <!-- Ring animation -->
          <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 100 100">
            <circle
              id="success-ring"
              cx="50"
              cy="50"
              r="46"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
              class="text-primary/20"
            />
            <circle
              id="success-ring-progress"
              cx="50"
              cy="50"
              r="46"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="text-primary"
              stroke-dasharray="289"
              stroke-dashoffset="289"
              stroke-linecap="round"
            />
          </svg>
          <!-- Checkmark -->
          <div class="absolute inset-0 flex items-center justify-center">
            <iconify-icon id="success-check" icon="solar:check-circle-bold" class="text-6xl text-foreground opacity-0 scale-50 transition-all duration-500"></iconify-icon>
          </div>
        </div>
      </div>

      <span class="section-label block mb-6 opacity-0 transform translate-y-6 transition-all duration-600" id="success-label">Request Confirmed</span>

      <h1 class="text-5xl md:text-6xl font-extralight tracking-tight text-foreground mb-6 opacity-0 transform translate-y-6 transition-all duration-600 delay-100" id="success-title">
        Thank You
      </h1>

      <p class="text-muted-foreground text-base mb-4 leading-relaxed opacity-0 transform translate-y-6 transition-all duration-600 delay-200" id="success-message">
        Your booking request has been received. We'll review your details and respond within 24–48 hours.
      </p>

      <p class="text-muted-foreground text-sm mb-12 opacity-0 transform translate-y-6 transition-all duration-600 delay-300" id="success-timing">
        Expect a response via your preferred contact method.
      </p>

      <!-- What's Next -->
      <div class="glass-card p-8 mb-10 text-left opacity-0 transform translate-y-6 transition-all duration-600 delay-400" id="success-next">
        <h2 class="text-lg font-normal italic text-foreground mb-6">What Happens Next</h2>
        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <iconify-icon icon="solar:check-bold" class="text-xs text-primary"></iconify-icon>
            </div>
            <p class="text-sm text-secondary-foreground">Our reception desk reviews your request and reference images</p>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <iconify-icon icon="solar:check-bold" class="text-xs text-primary"></iconify-icon>
            </div>
            <p class="text-sm text-secondary-foreground">Your selected artist reviews the details and reaches out to discuss your vision</p>
          </div>
          <div class="flex items-start gap-4">
            <div class="w-6 h-6 rounded-full bg-primary/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <iconify-icon icon="solar:check-bold" class="text-xs text-primary"></iconify-icon>
            </div>
            <p class="text-sm text-secondary-foreground">We propose dates/times and confirm any deposit details</p>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 opacity-0 transform translate-y-6 transition-all duration-600 delay-500" id="success-actions">
        <a href="/" class="px-10 py-4 bg-foreground text-background text-sm font-medium tracking-[0.15em] uppercase hover:bg-primary hover:text-primary-foreground transition-all duration-300">
          Return Home
        </a>
        <a href="/artists" class="px-10 py-4 border border-input text-foreground text-sm tracking-[0.15em] uppercase hover:bg-secondary transition-all duration-300">
          Browse Artists
        </a>
      </div>
    </div>
  </div>

  <EditorialFooter />

  </div>

  <script>
    const initBooking = () => {
      // File upload and Form handling
      const fileInput = document.getElementById('references') as HTMLInputElement;
      const filePreviews = document.getElementById('file-previews') as HTMLDivElement;
      const fileList = document.getElementById('file-list') as HTMLDivElement;
      const uploadZone = document.getElementById('upload-zone') as HTMLDivElement;
      const form = document.getElementById('booking-form') as HTMLFormElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const submitText = document.getElementById('submit-text') as HTMLSpanElement;
      const submitIcon = document.getElementById('submit-icon') as HTMLElement;
      const loadingIcon = document.getElementById('loading-icon') as HTMLElement;
      const errorMessage = document.getElementById('error-message') as HTMLDivElement;
      
      // Calendar Integration Logic
      const artistInput = form.querySelector('input[name="artist"]');
      const calendarContainer = document.getElementById('calendar-container');
      const manualContainer = document.getElementById('manual-availability-container');
      const manualLink = document.getElementById('use-manual-time');

      // Handle artist selection
      const handleArtistChange = (artistId: string) => {
          if (artistId && artistId !== 'no-preference' && calendarContainer && manualContainer) {
              calendarContainer.classList.remove('hidden');
              manualContainer.classList.add('hidden');
              
              // Show loading state
              const grid = document.getElementById('calendar-grid');
              if (grid) {
                grid.innerHTML = `
                    <div class="col-span-7 flex items-center justify-center py-16">
                    <iconify-icon icon="solar:refresh-bold" class="text-2xl text-primary animate-spin"></iconify-icon>
                    <span class="ml-3 text-muted-foreground text-sm">Loading availability...</span>
                    </div>
                `;
              }

              document.dispatchEvent(new CustomEvent('artist-changed', { detail: { artistId } }));
          } else if (calendarContainer && manualContainer) {
              calendarContainer.classList.add('hidden');
              manualContainer.classList.remove('hidden');
          }
      };

      if (artistInput) {
          artistInput.addEventListener('change', (e) => {
              handleArtistChange((e.target as HTMLInputElement).value);
          });
      }

      // Check for preselected artist on init
      if (artistInput && (artistInput as HTMLInputElement).value && (artistInput as HTMLInputElement).value !== 'no-preference') {
          handleArtistChange((artistInput as HTMLInputElement).value);
      }

      if (manualLink && calendarContainer && manualContainer) {
          manualLink.addEventListener('click', () => {
              calendarContainer.classList.add('hidden');
              manualContainer.classList.remove('hidden');
          });
      }

      document.addEventListener('request-artist-change', (e: any) => {
          const newArtistId = e.detail.artistId;
          const wrapper = document.querySelector('.custom-select-wrapper[data-select-id="artist"]');
          if (wrapper) {
              const option = wrapper.querySelector(`.custom-select-option[data-value="${newArtistId}"]`) as HTMLElement;
              if (option) {
                  option.click();
                  wrapper.scrollIntoView({ behavior: 'smooth', block: 'center' });
              }
          }
      });
      
      // Progress indicator elements
      const progressBar = document.getElementById('booking-progress') as HTMLDivElement;
      const progressStepLabel = document.getElementById('progress-step-label') as HTMLSpanElement;
      const progressDots = document.querySelectorAll('#progress-dots [data-step]');
      
      // Success modal elements
      const successModal = document.getElementById('success-modal') as HTMLDivElement;
      const successContent = document.getElementById('success-content') as HTMLDivElement;

      // Reset state on new page load
      const MAX_FILES = 5;
      const MAX_SIZE = 10 * 1024 * 1024; // 10MB
      let selectedFiles: File[] = [];
      
      const steps = [
        { label: '01 — ARTIST', section: 0 },
        { label: '02 — CONTACT', section: 1 },
        { label: '03 — DETAILS', section: 2 },
        { label: '04 — VISUALS', section: 3 },
        { label: '05 — SUBMIT', section: 4 }
      ];
      
      let currentSection = 0;

      function updateProgress(sectionIndex: number) {
        currentSection = sectionIndex;
        
        // Show progress bar
        if (progressBar && progressBar.classList.contains('translate-y-24')) {
          progressBar.classList.remove('translate-y-24');
          progressBar.classList.add('translate-y-0');
        }
        
        // Update label
        if (progressStepLabel) {
          progressStepLabel.textContent = steps[sectionIndex].label;
        }
        
        // Update dots
        progressDots.forEach((dot, index) => {
          if (index <= sectionIndex) {
            dot.classList.remove('bg-muted-foreground/40');
            dot.classList.add('bg-primary');
            if (index === sectionIndex) {
              dot.classList.add('scale-125');
            } else {
              dot.classList.remove('scale-125');
            }
          } else {
            dot.classList.remove('bg-primary');
            dot.classList.add('bg-muted-foreground/40');
            dot.classList.remove('scale-125');
          }
        });
      }

      function createThumbnail(file: File): Promise<string> {
        return new Promise((resolve) => {
          const reader = new FileReader();
          reader.onload = (e) => resolve(e.target?.result as string);
          reader.readAsDataURL(file);
        });
      }

      async function updateFilePreviews() {
        if (!filePreviews) return;
        
        if (selectedFiles.length === 0) {
          filePreviews.classList.add('hidden');
          filePreviews.innerHTML = '';
          return;
        }
        
        filePreviews.classList.remove('hidden');
        
        const thumbnails = await Promise.all(selectedFiles.map(async (file) => {
          const src = await createThumbnail(file);
          const ext = file.name.split('.').pop()?.toUpperCase() || 'IMG';
          return `
            <div class="relative group/file aspect-square bg-secondary border border-border rounded-lg overflow-hidden animate-fade-in">
              <img src="${src}" alt="${file.name}" class="w-full h-full object-cover" />
              <div class="absolute inset-0 bg-black/60 opacity-0 group-hover/file:opacity-100 transition-opacity flex items-center justify-center gap-2">
                <button type="button" data-remove class="p-2 bg-secondary rounded-full text-foreground hover:bg-red-500/80 transition-colors" title="Remove">
                  <iconify-icon icon="solar:trash-bin-minimalistic-bold"></iconify-icon>
                </button>
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-black/80 px-2 py-1">
                <span class="font-mono text-[10px] text-secondary-foreground truncate block">${file.name}</span>
              </div>
            </div>
          `;
        }));
        
        filePreviews.innerHTML = thumbnails.join('');
        
        // Add remove handlers
        filePreviews.querySelectorAll('[data-remove]').forEach((btn, index) => {
          btn.addEventListener('click', () => {
            selectedFiles.splice(index, 1);
            updateFilePreviews();
            updateFileList();
          });
        });
      }

      function updateFileList() {
        if (!fileList) return;
        if (selectedFiles.length === 0) {
          fileList.classList.add('hidden');
          fileList.innerHTML = '';
          return;
        }
        fileList.classList.remove('hidden');
        fileList.innerHTML = selectedFiles.map((file, index) => `
          <div class="flex items-center justify-between bg-secondary border border-border px-4 py-3 group hover:border-input transition-all duration-300 opacity-0 animate-fade-in">
            <div class="flex items-center gap-3">
              <iconify-icon icon="solar:gallery-bold" class="text-muted-foreground group-hover:text-primary transition-colors"></iconify-icon>
              <span class="font-mono text-xs text-secondary-foreground truncate max-w-[200px]">${file.name}</span>
              <span class="font-mono text-[10px] text-muted-foreground/40">${(file.size / 1024 / 1024).toFixed(1)} MB</span>
            </div>
            <button type="button" data-index="${index}" class="remove-file text-muted-foreground hover:text-red-400 transition-colors p-1">
              <iconify-icon icon="solar:trash-bin-minimalistic-bold"></iconify-icon>
            </button>
          </div>
        `).join('');

        document.querySelectorAll('.remove-file').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
            selectedFiles.splice(index, 1);
            updateFilePreviews();
            updateFileList();
          });
        });
      }

      function showError(message: string) {
        if (!errorMessage) return;
        const errorP = errorMessage.querySelector('p');
        if (errorP) errorP.textContent = message;
        errorMessage.classList.remove('hidden');
        errorMessage.classList.add('animate-shake');
        setTimeout(() => {
          errorMessage.classList.add('hidden');
          errorMessage.classList.remove('animate-shake');
        }, 5000);
      }

      function handleFiles(files: File[]) {
        const validFiles = files.filter(file => {
          if (!file.type.match(/^image\/(jpeg|png|webp|gif)$/)) {
            showError(`Invalid type: ${file.name}`);
            return false;
          }
          if (file.size > MAX_SIZE) {
            showError(`Too large: ${file.name}`);
            return false;
          }
          return true;
        });

        const totalFiles = selectedFiles.length + validFiles.length;
        if (totalFiles > MAX_FILES) {
          showError(`Max ${MAX_FILES} images allowed`);
          const allowed = MAX_FILES - selectedFiles.length;
          selectedFiles = [...selectedFiles, ...validFiles.slice(0, allowed)];
        } else {
          selectedFiles = [...selectedFiles, ...validFiles];
        }
        updateFilePreviews();
        updateFileList();
      }

      function resetButton() {
        if (!submitBtn) return;
        submitBtn.disabled = false;
        if (submitText) submitText.textContent = 'Send Request';
        if (submitIcon) submitIcon.classList.remove('hidden');
        if (loadingIcon) loadingIcon.classList.add('hidden');
      }
      
      function showSuccessModal() {
        if (!successModal || !successContent) return;
        
        // Show modal
        successModal.classList.remove('opacity-0', 'invisible');
        
        // Trigger GSAP animations
        const gsap = (window as any).gsap;
        
        if (gsap) {
          // Ring draw animation
          gsap.to('#success-ring-progress', {
            strokeDashoffset: 0,
            duration: 1,
            ease: 'power2.inOut'
          });
          
          // Checkmark reveal with bounce
          gsap.to('#success-check', {
            opacity: 1,
            scale: 1,
            duration: 0.5,
            ease: 'back.out(2)',
            delay: 0.8
          });
          
          // Staggered content reveal
          gsap.to('#success-label', {
            opacity: 1,
            y: 0,
            duration: 0.6,
            delay: 1
          });
          
          gsap.to('#success-title', {
            opacity: 1,
            y: 0,
            duration: 0.6,
            delay: 1.1
          });
          
          gsap.to('#success-message', {
            opacity: 1,
            y: 0,
            duration: 0.6,
            delay: 1.2
          });
          
          gsap.to('#success-timing', {
            opacity: 1,
            y: 0,
            duration: 0.6,
            delay: 1.3
          });
          
          gsap.to('#success-next', {
            opacity: 1,
            y: 0,
            duration: 0.6,
            delay: 1.4
          });
          
          gsap.to('#success-actions', {
            opacity: 1,
            y: 0,
            duration: 0.6,
            delay: 1.5
          });
        } else {
          // Fallback without GSAP
          const ring = document.getElementById('success-ring-progress');
          if (ring) (ring as HTMLElement).style.strokeDashoffset = '0';
          
          const elements = ['success-check', 'success-label', 'success-title', 'success-message', 'success-timing', 'success-next', 'success-actions'];
          elements.forEach((id) => {
            const el = document.getElementById(id);
            if (el) {
              (el as HTMLElement).style.opacity = '1';
              (el as HTMLElement).style.transform = 'translateY(0)';
            }
          });
        }
        
        // Scroll to top smoothly
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      // Event Listeners
      if (fileInput) {
        fileInput.addEventListener('change', () => {
          const files = Array.from(fileInput.files || []);
          handleFiles(files);
        });
      }

      if (uploadZone) {
        uploadZone.addEventListener('dragover', (e) => {
          e.preventDefault();
          uploadZone.classList.add('border-primary', 'bg-secondary');
          uploadZone.classList.remove('border-input');
        });

        uploadZone.addEventListener('dragleave', (e) => {
          e.preventDefault();
          uploadZone.classList.remove('border-primary', 'bg-secondary');
          uploadZone.classList.add('border-input');
        });

        uploadZone.addEventListener('drop', (e) => {
          e.preventDefault();
          uploadZone.classList.remove('border-primary', 'bg-secondary');
          uploadZone.classList.add('border-input');
          if (e.dataTransfer?.files) {
            handleFiles(Array.from(e.dataTransfer.files));
          }
        });
      }

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (submitBtn) submitBtn.disabled = true;
          if (submitText) submitText.textContent = 'Sending...';
          if (submitIcon) submitIcon.classList.add('hidden');
          if (loadingIcon) loadingIcon.classList.remove('hidden');
          if (errorMessage) errorMessage.classList.add('hidden');
          
          // Animate loading bar
          const loadingBar = document.getElementById('loading-bar') as HTMLElement;
          if (loadingBar) {
            loadingBar.style.width = '70%';
            loadingBar.style.transition = 'width 1.5s ease-out';
          }

          try {
            const formData = new FormData(form);
            formData.delete('references');
            selectedFiles.forEach(file => formData.append('references', file));

            const response = await fetch('/api/booking', { method: 'POST', body: formData });
            const result = await response.json();

            if (response.ok && result.success) {
              // Complete loading animation
              if (loadingBar) {
                loadingBar.style.width = '100%';
                loadingBar.style.transition = 'width 0.3s ease-out';
              }
              
              // Show success modal
              setTimeout(() => showSuccessModal(), 400);
            } else {
              showError(result.error || 'Something went wrong');
              resetButton();
              if (loadingBar) loadingBar.style.width = '0%';
            }
          } catch (error) {
            showError('Network error');
            resetButton();
            if (loadingBar) loadingBar.style.width = '0%';
          }
        });
      }

      // Animations
      const gsap = (window as any).gsap;
      const ScrollTrigger = (window as any).ScrollTrigger;
      if (!gsap || !ScrollTrigger) return;

      gsap.set('.page-hero-title-line > span', { y: '100%' });
      gsap.set('.page-hero-reveal', { opacity: 0, y: 20 });
      
      const tl = gsap.timeline({ delay: 0.2 });
      tl.to('.page-hero-title-line > span', { y: '0%', duration: 1, stagger: 0.1, ease: 'power3.out' })
        .to('.page-hero-reveal', { opacity: 1, y: 0, duration: 0.8, stagger: 0.05, ease: 'power2.out' }, '-=0.5');

      gsap.utils.toArray('.form-section-wrapper').forEach((section: any, index: number) => {
        gsap.from(section, {
          opacity: 0,
          y: 60,
          duration: 1,
          ease: 'power3.out',
          scrollTrigger: { 
            trigger: section, 
            start: 'top 85%',
            onEnter: () => updateProgress(index),
            onEnterBack: () => updateProgress(index)
          }
        });
      });
    };

    document.addEventListener('astro:page-load', initBooking);
  </script>
  
  <style>
    @keyframes fade-in {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
    .animate-fade-in {
      animation: fade-in 0.3s ease-out forwards;
    }
    
    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-4px); }
      75% { transform: translateX(4px); }
    }
    .animate-shake {
      animation: shake 0.3s ease-out;
    }
  </style>
</SiteLayout>
