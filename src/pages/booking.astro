---
import SiteLayout from '../layouts/SiteLayout.astro';
import { getCollection } from 'astro:content';
import CustomSelect from '../components/CustomSelect.astro';
import EditorialFooter from '../components/EditorialFooter.astro';
import CalendarPicker from '../components/CalendarPicker.astro';

export const prerender = true;

const artists = await getCollection('artists');
const preselectedArtist = Astro.url.searchParams.get('artist') || '';

// Prepare options for selects
const artistOptions = [
  ...artists.map((artist) => ({
    value: artist.id,
    label: artist.data.name,
    selected: artist.id === preselectedArtist
  })),
  { value: 'no-preference', label: 'No preference', selected: false }
];

const contactOptions = [
  { value: 'email', label: 'Email', selected: true },
  { value: 'phone', label: 'Phone', selected: false },
  { value: 'text', label: 'Text Message', selected: false }
];

const styleOptions = [
  { value: 'traditional', label: 'Traditional', selected: false },
  { value: 'neo-traditional', label: 'Neo-Traditional', selected: false },
  { value: 'realism', label: 'Realism', selected: false },
  { value: 'black-and-grey', label: 'Black and Grey', selected: false },
  { value: 'fine-line', label: 'Fine Line', selected: false },
  { value: 'blackwork', label: 'Blackwork', selected: false },
  { value: 'japanese', label: 'Japanese', selected: false },
  { value: 'chicano', label: 'Chicano', selected: false },
  { value: 'geometric', label: 'Geometric', selected: false },
  { value: 'illustrative', label: 'Illustrative', selected: false },
  { value: 'script', label: 'Script/Lettering', selected: false },
  { value: 'other', label: 'Other', selected: false }
];

const sizeOptions = [
  { value: 'small', label: 'Small (2-3 inches)', selected: false },
  { value: 'medium', label: 'Medium (4-6 inches)', selected: false },
  { value: 'large', label: 'Large (7-10 inches)', selected: false },
  { value: 'extra-large', label: 'Extra Large (11+ inches)', selected: false },
  { value: 'half-sleeve', label: 'Half Sleeve', selected: false },
  { value: 'full-sleeve', label: 'Full Sleeve', selected: false },
  { value: 'back-piece', label: 'Back Piece', selected: false }
];

const budgetOptions = [
  { value: 'under-200', label: 'Under $200', selected: false },
  { value: '200-500', label: '$200 - $500', selected: false },
  { value: '500-1000', label: '$500 - $1,000', selected: false },
  { value: '1000-2000', label: '$1,000 - $2,000', selected: false },
  { value: '2000-plus', label: '$2,000+', selected: false }
];
---

<SiteLayout
  title="Book a Session"
  description="Request a tattoo appointment with one of our talented artists at United Tattoo in Fountain, CO."
  removeMainPadding={true}
  hideFooter={true}
>
  <!-- Progress Bar (fixed top) -->
  <div id="booking-progress" class="fixed top-0 left-0 right-0 z-[100] h-1 bg-white/5">
    <div id="progress-fill" class="h-full bg-sage transition-all duration-500 ease-out" style="width: 0%"></div>
  </div>

  <!-- Hero Section -->
  <section class="booking-hero min-h-[60vh] flex flex-col justify-end px-6 pt-32 pb-16" data-scroll-section>
    <div class="max-w-[40rem] mx-auto w-full">
      <h1 class="booking-hero-title font-display italic text-white mb-6" style="font-size: var(--text-display-lg); line-height: 0.95; letter-spacing: -0.02em;">
        <span class="booking-title-line block overflow-hidden"><span class="inline-block">Begin Your</span></span>
        <span class="booking-title-line block overflow-hidden"><span class="inline-block">Journey</span></span>
      </h1>
      <p class="booking-hero-subtitle text-text-secondary text-lg leading-relaxed max-w-md opacity-0">
        Tell us about your vision. We'll connect you with the right artist and bring your idea to life.
      </p>
    </div>
  </section>

  <!-- Form Section -->
  <section class="booking-form-section relative z-20 pb-32" data-scroll-section>
    <form
      id="booking-form"
      action="/api/booking"
      method="POST"
      enctype="multipart/form-data"
      class="max-w-[40rem] mx-auto px-6"
    >
      <!-- Section 01: Artist -->
      <div class="form-section py-24 border-t border-white/10" data-section="0">
        <div class="mb-12">
          <span class="section-number block mb-4 text-sage/60 font-mono text-sm tracking-widest">[01]</span>
          <h2 class="text-3xl md:text-4xl font-display italic text-white">Choose Your Artist</h2>
        </div>

        <div class="space-y-8">
          <CustomSelect
            id="artist"
            name="artist"
            label="Select Artist"
            options={artistOptions}
            required={true}
            placeholder="Choose an artist..."
            hint="Select 'No preference' if you'd like us to recommend an artist based on your style."
          />

          <!-- Calendar Picker (shown when artist is selected) -->
          <div id="calendar-container" class="hidden animate-fade-in">
            <label class="block section-label mb-3 group-focus-within:text-white transition-colors">Select Availability</label>
            <CalendarPicker artistId="" />
            <div class="mt-3 text-center">
              <button type="button" id="use-manual-time" class="text-[11px] text-text-muted hover:text-sage underline decoration-white/20 underline-offset-4 transition-colors">
                Can't find a suitable time? Enter manually
              </button>
            </div>
          </div>

          <!-- Manual Availability Input -->
          <div id="manual-availability-container" class="form-field group">
            <label for="availability" class="block section-label mb-3 group-focus-within:text-white transition-colors">Preferred Dates / Times</label>
            <input
              type="text"
              id="availability"
              name="availability"
              class="booking-input"
              placeholder="e.g. Weekends in March, Tuesdays after 4pm"
            />
          </div>
        </div>
      </div>

      <!-- Section 02: Contact -->
      <div class="form-section py-24 border-t border-white/10" data-section="1">
        <div class="mb-12">
          <span class="section-number block mb-4 text-sage/60 font-mono text-sm tracking-widest">[02]</span>
          <h2 class="text-3xl md:text-4xl font-display italic text-white">Your Contact Details</h2>
        </div>

        <div class="space-y-10">
          <div class="form-field group">
            <label for="name" class="block section-label mb-3 group-focus-within:text-white transition-colors">Full Name</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="booking-input"
              placeholder="Enter your full name"
            />
          </div>

          <div class="form-field group">
            <label for="email" class="block section-label mb-3 group-focus-within:text-white transition-colors">Email Address</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="booking-input"
              placeholder="email@example.com"
            />
          </div>

          <div class="form-field group">
            <label for="phone" class="block section-label mb-3 group-focus-within:text-white transition-colors">Phone Number</label>
            <input
              type="tel"
              id="phone"
              name="phone"
              required
              class="booking-input"
              placeholder="(555) 123-4567"
            />
          </div>

          <div class="form-field">
            <CustomSelect
              id="preferred-contact"
              name="preferredContact"
              label="Preferred Contact Method"
              options={contactOptions}
            />
          </div>
        </div>
      </div>

      <!-- Section 03: Details -->
      <div class="form-section py-24 border-t border-white/10" data-section="2">
        <div class="mb-12">
          <span class="section-number block mb-4 text-sage/60 font-mono text-sm tracking-widest">[03]</span>
          <h2 class="text-3xl md:text-4xl font-display italic text-white">About Your Piece</h2>
        </div>

        <div class="space-y-10">
          <div class="form-field">
            <CustomSelect
              id="style"
              name="style"
              label="Tattoo Style"
              options={styleOptions}
              required={true}
              placeholder="Select style..."
            />
          </div>

          <div class="form-field group">
            <label for="placement" class="block section-label mb-3 group-focus-within:text-white transition-colors">Body Placement</label>
            <input
              type="text"
              id="placement"
              name="placement"
              required
              class="booking-input"
              placeholder="e.g. Inner forearm, upper back"
            />
          </div>

          <div class="form-field">
            <CustomSelect
              id="size"
              name="size"
              label="Approximate Size"
              options={sizeOptions}
              required={true}
              placeholder="Select size..."
            />
          </div>

          <div class="form-field">
            <CustomSelect
              id="budget"
              name="budget"
              label="Budget Range"
              options={budgetOptions}
              placeholder="Optional"
            />
          </div>

          <div class="form-field group">
            <label for="description" class="block section-label mb-3 group-focus-within:text-white transition-colors">Description</label>
            <textarea
              id="description"
              name="description"
              required
              rows="5"
              class="booking-input resize-none"
              placeholder="Describe your idea in detail. What does it mean to you? Any specific elements you want included?"
            ></textarea>
          </div>
        </div>
      </div>

      <!-- Section 04: References -->
      <div class="form-section py-24 border-t border-white/10" data-section="3">
        <div class="mb-12">
          <span class="section-number block mb-4 text-sage/60 font-mono text-sm tracking-widest">[04]</span>
          <h2 class="text-3xl md:text-4xl font-display italic text-white">Reference Images</h2>
          <p class="mt-4 text-text-secondary leading-relaxed">
            Upload up to 5 images to help us understand your vision. These can be photos of other tattoos, artwork, or placement photos.
          </p>
        </div>

        <div class="relative group">
          <input
            type="file"
            id="references"
            name="references"
            multiple
            accept="image/jpeg,image/png,image/webp,image/gif"
            class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10"
          />
          <div id="upload-zone" class="border border-dashed border-white/20 p-12 text-center transition-all duration-500 group-hover:border-sage/50 group-hover:bg-white/[0.02] rounded-lg">
            <div class="mb-6 inline-flex items-center justify-center w-16 h-16 rounded-full bg-white/5 border border-white/10 group-hover:scale-110 group-hover:border-sage/50 transition-all duration-500">
              <iconify-icon icon="solar:upload-minimalistic-bold" class="text-2xl text-text-muted group-hover:text-sage transition-colors"></iconify-icon>
            </div>
            <p class="font-display text-xl text-white mb-2 group-hover:text-sage/80 transition-colors italic">Drop your inspiration</p>
            <p class="section-label">or click to browse</p>
            <p class="text-text-muted text-xs mt-2">Max 5 images, 10MB each</p>
          </div>
        </div>

        <!-- File Previews -->
        <div id="file-previews" class="grid grid-cols-2 sm:grid-cols-3 gap-4 mt-6 hidden"></div>
        <div id="file-list" class="space-y-3 mt-6 hidden"></div>
      </div>

      <!-- Section 05: Submit -->
      <div class="form-section py-24 border-t border-white/10" data-section="4">
        <div class="mb-12">
          <span class="section-number block mb-4 text-sage/60 font-mono text-sm tracking-widest">[05]</span>
          <h2 class="text-3xl md:text-4xl font-display italic text-white">Confirm & Submit</h2>
        </div>

        <div class="space-y-6 mb-12">
          <label class="flex items-start gap-4 cursor-pointer group">
            <div class="relative mt-0.5">
              <input type="checkbox" name="acceptTerms" required class="peer sr-only" />
              <div class="w-5 h-5 border border-white/30 peer-checked:bg-sage peer-checked:border-sage transition-all flex items-center justify-center rounded-sm">
                <iconify-icon icon="solar:check-bold" class="text-bg-deep text-xs opacity-0 peer-checked:opacity-100"></iconify-icon>
              </div>
            </div>
            <span class="text-sm text-text-secondary group-hover:text-text-main transition-colors leading-relaxed">
              I agree to the <a href="/terms" class="text-white underline decoration-white/30 hover:decoration-sage hover:text-sage underline-offset-4 transition-colors">Terms of Service</a> & <a href="/privacy" class="text-white underline decoration-white/30 hover:decoration-sage hover:text-sage underline-offset-4 transition-colors">Privacy Policy</a>.
            </span>
          </label>

          <label class="flex items-start gap-4 cursor-pointer group">
            <div class="relative mt-0.5">
              <input type="checkbox" name="acceptAge" required class="peer sr-only" />
              <div class="w-5 h-5 border border-white/30 peer-checked:bg-sage peer-checked:border-sage transition-all flex items-center justify-center rounded-sm">
                <iconify-icon icon="solar:check-bold" class="text-bg-deep text-xs opacity-0 peer-checked:opacity-100"></iconify-icon>
              </div>
            </div>
            <span class="text-sm text-text-secondary group-hover:text-text-main transition-colors leading-relaxed">
              I confirm I am 18+ years old.
            </span>
          </label>

          <label class="flex items-start gap-4 cursor-pointer group">
            <div class="relative mt-0.5">
              <input type="checkbox" name="subscribeToNewsletter" class="peer sr-only" />
              <div class="w-5 h-5 border border-white/30 peer-checked:bg-sage peer-checked:border-sage transition-all flex items-center justify-center rounded-sm">
                <iconify-icon icon="solar:check-bold" class="text-bg-deep text-xs opacity-0 peer-checked:opacity-100"></iconify-icon>
              </div>
            </div>
            <span class="text-sm text-text-secondary group-hover:text-text-main transition-colors leading-relaxed">
              Stay informed about promotions, events, and tattoo inspiration from United Tattoo.
            </span>
          </label>
        </div>

        <button
          type="submit"
          id="submit-btn"
          class="btn-primary w-full justify-center py-5 text-sm disabled:opacity-50 disabled:cursor-not-allowed group overflow-hidden relative"
        >
          <span class="relative z-10 flex items-center justify-center gap-3">
            <span id="submit-text">Send Request</span>
            <iconify-icon id="submit-icon" icon="solar:arrow-right-linear" class="text-lg group-hover:translate-x-1 transition-transform"></iconify-icon>
          </span>
          <iconify-icon id="loading-icon" icon="solar:refresh-bold" class="text-lg animate-spin hidden"></iconify-icon>
        </button>

        <div id="error-message" class="hidden mt-6 p-4 border border-red-500/20 bg-red-500/5 text-center rounded-lg">
          <p class="text-sm text-red-400"></p>
        </div>
      </div>
    </form>
  </section>

  <!-- Success Modal -->
  <div id="success-modal" class="fixed inset-0 z-[200] bg-bg-deep/95 backdrop-blur-sm flex items-center justify-center opacity-0 invisible transition-all duration-700">
    <div class="max-w-xl mx-auto px-6 text-center transform scale-95 transition-all duration-700" id="success-content">
      <!-- Success Icon with Ring Animation -->
      <div class="mb-10 flex justify-center relative">
        <div class="relative w-28 h-28">
          <svg class="absolute inset-0 w-full h-full -rotate-90" viewBox="0 0 100 100">
            <circle
              id="success-ring"
              cx="50"
              cy="50"
              r="46"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
              class="text-sage/20"
            />
            <circle
              id="success-ring-progress"
              cx="50"
              cy="50"
              r="46"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              class="text-sage"
              stroke-dasharray="289"
              stroke-dashoffset="289"
              stroke-linecap="round"
            />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <iconify-icon id="success-check" icon="solar:check-circle-bold" class="text-5xl text-white opacity-0 scale-50 transition-all duration-500"></iconify-icon>
          </div>
        </div>
      </div>

      <span class="section-label block mb-4 opacity-0 transform translate-y-6 transition-all duration-600" id="success-label">Request Confirmed</span>

      <h1 class="font-display italic text-white mb-6 opacity-0 transform translate-y-6 transition-all duration-600 delay-100" id="success-title" style="font-size: var(--text-heading-lg);">
        Thank You
      </h1>

      <p class="text-text-secondary text-base mb-4 leading-relaxed opacity-0 transform translate-y-6 transition-all duration-600 delay-200 max-w-md mx-auto" id="success-message">
        Your booking request has been received. We'll review your details and respond within 24-48 hours.
      </p>

      <p class="text-text-muted text-sm mb-10 opacity-0 transform translate-y-6 transition-all duration-600 delay-300" id="success-timing">
        Expect a response via your preferred contact method.
      </p>

      <!-- What's Next -->
      <div class="glass-card p-6 mb-8 text-left opacity-0 transform translate-y-6 transition-all duration-600 delay-400 rounded-lg" id="success-next">
        <h2 class="text-lg font-display italic text-white mb-5">What Happens Next</h2>
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="w-5 h-5 rounded-full bg-sage/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <iconify-icon icon="solar:check-bold" class="text-[10px] text-sage"></iconify-icon>
            </div>
            <p class="text-sm text-text-secondary">Our team reviews your request and reference images</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-5 h-5 rounded-full bg-sage/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <iconify-icon icon="solar:check-bold" class="text-[10px] text-sage"></iconify-icon>
            </div>
            <p class="text-sm text-text-secondary">Your selected artist reaches out to discuss your vision</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-5 h-5 rounded-full bg-sage/20 flex items-center justify-center flex-shrink-0 mt-0.5">
              <iconify-icon icon="solar:check-bold" class="text-[10px] text-sage"></iconify-icon>
            </div>
            <p class="text-sm text-text-secondary">We confirm dates, times, and deposit details</p>
          </div>
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 opacity-0 transform translate-y-6 transition-all duration-600 delay-500" id="success-actions">
        <a href="/" class="btn-primary">
          Return Home
        </a>
        <a href="/artists" class="btn-secondary">
          Browse Artists
        </a>
      </div>
    </div>
  </div>

  <EditorialFooter />

  <script>
    const initBooking = () => {
      // File upload and Form handling
      const fileInput = document.getElementById('references') as HTMLInputElement;
      const filePreviews = document.getElementById('file-previews') as HTMLDivElement;
      const fileList = document.getElementById('file-list') as HTMLDivElement;
      const uploadZone = document.getElementById('upload-zone') as HTMLDivElement;
      const form = document.getElementById('booking-form') as HTMLFormElement;
      const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
      const submitText = document.getElementById('submit-text') as HTMLSpanElement;
      const submitIcon = document.getElementById('submit-icon') as HTMLElement;
      const loadingIcon = document.getElementById('loading-icon') as HTMLElement;
      const errorMessage = document.getElementById('error-message') as HTMLDivElement;

      // Calendar Integration Logic
      const artistInput = form.querySelector('input[name="artist"]');
      const calendarContainer = document.getElementById('calendar-container');
      const manualContainer = document.getElementById('manual-availability-container');
      const manualLink = document.getElementById('use-manual-time');

      // Handle artist selection
      const handleArtistChange = (artistId: string) => {
        if (artistId && artistId !== 'no-preference' && calendarContainer && manualContainer) {
          calendarContainer.classList.remove('hidden');
          manualContainer.classList.add('hidden');

          // Show loading state
          const grid = document.getElementById('calendar-grid');
          if (grid) {
            grid.innerHTML = `
              <div class="col-span-7 flex items-center justify-center py-16">
                <iconify-icon icon="solar:refresh-bold" class="text-2xl text-sage animate-spin"></iconify-icon>
                <span class="ml-3 text-text-muted text-sm">Loading availability...</span>
              </div>
            `;
          }

          document.dispatchEvent(new CustomEvent('artist-changed', { detail: { artistId } }));
        } else if (calendarContainer && manualContainer) {
          calendarContainer.classList.add('hidden');
          manualContainer.classList.remove('hidden');
        }
      };

      if (artistInput) {
        artistInput.addEventListener('change', (e) => {
          handleArtistChange((e.target as HTMLInputElement).value);
        });
      }

      // Check for preselected artist on init
      if (artistInput && (artistInput as HTMLInputElement).value && (artistInput as HTMLInputElement).value !== 'no-preference') {
        handleArtistChange((artistInput as HTMLInputElement).value);
      }

      if (manualLink && calendarContainer && manualContainer) {
        manualLink.addEventListener('click', () => {
          calendarContainer.classList.add('hidden');
          manualContainer.classList.remove('hidden');
        });
      }

      document.addEventListener('request-artist-change', (e: any) => {
        const newArtistId = e.detail.artistId;
        const wrapper = document.querySelector('.custom-select-wrapper[data-select-id="artist"]');
        if (wrapper) {
          const option = wrapper.querySelector(`.custom-select-option[data-value="${newArtistId}"]`) as HTMLElement;
          if (option) {
            option.click();
            wrapper.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }
        }
      });

      // Progress bar
      const progressFill = document.getElementById('progress-fill') as HTMLDivElement;

      // Success modal elements
      const successModal = document.getElementById('success-modal') as HTMLDivElement;

      // Reset state on new page load
      const MAX_FILES = 5;
      const MAX_SIZE = 10 * 1024 * 1024; // 10MB
      let selectedFiles: File[] = [];

      function updateProgress() {
        const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrolled = window.scrollY;
        const progress = Math.min((scrolled / scrollHeight) * 100, 100);

        if (progressFill) {
          progressFill.style.width = `${progress}%`;
        }
      }

      // Throttled scroll handler
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            updateProgress();
            ticking = false;
          });
          ticking = true;
        }
      });

      function createThumbnail(file: File): Promise<string> {
        return new Promise((resolve) => {
          const reader = new FileReader();
          reader.onload = (e) => resolve(e.target?.result as string);
          reader.readAsDataURL(file);
        });
      }

      async function updateFilePreviews() {
        if (!filePreviews) return;

        if (selectedFiles.length === 0) {
          filePreviews.classList.add('hidden');
          filePreviews.innerHTML = '';
          return;
        }

        filePreviews.classList.remove('hidden');

        const thumbnails = await Promise.all(selectedFiles.map(async (file) => {
          const src = await createThumbnail(file);
          return `
            <div class="relative group/file aspect-square bg-white/5 border border-white/10 rounded-lg overflow-hidden animate-fade-in">
              <img src="${src}" alt="${file.name}" class="w-full h-full object-cover" />
              <div class="absolute inset-0 bg-black/60 opacity-0 group-hover/file:opacity-100 transition-opacity flex items-center justify-center gap-2">
                <button type="button" data-remove class="p-2 bg-white/10 rounded-full text-white hover:bg-red-500/80 transition-colors" title="Remove">
                  <iconify-icon icon="solar:trash-bin-minimalistic-bold"></iconify-icon>
                </button>
              </div>
              <div class="absolute bottom-0 left-0 right-0 bg-black/80 px-2 py-1">
                <span class="font-mono text-[10px] text-neutral-300 truncate block">${file.name}</span>
              </div>
            </div>
          `;
        }));

        filePreviews.innerHTML = thumbnails.join('');

        // Add remove handlers
        filePreviews.querySelectorAll('[data-remove]').forEach((btn, index) => {
          btn.addEventListener('click', () => {
            selectedFiles.splice(index, 1);
            updateFilePreviews();
            updateFileList();
          });
        });
      }

      function updateFileList() {
        if (!fileList) return;
        if (selectedFiles.length === 0) {
          fileList.classList.add('hidden');
          fileList.innerHTML = '';
          return;
        }
        fileList.classList.remove('hidden');
        fileList.innerHTML = selectedFiles.map((file, index) => `
          <div class="flex items-center justify-between bg-white/5 border border-white/10 px-4 py-3 group hover:border-white/20 transition-all duration-300 opacity-0 animate-fade-in rounded-lg">
            <div class="flex items-center gap-3">
              <iconify-icon icon="solar:gallery-bold" class="text-text-muted group-hover:text-sage transition-colors"></iconify-icon>
              <span class="font-mono text-xs text-neutral-300 truncate max-w-[200px]">${file.name}</span>
              <span class="font-mono text-[10px] text-text-muted">${(file.size / 1024 / 1024).toFixed(1)} MB</span>
            </div>
            <button type="button" data-index="${index}" class="remove-file text-text-muted hover:text-red-400 transition-colors p-1">
              <iconify-icon icon="solar:trash-bin-minimalistic-bold"></iconify-icon>
            </button>
          </div>
        `).join('');

        document.querySelectorAll('.remove-file').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const index = parseInt((e.currentTarget as HTMLElement).dataset.index || '0');
            selectedFiles.splice(index, 1);
            updateFilePreviews();
            updateFileList();
          });
        });
      }

      function showError(message: string) {
        if (!errorMessage) return;
        const errorP = errorMessage.querySelector('p');
        if (errorP) errorP.textContent = message;
        errorMessage.classList.remove('hidden');
        errorMessage.classList.add('animate-shake');
        setTimeout(() => {
          errorMessage.classList.add('hidden');
          errorMessage.classList.remove('animate-shake');
        }, 5000);
      }

      function handleFiles(files: File[]) {
        const validFiles = files.filter(file => {
          if (!file.type.match(/^image\/(jpeg|png|webp|gif)$/)) {
            showError(`Invalid type: ${file.name}`);
            return false;
          }
          if (file.size > MAX_SIZE) {
            showError(`Too large: ${file.name}`);
            return false;
          }
          return true;
        });

        const totalFiles = selectedFiles.length + validFiles.length;
        if (totalFiles > MAX_FILES) {
          showError(`Max ${MAX_FILES} images allowed`);
          const allowed = MAX_FILES - selectedFiles.length;
          selectedFiles = [...selectedFiles, ...validFiles.slice(0, allowed)];
        } else {
          selectedFiles = [...selectedFiles, ...validFiles];
        }
        updateFilePreviews();
        updateFileList();
      }

      function resetButton() {
        if (!submitBtn) return;
        submitBtn.disabled = false;
        if (submitText) submitText.textContent = 'Send Request';
        if (submitIcon) submitIcon.classList.remove('hidden');
        if (loadingIcon) loadingIcon.classList.add('hidden');
      }

      function showSuccessModal() {
        if (!successModal) return;

        // Show modal
        successModal.classList.remove('opacity-0', 'invisible');

        // Trigger GSAP animations
        const gsap = (window as any).gsap;

        if (gsap) {
          // Ring draw animation
          gsap.to('#success-ring-progress', {
            strokeDashoffset: 0,
            duration: 1,
            ease: 'power2.inOut'
          });

          // Checkmark reveal with bounce
          gsap.to('#success-check', {
            opacity: 1,
            scale: 1,
            duration: 0.5,
            ease: 'back.out(2)',
            delay: 0.8
          });

          // Staggered content reveal
          gsap.to('#success-label', { opacity: 1, y: 0, duration: 0.6, delay: 1 });
          gsap.to('#success-title', { opacity: 1, y: 0, duration: 0.6, delay: 1.1 });
          gsap.to('#success-message', { opacity: 1, y: 0, duration: 0.6, delay: 1.2 });
          gsap.to('#success-timing', { opacity: 1, y: 0, duration: 0.6, delay: 1.3 });
          gsap.to('#success-next', { opacity: 1, y: 0, duration: 0.6, delay: 1.4 });
          gsap.to('#success-actions', { opacity: 1, y: 0, duration: 0.6, delay: 1.5 });
        } else {
          // Fallback without GSAP
          const ring = document.getElementById('success-ring-progress');
          if (ring) (ring as HTMLElement).style.strokeDashoffset = '0';

          const elements = ['success-check', 'success-label', 'success-title', 'success-message', 'success-timing', 'success-next', 'success-actions'];
          elements.forEach((id) => {
            const el = document.getElementById(id);
            if (el) {
              (el as HTMLElement).style.opacity = '1';
              (el as HTMLElement).style.transform = 'translateY(0)';
            }
          });
        }

        // Scroll to top smoothly
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      // Event Listeners
      if (fileInput) {
        fileInput.addEventListener('change', () => {
          const files = Array.from(fileInput.files || []);
          handleFiles(files);
        });
      }

      if (uploadZone) {
        uploadZone.addEventListener('dragover', (e) => {
          e.preventDefault();
          uploadZone.classList.add('border-sage', 'bg-white/10');
          uploadZone.classList.remove('border-white/20');
        });

        uploadZone.addEventListener('dragleave', (e) => {
          e.preventDefault();
          uploadZone.classList.remove('border-sage', 'bg-white/10');
          uploadZone.classList.add('border-white/20');
        });

        uploadZone.addEventListener('drop', (e) => {
          e.preventDefault();
          uploadZone.classList.remove('border-sage', 'bg-white/10');
          uploadZone.classList.add('border-white/20');
          if (e.dataTransfer?.files) {
            handleFiles(Array.from(e.dataTransfer.files));
          }
        });
      }

      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          if (submitBtn) submitBtn.disabled = true;
          if (submitText) submitText.textContent = 'Sending...';
          if (submitIcon) submitIcon.classList.add('hidden');
          if (loadingIcon) loadingIcon.classList.remove('hidden');
          if (errorMessage) errorMessage.classList.add('hidden');

          try {
            const formData = new FormData(form);
            formData.delete('references');
            selectedFiles.forEach(file => formData.append('references', file));

            const response = await fetch('/api/booking', { method: 'POST', body: formData });
            const result = await response.json();

            if (response.ok && result.success) {
              setTimeout(() => showSuccessModal(), 400);
            } else {
              showError(result.error || 'Something went wrong');
              resetButton();
            }
          } catch (error) {
            showError('Network error');
            resetButton();
          }
        });
      }

      // Animations
      const gsap = (window as any).gsap;
      const ScrollTrigger = (window as any).ScrollTrigger;
      if (!gsap || !ScrollTrigger) return;

      // Hero animations
      gsap.set('.booking-title-line > span', { y: '100%' });
      gsap.set('.booking-hero-subtitle', { opacity: 0, y: 20 });

      const tl = gsap.timeline({ delay: 0.2 });
      tl.to('.booking-title-line > span', { y: '0%', duration: 1, stagger: 0.1, ease: 'power3.out' })
        .to('.booking-hero-subtitle', { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out' }, '-=0.5');

      // Form section animations
      gsap.utils.toArray('.form-section').forEach((section: any) => {
        gsap.from(section, {
          opacity: 0,
          y: 40,
          duration: 0.8,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: section,
            start: 'top 85%'
          }
        });
      });
    };

    document.addEventListener('astro:page-load', initBooking);
  </script>

  <style>
    /* Booking input styles */
    .booking-input {
      width: 100%;
      background: transparent;
      border: none;
      border-bottom: 1px solid rgba(255, 255, 255, 0.2);
      padding: 1rem 0;
      color: white;
      font-family: 'Inter', sans-serif;
      font-size: 1rem;
      line-height: 1.6;
      border-radius: 0;
      appearance: none;
      transition: border-color 0.3s ease;
    }

    .booking-input::placeholder {
      color: var(--text-muted);
    }

    .booking-input:focus {
      outline: none;
      border-bottom-color: var(--color-sage);
    }

    @keyframes fade-in {
      from { opacity: 0; transform: scale(0.95); }
      to { opacity: 1; transform: scale(1); }
    }
    .animate-fade-in {
      animation: fade-in 0.3s ease-out forwards;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-4px); }
      75% { transform: translateX(4px); }
    }
    .animate-shake {
      animation: shake 0.3s ease-out;
    }
  </style>
</SiteLayout>
