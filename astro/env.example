# Copy this file to `astro/.env` for local development (DO NOT commit secrets).
#
# Required for Nextcloud CMS + CalDAV:
NEXTCLOUD_BASE_URL="https://portal.united-tattoos.com"
NEXTCLOUD_USERNAME="service-account"
NEXTCLOUD_PASSWORD="app-password-or-password"
#
# Optional (defaults shown):
NEXTCLOUD_WEBDAV_BASE_PATH="/remote.php/dav/files"
NEXTCLOUD_CMS_ARTISTS_DIR="Artists"


