---
interface ContactItem {
  label: string;
  value: string;
  href?: string;
}

interface Props {
  label?: string;
  title?: string;
  description?: string;
  contactItems?: ContactItem[];
  id?: string;
}

const {
  label = "Get in Touch",
  title = 'Ready to tell your <em>story?</em>',
  description = "We'd love to hear about your vision. Whether it's your first tattoo or your fiftieth, we approach every piece with the same care and dedication.",
  contactItems = [
    { label: "Location", value: "Fountain, Colorado" },
    { label: "Email", value: "hello@unitedtattoo.com", href: "mailto:hello@unitedtattoo.com" },
    { label: "Social", value: "@unitedtattoo", href: "#" },
  ],
  id = "contact",
} = Astro.props;
---

<section class="contact" id={id}>
  <div class="contact-info">
    <span class="contact-label">{label}</span>
    <h2 class="contact-title reveal" set:html={title} />
    <p class="reveal">{description}</p>
    
    <div class="contact-details">
      {contactItems.map((item) => (
        <div class="contact-item reveal">
          <span class="contact-item-label">{item.label}</span>
          <p class="contact-item-value">
            {item.href ? (
              <a href={item.href}>{item.value}</a>
            ) : (
              item.value
            )}
          </p>
        </div>
      ))}
    </div>
  </div>
  
  <div class="contact-form-section">
    <form class="contact-form">
      <div class="form-row reveal">
        <label for="name">Your Name</label>
        <input type="text" id="name" placeholder="How should we call you?">
      </div>
      <div class="form-row reveal">
        <label for="email">Email Address</label>
        <input type="email" id="email" placeholder="your@email.com">
      </div>
      <div class="form-row reveal">
        <label for="vision">Your Vision</label>
        <textarea id="vision" placeholder="Tell us about your tattoo idea, placement, size, and any inspiration you have..."></textarea>
      </div>
      <button type="submit" class="form-submit reveal">
        Send Request
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </button>
    </form>
  </div>
</section>

<style>
  .contact {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 100vh;
  }

  .contact-info {
    padding: 8rem 6rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-label {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--warm-gray);
    margin-bottom: 2rem;
  }

  .contact-title {
    font-family: 'Playfair Display', serif;
    font-weight: 400;
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.2;
    margin-bottom: 3rem;
  }

  .contact-title :global(em) {
    font-style: italic;
    color: var(--terracotta);
  }

  .contact-details {
    margin-top: 3rem;
  }

  .contact-item {
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--cream-dark);
  }

  .contact-item:last-child {
    border-bottom: none;
  }

  .contact-item-label {
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--warm-gray);
    margin-bottom: 0.5rem;
    display: block;
  }

  .contact-item-value {
    font-family: 'Libre Baskerville', serif;
    font-size: 1.1rem;
  }

  .contact-item-value a {
    color: inherit;
    text-decoration: none;
    transition: color 0.3s;
  }

  .contact-item-value a:hover {
    color: var(--terracotta);
  }

  .contact-form-section {
    background: var(--cream-dark);
    padding: 8rem 6rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .contact-form {
    max-width: 500px;
  }

  .form-row {
    margin-bottom: 2rem;
  }

  .form-row label {
    display: block;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--warm-gray);
    margin-bottom: 0.75rem;
  }

  .form-row input,
  .form-row textarea {
    width: 100%;
    padding: 1rem 0;
    border: none;
    border-bottom: 1px solid var(--warm-gray);
    background: transparent;
    font-family: inherit;
    font-size: 1rem;
    color: var(--ink);
    transition: border-color 0.3s;
  }

  .form-row input:focus,
  .form-row textarea:focus {
    outline: none;
    border-color: var(--terracotta);
  }

  .form-row textarea {
    resize: none;
    min-height: 120px;
  }

  .form-row input::placeholder,
  .form-row textarea::placeholder {
    color: var(--warm-gray);
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: var(--ink);
    color: var(--cream);
    border: none;
    padding: 1.25rem 2.5rem;
    font-family: inherit;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s;
    margin-top: 1rem;
  }

  .form-submit:hover {
    background: var(--terracotta);
    gap: 1.5rem;
  }

  .form-submit svg {
    width: 20px;
    height: 20px;
  }

  /* Responsive */
  @media (max-width: 1200px) {
    .contact-info,
    .contact-form-section {
      padding: 6rem 4rem;
    }
  }

  @media (max-width: 1024px) {
    .contact {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .contact-info,
    .contact-form-section {
      padding: 4rem 2rem;
    }
  }
</style>

