---
interface GalleryImage {
  src: string;
  alt: string;
}

interface Props {
  title?: string;
  linkText?: string;
  linkHref?: string;
  images?: GalleryImage[];
  id?: string;
}

const {
  title = "Our <em>Work</em>",
  linkText = "View Full Portfolio",
  linkHref = "#",
  images = [
    { src: "https://images.unsplash.com/photo-1568515045052-f9a854d70bfd?w=800&q=80", alt: "Tattoo artwork" },
    { src: "https://images.unsplash.com/photo-1542359649-6068c0b0abe3?w=600&q=80", alt: "Tattoo artwork" },
    { src: "https://images.unsplash.com/photo-1475403614135-5f1aa0eb5015?w=600&q=80", alt: "Tattoo artwork" },
    { src: "https://images.unsplash.com/photo-1461956846143-95c7b46ca8e0?w=800&q=80", alt: "Tattoo artwork" },
    { src: "https://images.unsplash.com/photo-1590246815117-e8c31569bf05?w=600&q=80", alt: "Tattoo artwork" },
    { src: "https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=600&q=80", alt: "Tattoo artwork" },
    { src: "https://images.unsplash.com/photo-1604941590519-65c8ea85c7e7?w=600&q=80", alt: "Tattoo artwork" },
  ],
  id = "work",
} = Astro.props;
---

<section class="gallery" id={id}>
  <div class="gallery-header">
    <h2 class="gallery-title reveal" set:html={title} />
    <a href={linkHref} class="gallery-link reveal">
      {linkText}
      <span></span>
    </a>
  </div>
  <div class="gallery-grid">
    {images.map((image) => (
      <div class="gallery-item reveal">
        <img src={image.src} alt={image.alt}>
      </div>
    ))}
  </div>
</section>

<style>
  .gallery {
    padding: 10rem 0;
  }

  .gallery-header {
    padding: 0 8rem;
    margin-bottom: 4rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .gallery-title {
    font-family: 'Playfair Display', serif;
    font-weight: 400;
    font-size: clamp(3rem, 8vw, 6rem);
  }

  .gallery-title :global(em) {
    font-style: italic;
    color: var(--terracotta);
  }

  .gallery-link {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: gap 0.3s;
  }

  .gallery-link:hover {
    gap: 1.25rem;
  }

  .gallery-link span {
    width: 30px;
    height: 1px;
    background: currentColor;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: repeat(3, 280px);
    gap: 1rem;
    padding: 0 2rem;
  }

  .gallery-item {
    overflow: hidden;
    position: relative;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .gallery-item:hover img {
    transform: scale(1.08);
  }

  .gallery-item:nth-child(1) { grid-column: 1 / 5; grid-row: 1 / 3; }
  .gallery-item:nth-child(2) { grid-column: 5 / 8; grid-row: 1 / 2; }
  .gallery-item:nth-child(3) { grid-column: 8 / 13; grid-row: 1 / 2; }
  .gallery-item:nth-child(4) { grid-column: 5 / 9; grid-row: 2 / 4; }
  .gallery-item:nth-child(5) { grid-column: 9 / 13; grid-row: 2 / 3; }
  .gallery-item:nth-child(6) { grid-column: 1 / 5; grid-row: 3 / 4; }
  .gallery-item:nth-child(7) { grid-column: 9 / 13; grid-row: 3 / 4; }

  /* Responsive */
  @media (max-width: 1200px) {
    .gallery-header {
      padding: 0 4rem;
    }
  }

  @media (max-width: 1024px) {
    .gallery-grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto;
    }

    .gallery-item {
      grid-column: auto !important;
      grid-row: auto !important;
      height: 300px;
    }
  }

  @media (max-width: 768px) {
    .gallery-header {
      padding: 0 2rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
      padding: 0 1rem;
    }

    .gallery-item {
      height: 250px;
    }
  }
</style>

