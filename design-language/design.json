      "className": "demo-btn",
      "structure": {
        "element": "button.demo-btn",
        "padding": "1rem 1.6rem",
        "borderRadius": "12px",
        "fontSize": "0.85rem",
        "fontWeight": 500,
        "textTransform": "uppercase",
        "letterSpacing": "0.2em",
        "border": "none",
        "cursor": "pointer",
        "transition": "transform 0.2s ease, box-shadow 0.2s ease"
      },
