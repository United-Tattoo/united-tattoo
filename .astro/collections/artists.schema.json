{
  "$ref": "#/definitions/artists",
  "definitions": {
    "artists": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "portrait": {
          "type": "string"
        },
        "galleryDir": {
          "type": "string"
        },
        "specialties": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instagram": {
          "type": "string"
        },
        "facebook": {
          "type": "string"
        },
        "tiktok": {
          "type": "string"
        },
        "twitch": {
          "type": "string"
        },
        "portfolioUrl": {
          "type": "string",
          "format": "uri"
        },
        "bookingEmailCc": {
          "type": "string",
          "format": "email"
        },
        "testimonials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "quote": {
                "type": "string"
              },
              "client": {
                "type": "string"
              }
            },
            "required": [
              "quote",
              "client"
            ],
            "additionalProperties": false
          }
        },
        "calendarId": {
          "type": "string"
        },
        "acceptingBookings": {
          "type": "boolean",
          "default": true
        },
        "schedule": {
          "type": "object",
          "properties": {
            "monday": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "string",
                  "const": "closed"
                }
              ]
            },
            "tuesday": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "string",
                  "const": "closed"
                }
              ]
            },
            "wednesday": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "string",
                  "const": "closed"
                }
              ]
            },
            "thursday": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "string",
                  "const": "closed"
                }
              ]
            },
            "friday": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "string",
                  "const": "closed"
                }
              ]
            },
            "saturday": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "string",
                  "const": "closed"
                }
              ]
            },
            "sunday": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "string",
                  "const": "closed"
                }
              ]
            }
          },
          "required": [
            "monday",
            "tuesday",
            "wednesday",
            "thursday",
            "friday",
            "saturday",
            "sunday"
          ],
          "additionalProperties": false
        },
        "bufferMinutes": {
          "type": "number",
          "default": 30
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "portrait",
        "galleryDir"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}